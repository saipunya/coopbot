  "dependencies": {
    "@google/genai": "^1.47.0",
    "@napi-rs/canvas": "^0.1.97",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "pdfjs-dist": "^5.6.205",
    "sanitize-filename": "^1.6.4",
    "tesseract.js": "^7.0.0",
    "word-extractor": "^1.0.4"
