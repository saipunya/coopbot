<%
  const hasGoogleUser = typeof isGoogleUser !== "undefined" ? Boolean(isGoogleUser) : false;
  const hasAdminUser = typeof currentUser !== "undefined" ? Boolean(currentUser) : false;
  const headerPlanAliases = { standard: "pro", professional: "pro", blue: "pro", "premium-monthly": "premium", "premium-yearly": "premium" };
  const headerPlanSource = hasGoogleUser
    ? (
        (typeof signedInUser !== "undefined" && signedInUser && signedInUser.plan)
        || (typeof data !== "undefined" && data && data.currentPlanContext && data.currentPlanContext.code)
        || (typeof data !== "undefined" && data && data.planContext && data.planContext.code)
        || (typeof data !== "undefined" && data && data.user && data.user.plan)
        || "free"
      )
    : (hasAdminUser ? "admin" : "guest");
  const rawHeaderPlanCode = String(headerPlanSource || "free").trim().toLowerCase();
  const headerPlanCode = ["free", "pro", "premium", "guest", "admin"].includes(rawHeaderPlanCode)
    ? rawHeaderPlanCode
    : (headerPlanAliases[rawHeaderPlanCode] || "free");
  const headerPlanLabelMap = {
    guest: "โหมดผู้เยี่ยมชม",
    free: "แพ็กเกจฟรี",
    pro: "Professional",
    premium: "Premium",
    admin: "ผู้ดูแลระบบ",
  };
  const headerPlanLabel = headerPlanLabelMap[headerPlanCode] || "แพ็กเกจฟรี";
  const headerModeCode = hasAdminUser ? "admin" : (hasGoogleUser ? "user" : "guest");
  const headerModeLabelMap = {
    guest: "โหมด Guest",
    user: "โหมด User",
    admin: "โหมด Admin",
  };
  const headerModeLabel = headerModeLabelMap[headerModeCode] || "โหมด Guest";
%>
<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Coopbot</title>
    <link rel="manifest" href="/manifest-law-chatbot.json" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon/robot-icon-192.png" />
    <link rel="apple-touch-icon" href="/icon/robot-icon-180.png" />
    <style>
      :root {
        color-scheme: light;
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --panel: rgba(255, 255, 255, 0.88);
        --panel-strong: #ffffff;
        --ink: #1f2a37;
        --subtle: #5d6a79;
        --accent: #15547a;
        --accent-strong: #0f4667;
        --accent-soft: #d2e8f7;
        --line: #d8e2ea;
        --ok: #1d7a52;
        --warn: #8b2e2e;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
        --hero-glow: rgba(43, 132, 187, 0.18);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Sarabun', Arial, sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        background-attachment: fixed;
      }
      .shell {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }
      .topbar, .card, .nav {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 20px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
        position: relative;
        overflow: hidden;
      }
      .topbar::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 0% 0%, var(--hero-glow), transparent 38%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.28), transparent 44%);
        pointer-events: none;
      }
      .topbar > * {
        position: relative;
        z-index: 1;
      }
      .brand-stack {
        display: grid;
        gap: 0.35rem;
      }
      .brand {
        font-size: 1.2rem;
        font-weight: 700;
        text-decoration: none;
        color: var(--ink);
      }
      .brand-meta {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        flex-wrap: wrap;
      }
      .brand-chip,
      .brand-subtle {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 999px;
        padding: 0.38rem 0.72rem;
        font-size: 0.82rem;
        font-weight: 700;
      }
      .brand-chip {
        background: linear-gradient(145deg, var(--accent), var(--accent-strong));
        color: #fff;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .brand-subtle {
        background: rgba(255, 255, 255, 0.72);
        color: var(--accent-strong);
        border: 1px solid rgba(255, 255, 255, 0.6);
      }
      .brand-mode {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border-radius: 999px;
        padding: 0.38rem 0.72rem;
        font-size: 0.82rem;
        font-weight: 700;
        border: 1px solid rgba(21, 84, 122, 0.18);
        background: rgba(255, 255, 255, 0.9);
        color: var(--ink);
      }
      .brand-mode::before {
        content: "";
        width: 0.56rem;
        height: 0.56rem;
        border-radius: 50%;
        background: var(--accent);
        box-shadow: 0 0 0 0.18rem rgba(21, 84, 122, 0.12);
      }
      .nav {
        display: flex;
        gap: 0.75rem;
        padding: 0.4rem;
        background: rgba(255, 255, 255, 0.72);
      }
      .nav a {
        text-decoration: none;
        color: var(--ink);
        padding: 0.7rem 1rem;
        border-radius: 14px;
        font-weight: 600;
      }
      .nav a.active {
        background: linear-gradient(145deg, var(--accent), var(--accent-strong));
        color: white;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .card {
        padding: 1.5rem;
        margin-bottom: 1rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.5rem 0 0;
      }
      .button, button {
        border: none;
        background: linear-gradient(145deg, var(--accent), var(--accent-strong));
        color: white;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        text-decoration: none;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      input, textarea, select {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--line);
        margin: 0.35rem 0 1rem;
        font: inherit;
        background: var(--panel-strong);
        color: var(--ink);
      }
      label {
        font-weight: 700;
      }
      p {
        color: var(--subtle);
      }
      a {
        color: var(--accent-strong);
      }
      ul {
        padding-left: 1.2rem;
      }
      @media (max-width: 700px) {
        .shell {
          width: min(100%, calc(100% - 1rem));
          padding: 0.75rem 0 1.4rem;
        }
        .topbar {
          padding: 1rem;
          flex-direction: column;
          align-items: stretch;
        }
        .brand-meta {
          gap: 0.45rem;
        }
        .nav {
          overflow: auto;
          gap: 0.45rem;
          padding: 0.35rem;
        }
        .nav a {
          white-space: nowrap;
          padding: 0.68rem 0.9rem;
          font-size: 0.92rem;
        }
      }

      @media (max-width: 420px) {
        .brand-subtle {
          display: none;
        }
        .nav a {
          padding: 0.64rem 0.82rem;
          font-size: 0.88rem;
        }
      }

      body[data-plan-theme="guest"] {
        --accent: #42647c;
        --accent-strong: #27465d;
        --accent-soft: #deebf4;
        --hero-glow: rgba(90, 128, 157, 0.18);
      }

      body[data-plan-theme="free"] {
        --accent: #2f6e95;
        --accent-strong: #184d6f;
        --accent-soft: #d9edf9;
        --hero-glow: rgba(46, 113, 154, 0.2);
      }

      body[data-plan-theme="pro"] {
        --accent: #0f6d64;
        --accent-strong: #09473f;
        --accent-soft: #d7f0ea;
        --hero-glow: rgba(15, 109, 100, 0.2);
      }

      body[data-plan-theme="premium"] {
        --accent: #8b5a17;
        --accent-strong: #57350d;
        --accent-soft: #f7ead1;
        --hero-glow: rgba(191, 138, 46, 0.24);
        --shadow-soft: 0 22px 50px rgba(75, 53, 18, 0.18);
      }

      body[data-plan-theme="admin"] {
        --accent: #7b2f33;
        --accent-strong: #501417;
        --accent-soft: #f5dfe1;
        --hero-glow: rgba(123, 47, 51, 0.2);
      }
    </style>
  </head>
  <body data-plan-theme="<%= headerPlanCode %>">
    <div class="shell">
      <header class="topbar">
        <div class="brand-stack">
          <a class="brand" href="/law-chatbot">Coopbot</a>
          <div class="brand-meta">
            <span class="brand-chip"><%= headerPlanLabel %></span>
            <span class="brand-mode"><%= headerModeLabel %></span>
            <span class="brand-subtle">ระบบผู้ช่วยค้นหากฎหมายสหกรณ์</span>
          </div>
        </div>
        <nav class="nav">
          <a class="<%= page === 'index' ? 'active' : '' %>" href="/law-chatbot">หน้าแชต</a>
          <% if (hasGoogleUser) { %>
            <a class="<%= page === 'user' ? 'active' : '' %>" href="/user">บัญชีผู้ใช้</a>
            <a class="<%= page === 'payment-request' ? 'active' : '' %>" href="/law-chatbot/payment-request">อัปเกรดแพ็กเกจ</a>
          <% } %>
          <% if (hasAdminUser) { %>
            <a class="<%= page === 'upload' ? 'active' : '' %>" href="/law-chatbot/upload">อัปโหลดเอกสาร</a>
            <a class="<%= page === 'feedback' ? 'active' : '' %>" href="/law-chatbot/feedback">ข้อเสนอแนะ</a>
          <% } %>
        </nav>
      </header>
