<%
  const hasGoogleUser = typeof isGoogleUser !== "undefined" ? Boolean(isGoogleUser) : false;
  const hasAdminUser = typeof currentUser !== "undefined" ? Boolean(currentUser) : false;
%>
<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Coopbot</title>
    <link rel="manifest" href="/manifest-law-chatbot.json" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon/robot-icon-192.png" />
    <link rel="apple-touch-icon" href="/icon/robot-icon-180.png" />
    <style>
      :root {
        color-scheme: light;
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --panel: rgba(255, 255, 255, 0.88);
        --panel-strong: #ffffff;
        --ink: #1f2a37;
        --subtle: #5d6a79;
        --accent: #15547a;
        --accent-strong: #0f4667;
        --accent-soft: #d2e8f7;
        --line: #d8e2ea;
        --ok: #1d7a52;
        --warn: #8b2e2e;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: 'Sarabun', Arial, sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        background-attachment: fixed;
      }
      .shell {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }
      .topbar, .card, .nav {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 20px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
      }
      .brand {
        font-size: 1.2rem;
        font-weight: 700;
        text-decoration: none;
        color: var(--ink);
      }
      .nav {
        display: flex;
        gap: 0.75rem;
        padding: 0.4rem;
        background: rgba(255, 255, 255, 0.72);
      }
      .nav a {
        text-decoration: none;
        color: var(--ink);
        padding: 0.7rem 1rem;
        border-radius: 14px;
        font-weight: 600;
      }
      .nav a.active {
        background: linear-gradient(145deg, var(--accent), var(--accent-strong));
        color: white;
      }
      .card {
        padding: 1.5rem;
        margin-bottom: 1rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.5rem 0 0;
      }
      .button, button {
        border: none;
        background: linear-gradient(145deg, var(--accent), var(--accent-strong));
        color: white;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        text-decoration: none;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      input, textarea, select {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--line);
        margin: 0.35rem 0 1rem;
        font: inherit;
        background: var(--panel-strong);
        color: var(--ink);
      }
      label {
        font-weight: 700;
      }
      p {
        color: var(--subtle);
      }
      a {
        color: var(--accent-strong);
      }
      ul {
        padding-left: 1.2rem;
      }
      @media (max-width: 700px) {
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }
        .nav {
          overflow: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/law-chatbot">Coopbot</a>
        <nav class="nav">
          <a class="<%= page === 'index' ? 'active' : '' %>" href="/law-chatbot">หน้าแชต</a>
          <% if (hasGoogleUser) { %>
            <a class="<%= page === 'user' ? 'active' : '' %>" href="/user">บัญชีผู้ใช้</a>
            <a class="<%= page === 'payment-request' ? 'active' : '' %>" href="/law-chatbot/payment-request">อัปเกรดแพ็กเกจ</a>
          <% } %>
          <% if (hasAdminUser) { %>
            <a class="<%= page === 'upload' ? 'active' : '' %>" href="/law-chatbot/upload">อัปโหลดเอกสาร</a>
            <a class="<%= page === 'feedback' ? 'active' : '' %>" href="/law-chatbot/feedback">ข้อเสนอแนะ</a>
          <% } %>
        </nav>
      </header>
