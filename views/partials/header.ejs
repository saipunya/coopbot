<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Coopbot</title>
    <link rel="manifest" href="/manifest-law-chatbot.json" />
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe6;
        --panel: #fffaf2;
        --ink: #1e2a39;
        --accent: #da8b2d;
        --line: #dfd2bf;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Arial, sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(218, 139, 45, 0.18), transparent 30%),
          linear-gradient(180deg, #f9f3ea 0%, var(--bg) 100%);
      }
      .shell {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 4rem;
      }
      .topbar, .card, .nav {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 20px;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.25rem;
        margin-bottom: 1.5rem;
      }
      .brand {
        font-size: 1.2rem;
        font-weight: 700;
        text-decoration: none;
        color: var(--ink);
      }
      .nav {
        display: flex;
        gap: 0.75rem;
        padding: 0.4rem;
      }
      .nav a {
        text-decoration: none;
        color: var(--ink);
        padding: 0.7rem 1rem;
        border-radius: 14px;
      }
      .nav a.active {
        background: var(--accent);
        color: white;
      }
      .card {
        padding: 1.5rem;
        margin-bottom: 1rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.5rem 0 0;
      }
      .button, button {
        border: none;
        background: var(--accent);
        color: white;
        border-radius: 12px;
        padding: 0.9rem 1.1rem;
        text-decoration: none;
        cursor: pointer;
      }
      input, textarea {
        width: 100%;
        padding: 0.9rem 1rem;
        border-radius: 12px;
        border: 1px solid var(--line);
        margin: 0.35rem 0 1rem;
        font: inherit;
      }
      label {
        font-weight: 700;
      }
      ul {
        padding-left: 1.2rem;
      }
      @media (max-width: 700px) {
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }
        .nav {
          overflow: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header class="topbar">
        <a class="brand" href="/law-chatbot">Coopbot</a>
        <nav class="nav">
          <a class="<%= page === 'index' ? 'active' : '' %>" href="/law-chatbot">Dashboard</a>
          <a class="<%= page === 'upload' ? 'active' : '' %>" href="/law-chatbot/upload">Upload</a>
          <a class="<%= page === 'feedback' ? 'active' : '' %>" href="/law-chatbot/feedback">Feedback</a>
        </nav>
      </header>
