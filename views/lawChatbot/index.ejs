  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (() => {
      const ENABLE_CHAT_CACHE = false;
      const CHAT_CACHE_KEY = 'lawbot-chat-cache-v3';
      const CHAT_CACHE_LIMIT = 20;
      const HEADER_COLLAPSE_KEY = 'lawbot-header-collapsed-v1';
      const PLAN_RIBBON_COLLAPSE_KEY = 'lawbot-plan-ribbon-collapsed-v1';
      const POST_LOGIN_PENDING_CHAT_KEY = 'lawbot-post-login-pending-chat-v1';
      const POST_LOGIN_PENDING_CHAT_MAX_AGE_MS = 30 * 60 * 1000;
      const LEGACY_CHAT_CACHE_KEYS = ['lawbot-chat-cache-v1', 'lawbot-chat-cache-v2', 'lawbot-chat-cache-v3'];
      const isAdminUser = <%- JSON.stringify(Boolean(currentUser)) %>;
      const isGoogleSignedIn = <%- JSON.stringify(Boolean(isGoogleUser)) %>;
      const isSignedInUser = isAdminUser || isGoogleSignedIn;
      const signedInUserAvatarUrl = <%- JSON.stringify(headerUserImage || "") %>;
      const botPackageVariant = <%- JSON.stringify(botPackageVariant) %>;
      const initialAssistantProfile = <%- JSON.stringify(data && data.assistantProfile ? data.assistantProfile : null) %>;
      const botAvatarConfigs = {
        free: {
          iconClass: 'bi-robot',
          avatarClass: 'message-avatar-bot-free',
          badgeText: 'FRE',
          badgeClass: 'bot-avatar-badge-free'
        },
        pro: {
          iconClass: 'bi-robot',
          avatarClass: 'message-avatar-bot-pro',
          badgeText: 'PRO',
          badgeClass: 'bot-avatar-badge-pro'
        },
        premium: {
          iconClass: 'bi-robot',
          avatarClass: 'message-avatar-bot-premium',
          badgeText: 'PRE',
          badgeClass: 'bot-avatar-badge-premium'
        },
        admin: {
          iconClass: 'bi-robot',
          avatarClass: 'message-avatar-bot-admin',
          badgeText: 'ADM',
          badgeClass: 'bot-avatar-badge-admin'
        }
      };

      const assistantAvatarConfigs = {
        male: {
          iconClass: 'bi-person-fill',
          avatarClass: 'message-avatar-bot-assistant-male',
          badgeClass: 'bot-avatar-badge-assistant-male',
          badgeText: 'KR'
        },
        female: {
          iconClass: 'bi-person-standing-dress',
          avatarClass: 'message-avatar-bot-assistant-female',
          badgeClass: 'bot-avatar-badge-assistant-female',
          badgeText: 'DA'
        }
      };

      function getBotAvatarConfig() {
        return botAvatarConfigs[botPackageVariant] || botAvatarConfigs.free;
      }

      const chatMessages = document.getElementById('chatMessages');
      const chatForm = document.getElementById('chatForm');
      const chatInput = document.getElementById('chatInput');
      const composerSuggestions = document.getElementById('composerSuggestions');
      const composerSuggestionsLabelText = document.getElementById('composerSuggestionsLabelText');
      const composerSuggestionsNav = document.getElementById('composerSuggestionsNav');
      const composerSuggestionsPrevBtn = document.getElementById('composerSuggestionsPrevBtn');
      const composerSuggestionsNextBtn = document.getElementById('composerSuggestionsNextBtn');
      const composerSuggestionsPageText = document.getElementById('composerSuggestionsPageText');
      const composerSuggestionsList = document.getElementById('composerSuggestionsList');
      const voiceBtn = document.getElementById('voiceBtn');
      const voiceStatus = document.getElementById('voiceStatus');
      const sendBtn = document.getElementById('sendBtn');
      const debugBtn = document.getElementById('debugBtn');
      const clearChatButtons = Array.from(document.querySelectorAll('[data-clear-chat-control="1"]'));
      const mobileMenuButtons = Array.from(document.querySelectorAll('[data-mobile-menu-control="1"]'));
      const mobileSidebarCloseTargets = Array.from(document.querySelectorAll('.cooplaw-sidebar a, .cooplaw-sidebar button'));
      const toggleHeaderButtons = Array.from(document.querySelectorAll('[data-toggle-header-control="1"]'));
      const togglePlanRibbonButtons = Array.from(document.querySelectorAll('[data-toggle-plan-ribbon-control="1"]'));
      const lawbotApp = document.querySelector('.lawbot-app');
      const planRibbon = document.querySelector('.plan-ribbon');
      const quickButtons = document.querySelectorAll('.quick-btn');
      const installBtn = document.getElementById('installBtn');
      const iosInstallBtn = document.getElementById('iosInstallBtn');
      const onlineBadge = document.getElementById('onlineBadge');
      const adminKnowledgeModalElement = document.getElementById('adminKnowledgeModal');
      const adminKnowledgeForm = document.getElementById('adminKnowledgeForm');
      const adminKnowledgeAlert = document.getElementById('adminKnowledgeAlert');
      const adminKnowledgeQuestionInput = document.getElementById('adminKnowledgeQuestion');
      const adminKnowledgeTargetInput = document.getElementById('adminKnowledgeTarget');
      const adminKnowledgeLawNumberInput = document.getElementById('adminKnowledgeLawNumber');
      const adminKnowledgeTitleInput = document.getElementById('adminKnowledgeTitle');
      const adminKnowledgeContentInput = document.getElementById('adminKnowledgeContent');
      const adminKnowledgeSourceNoteInput = document.getElementById('adminKnowledgeSourceNote');
      const adminKnowledgeSubmitBtn = document.getElementById('adminKnowledgeSubmitBtn');
      const knowledgeSuggestionModalElement = document.getElementById('knowledgeSuggestionModal');
      const knowledgeSuggestionForm = document.getElementById('knowledgeSuggestionForm');
      const knowledgeSuggestionAlert = document.getElementById('knowledgeSuggestionAlert');
      const knowledgeSuggestionTargetInput = document.getElementById('knowledgeSuggestionTarget');
      const knowledgeSuggestionSourceTypeInput = document.getElementById('knowledgeSuggestionSourceType');
      const knowledgeSuggestionTitleInput = document.getElementById('knowledgeSuggestionTitle');
      const knowledgeSuggestionContentInput = document.getElementById('knowledgeSuggestionContent');
      const knowledgeSuggestionSourceReferenceInput = document.getElementById('knowledgeSuggestionSourceReference');
      const knowledgeSuggestionSubmitBtn = document.getElementById('knowledgeSuggestionSubmitBtn');
      const knowledgeSuggestionVoiceBtn = document.getElementById('knowledgeSuggestionVoiceBtn');

      function setMobileMenuOpen(open) {
        if (!lawbotApp) {
          return;
        }

        const shouldOpen = Boolean(open);
        lawbotApp.classList.toggle('mobile-menu-open', shouldOpen);
        document.body.classList.toggle('mobile-menu-open', shouldOpen);
        mobileMenuButtons.forEach((button) => {
          button.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
        });
      }
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      const isAndroidDevice = /android/i.test(window.navigator.userAgent || '');
      const isIosDevice = /iphone|ipad|ipod/i.test(window.navigator.userAgent || '');
      const adminKnowledgeModal = adminKnowledgeModalElement && window.bootstrap
        ? new window.bootstrap.Modal(adminKnowledgeModalElement)
        : null;
      const knowledgeSuggestionModal = knowledgeSuggestionModalElement && window.bootstrap
        ? new window.bootstrap.Modal(knowledgeSuggestionModalElement)
        : null;

      let selectedTarget = 'all';
      let deferredInstallPrompt = null;
      let recognition = null;
      let isListening = false;
      let isSubmitting = false;
      let shouldSubmitVoiceOnEnd = false;
      let pendingAdminKnowledgeResolve = null;
      let pendingKnowledgeSuggestionResolve = null;
      let suggestionRecognition = null;
      let isSuggestionListening = false;
      let currentAssistantProfile = normalizeAssistantProfile(initialAssistantProfile);
      const DEFAULT_FREQUENT_CHAT_SUGGESTIONS = [
        'มาตรา 12 ของ พ.ร.บ.สหกรณ์ คืออะไร',
        'สมาชิกสหกรณ์ลาออกต้องทำอย่างไร',
        'สหกรณ์ประชุมใหญ่สามัญปีละกี่ครั้ง',
        'คณะกรรมการดำเนินการมีอำนาจหน้าที่อะไรบ้าง',
        'การรับสมาชิกใหม่ต้องมีคุณสมบัติอย่างไร',
        'สหกรณ์กู้ยืมเงินจากที่ใดได้บ้าง',
        'กลุ่มเกษตรกรจดทะเบียนต้องใช้เอกสารอะไร',
        'ค่าบำรุงสันนิบาตสหกรณ์คำนวณอย่างไร',
        'นายทะเบียนสหกรณ์มีอำนาจสั่งการเรื่องใดได้บ้าง',
        'เงินปันผลและเงินเฉลี่ยคืนต่างกันอย่างไร',
        'สมาชิกขาดจากสมาชิกภาพในกรณีใดบ้าง',
        'การแก้ไขข้อบังคับสหกรณ์ต้องทำอย่างไร'
      ];
      const MANAGED_CHAT_SUGGESTIONS = <%- JSON.stringify(
        data && Array.isArray(data.suggestedQuestions)
          ? data.suggestedQuestions
              .map((item) => String((item && item.questionText) || '').trim())
              .filter(Boolean)
          : []
      ) %>;
      const FREQUENT_CHAT_SUGGESTIONS = MANAGED_CHAT_SUGGESTIONS.length > 0
        ? MANAGED_CHAT_SUGGESTIONS
        : DEFAULT_FREQUENT_CHAT_SUGGESTIONS;
      const COMPOSER_SUGGESTION_MIN_QUERY_LENGTH = 2;
      const COMPOSER_SUGGESTION_PAGE_SIZE = 4;
      let composerSuggestionPageIndex = 0;
      let composerSuggestionsAreFiltered = false;
      let activeComposerSuggestionIndex = -1;
      let composerSuggestionTouchStartX = 0;
      let composerSuggestionTouchStartY = 0;

      function setOnlineState() {
        const online = navigator.onLine;
        onlineBadge.innerHTML = online
          ? '<i class="bi bi-wifi"></i>ออนไลน์'
          : '<i class="bi bi-wifi-off"></i>ออฟไลน์';
        onlineBadge.style.color = online ? 'var(--ok)' : 'var(--warn)';
      }

      function autoScroll() {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }

      function normalizeAssistantProfile(profile) {
        if (!profile || typeof profile !== 'object') {
          return null;
        }

        const id = String(profile.id || '').trim();
        const label = String(profile.label || '').trim();
        const gender = String(profile.gender || '').trim();

        if (!id && !label) {
          return null;
        }

        return {
          id: id || 'assistant',
          label: label || 'ผู้ช่วยกฎหมาย',
          gender: gender || '',
        };
      }

      function updateAssistantProfile(profile) {
        const normalizedProfile = normalizeAssistantProfile(profile);
        if (!normalizedProfile) {
          return currentAssistantProfile;
        }

        currentAssistantProfile = normalizedProfile;
        return currentAssistantProfile;
      }

      function getAssistantProfileVariant(profile) {
        const normalizedProfile = normalizeAssistantProfile(profile) || currentAssistantProfile;
        return normalizedProfile && normalizedProfile.id ? normalizedProfile.id : '';
      }

      function getAssistantAvatarConfig(profile) {
        const botAvatarConfig = getBotAvatarConfig();
        const variant = getAssistantProfileVariant(profile);
        const override = assistantAvatarConfigs[variant];

        if (!override) {
          return botAvatarConfig;
        }

        return {
          ...botAvatarConfig,
          iconClass: override.iconClass || botAvatarConfig.iconClass,
          avatarClass: `${botAvatarConfig.avatarClass || ''} ${override.avatarClass || ''}`.trim(),
          badgeClass: `${botAvatarConfig.badgeClass || ''} ${override.badgeClass || ''}`.trim(),
          badgeText: override.badgeText || botAvatarConfig.badgeText,
        };
      }

      function buildAssistantProfileHtml(profile) {
        const normalizedProfile = normalizeAssistantProfile(profile) || currentAssistantProfile;
        if (!normalizedProfile || !normalizedProfile.label) {
          return '';
        }

        const variant = getAssistantProfileVariant(normalizedProfile);
        const variantClass = variant ? ` bubble-assistant-name-${variant}` : '';

        return `<div class="bubble-assistant-name${variantClass}"><i class="bi bi-person-badge"></i><span>${escapeHtml(normalizedProfile.label)}</span></div>`;
      }

      function getAssistantPoliteParticle(profile) {
        const variant = getAssistantProfileVariant(profile);
        return variant === 'female' ? 'ค่ะ' : 'ครับ';
      }

      function buildAssistantWelcomeText(options = {}) {
        const normalizedProfile = normalizeAssistantProfile(options.assistantProfile) || currentAssistantProfile;
        const politeParticle = getAssistantPoliteParticle(normalizedProfile);
        const variant = getAssistantProfileVariant(normalizedProfile);

        if (options.afterClear) {
          if (variant === 'female') {
            return `จัดหน้าแชตให้โล่งเรียบร้อยแล้ว${politeParticle} ถ้าอยากเริ่มเรื่องใหม่พิมพ์มาได้เลย`;
          }

          return `เคลียร์บทสนทนาให้เรียบร้อยแล้ว${politeParticle} พร้อมลุยคำถามใหม่ได้ทันที`;
        }

        if (variant === 'female') {
          return `พร้อมช่วยสรุปกฎหมายสหกรณ์และกลุ่มเกษตรกรแบบอ่านง่ายให้${politeParticle} ส่งคำถามเข้ามาได้เลย`;
        }

        return `พร้อมช่วยค้นข้อกฎหมายและประเด็นสำคัญให้แบบตรงประเด็น${politeParticle} ถามมาได้เลย`;
      }

      function buildAssistantWelcomeHtml(options = {}) {
        const normalizedProfile = normalizeAssistantProfile(options.assistantProfile) || currentAssistantProfile;
        const welcomeText = buildAssistantWelcomeText({
          ...options,
          assistantProfile: normalizedProfile,
        });

        return formatBotMessageHtml(welcomeText, [], {
          assistantProfile: normalizedProfile,
        });
      }

      function getComposerSuggestionPageCount() {
        return Math.max(1, Math.ceil(FREQUENT_CHAT_SUGGESTIONS.length / COMPOSER_SUGGESTION_PAGE_SIZE));
      }

      function getPagedComposerSuggestions(pageIndex) {
        const pageCount = getComposerSuggestionPageCount();
        const nextPageIndex = Math.max(0, Math.min(pageIndex, pageCount - 1));
        const startIndex = nextPageIndex * COMPOSER_SUGGESTION_PAGE_SIZE;
        return FREQUENT_CHAT_SUGGESTIONS.slice(startIndex, startIndex + COMPOSER_SUGGESTION_PAGE_SIZE);
      }

      function updateComposerSuggestionPager({ isFiltered = false } = {}) {
        if (!composerSuggestionsNav || !composerSuggestionsPrevBtn || !composerSuggestionsNextBtn || !composerSuggestionsPageText) {
          return;
        }

        composerSuggestionsAreFiltered = Boolean(isFiltered);
        const pageCount = getComposerSuggestionPageCount();
        const shouldShowPager = !isFiltered && pageCount > 1;
        composerSuggestionsNav.hidden = !shouldShowPager;

        if (!shouldShowPager) {
          return;
        }

        composerSuggestionsPageText.textContent = `${composerSuggestionPageIndex + 1}/${pageCount}`;
        composerSuggestionsPrevBtn.disabled = false;
        composerSuggestionsNextBtn.disabled = false;
      }

      function canPageComposerSuggestions() {
        return !composerSuggestionsAreFiltered && getComposerSuggestionPageCount() > 1;
      }

      function goToPreviousComposerSuggestionPage() {
        if (!canPageComposerSuggestions()) return;
        const pageCount = getComposerSuggestionPageCount();
        composerSuggestionPageIndex = (composerSuggestionPageIndex - 1 + pageCount) % pageCount;
        showComposerSuggestions({ animateDirection: 'backward' });
      }

      function goToNextComposerSuggestionPage() {
        if (!canPageComposerSuggestions()) return;
        const pageCount = getComposerSuggestionPageCount();
        composerSuggestionPageIndex = (composerSuggestionPageIndex + 1) % pageCount;
        showComposerSuggestions({ animateDirection: 'forward' });
      }

      function normalizeSuggestionSearchText(value) {
        return String(value || '')
          .normalize('NFKC')
          .toLowerCase()
          .replace(/[^0-9a-zA-Z\u0E00-\u0E7F\s]/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
      }

      const SUGGESTION_SYNONYM_GROUPS = [
        ['พ ร บ', 'พรบ', 'พระราชบัญญัติ'],
        ['คณะกรรมการดำเนินการ', 'กรรมการดำเนินการ', 'คณะกรรมการ', 'กรรมการ'],
        ['นายทะเบียนสหกรณ์', 'นายทะเบียน'],
        ['สมาชิกภาพ', 'ขาดจากสมาชิกภาพ', 'พ้นสมาชิกภาพ'],
        ['เงินปันผล', 'ปันผล'],
        ['เงินเฉลี่ยคืน', 'เฉลี่ยคืน'],
        ['ประชุมใหญ่สามัญ', 'ประชุมใหญ่'],
        ['ข้อบังคับสหกรณ์', 'ข้อบังคับ'],
        ['กลุ่มเกษตรกร', 'กลุ่มเกษตร'],
      ];

      function expandSuggestionAliases(value) {
        const normalizedValue = normalizeSuggestionSearchText(value);
        if (!normalizedValue) {
          return '';
        }

        const expandedTerms = [normalizedValue];
        SUGGESTION_SYNONYM_GROUPS.forEach((group) => {
          const normalizedGroup = group.map((term) => normalizeSuggestionSearchText(term)).filter(Boolean);
          if (!normalizedGroup.length) {
            return;
          }

          const hasGroupMatch = normalizedGroup.some((term) => normalizedValue.includes(term));
          if (!hasGroupMatch) {
            return;
          }

          normalizedGroup.forEach((term) => {
            if (!expandedTerms.includes(term)) {
              expandedTerms.push(term);
            }
          });
        });

        return expandedTerms.join(' ');
      }

      function getSuggestionHighlightTerms(query, suggestion) {
        const rawQuery = String(query || '').trim();
        const rawSuggestion = String(suggestion || '').trim();
        const normalizedQuery = normalizeSuggestionSearchText(rawQuery);
        const normalizedSuggestion = normalizeSuggestionSearchText(rawSuggestion);
        const expandedQuery = expandSuggestionAliases(normalizedQuery);
        const queryTokens = expandedQuery.split(' ').filter((token) => token.length >= 2);
        const highlightTerms = [];

        queryTokens.forEach((token) => {
          if (rawSuggestion.toLowerCase().includes(token.toLowerCase()) && !highlightTerms.includes(token)) {
            highlightTerms.push(token);
          }
        });

        SUGGESTION_SYNONYM_GROUPS.forEach((group) => {
          const normalizedGroup = group.map((term) => normalizeSuggestionSearchText(term)).filter(Boolean);
          const queryHitsGroup = normalizedGroup.some((term) => normalizedQuery.includes(term) || expandedQuery.includes(term));
          const suggestionHitsGroup = normalizedGroup.some((term) => normalizedSuggestion.includes(term));

          if (!queryHitsGroup || !suggestionHitsGroup) {
            return;
          }

          group.forEach((term) => {
            const rawTerm = String(term || '').trim();
            if (!rawTerm) {
              return;
            }

            if (rawSuggestion.toLowerCase().includes(rawTerm.toLowerCase()) && !highlightTerms.includes(rawTerm)) {
              highlightTerms.push(rawTerm);
            }
          });
        });

        return highlightTerms.sort((left, right) => right.length - left.length);
      }

      function highlightComposerSuggestionText(text, query) {
        const rawText = String(text || '');
        const highlightTerms = getSuggestionHighlightTerms(query, rawText);
        if (!highlightTerms.length) {
          return escapeHtml(rawText);
        }

        const pattern = highlightTerms.map((term) => escapeRegExp(term)).join('|');
        if (!pattern) {
          return escapeHtml(rawText);
        }

        const regex = new RegExp(`(${pattern})`, 'gi');
        const segments = rawText.split(regex);

        return segments
          .map((segment) => {
            if (!segment) {
              return '';
            }

            const isMatch = highlightTerms.some((term) => term.toLowerCase() === segment.toLowerCase());
            if (!isMatch) {
              return escapeHtml(segment);
            }

            return `<mark class="composer-suggestion-mark">${escapeHtml(segment)}</mark>`;
          })
          .join('');
      }

      function compactSuggestionSearchText(value) {
        return normalizeSuggestionSearchText(value).replace(/\s+/g, '');
      }

      function buildSuggestionBigrams(value) {
        const compactValue = compactSuggestionSearchText(value);
        if (!compactValue) {
          return [];
        }

        if (compactValue.length === 1) {
          return [compactValue];
        }

        const bigrams = [];
        for (let index = 0; index < compactValue.length - 1; index += 1) {
          bigrams.push(compactValue.slice(index, index + 2));
        }

        return bigrams;
      }

      function calculateBigramSimilarity(source, target) {
        const sourceBigrams = buildSuggestionBigrams(source);
        const targetBigrams = buildSuggestionBigrams(target);

        if (!sourceBigrams.length || !targetBigrams.length) {
          return 0;
        }

        const targetCounts = new Map();
        targetBigrams.forEach((bigram) => {
          targetCounts.set(bigram, (targetCounts.get(bigram) || 0) + 1);
        });

        let overlapCount = 0;
        sourceBigrams.forEach((bigram) => {
          const availableCount = targetCounts.get(bigram) || 0;
          if (availableCount <= 0) {
            return;
          }

          overlapCount += 1;
          targetCounts.set(bigram, availableCount - 1);
        });

        return (2 * overlapCount) / (sourceBigrams.length + targetBigrams.length);
      }

      function calculateTokenMatchScore(queryToken, suggestionTokens, normalizedSuggestion, compactSuggestion) {
        if (!queryToken) {
          return 0;
        }

        const compactQueryToken = compactSuggestionSearchText(queryToken);
        if (!compactQueryToken) {
          return 0;
        }

        if (normalizedSuggestion.includes(queryToken) || compactSuggestion.includes(compactQueryToken)) {
          return 1;
        }

        let bestScore = 0;
        suggestionTokens.forEach((suggestionToken) => {
          const compactSuggestionToken = compactSuggestionSearchText(suggestionToken);
          if (!compactSuggestionToken) {
            return;
          }

          if (
            compactSuggestionToken.startsWith(compactQueryToken) ||
            compactQueryToken.startsWith(compactSuggestionToken)
          ) {
            bestScore = Math.max(bestScore, 0.92);
            return;
          }

          if (
            compactSuggestionToken.includes(compactQueryToken) ||
            compactQueryToken.includes(compactSuggestionToken)
          ) {
            bestScore = Math.max(bestScore, 0.84);
          }

          const similarity = calculateBigramSimilarity(compactQueryToken, compactSuggestionToken);
          if (similarity >= 0.9) {
            bestScore = Math.max(bestScore, 0.88);
            return;
          }

          if (similarity >= 0.72) {
            bestScore = Math.max(bestScore, 0.74);
          } else if (similarity >= 0.58) {
            bestScore = Math.max(bestScore, 0.62);
          }
        });

        return bestScore;
      }

      function scoreComposerSuggestionMatch(query, suggestion) {
        const normalizedQuery = normalizeSuggestionSearchText(query);
        const normalizedSuggestion = normalizeSuggestionSearchText(suggestion);
        const expandedQuery = expandSuggestionAliases(normalizedQuery);
        const expandedSuggestion = expandSuggestionAliases(normalizedSuggestion);
        const compactQuery = compactSuggestionSearchText(expandedQuery);
        const compactSuggestion = compactSuggestionSearchText(expandedSuggestion);

        if (!normalizedQuery || !normalizedSuggestion || !expandedQuery || !expandedSuggestion || !compactQuery || !compactSuggestion) {
          return 0;
        }

        if (
          normalizedQuery === normalizedSuggestion ||
          expandedQuery === expandedSuggestion ||
          compactQuery === compactSuggestion
        ) {
          return 1000;
        }

        const queryTokens = expandedQuery.split(' ').filter(Boolean);
        const suggestionTokens = expandedSuggestion.split(' ').filter(Boolean);
        const fullTextSimilarity = calculateBigramSimilarity(compactQuery, compactSuggestion);
        let score = 0;
        let strongTokenMatches = 0;
        let fuzzyTokenMatches = 0;

        if (expandedSuggestion.includes(expandedQuery) || compactSuggestion.includes(compactQuery)) {
          score += 320;
        }

        queryTokens.forEach((queryToken) => {
          const tokenScore = calculateTokenMatchScore(
            queryToken,
            suggestionTokens,
            expandedSuggestion,
            compactSuggestion
          );

          if (tokenScore >= 0.98) {
            strongTokenMatches += 1;
          }

          if (tokenScore >= 0.62) {
            fuzzyTokenMatches += 1;
          }

          score += tokenScore * 110;
        });

        if (queryTokens.length > 1 && fuzzyTokenMatches === queryTokens.length) {
          score += 180;
        } else if (fuzzyTokenMatches > 0) {
          score += (fuzzyTokenMatches / queryTokens.length) * 90;
        }

        if (strongTokenMatches === queryTokens.length && queryTokens.length > 0) {
          score += 70;
        }

        score += fullTextSimilarity * 180;

        if (
          queryTokens.length >= 2 &&
          fuzzyTokenMatches < Math.ceil(queryTokens.length / 2) &&
          fullTextSimilarity < 0.46 &&
          !expandedSuggestion.includes(expandedQuery)
        ) {
          return 0;
        }

        if (score < 145 && fullTextSimilarity < 0.38 && fuzzyTokenMatches === 0) {
          return 0;
        }

        return score;
      }

      function getFilteredComposerSuggestions(query, count = 6) {
        const normalizedQuery = normalizeSuggestionSearchText(query);
        if (!normalizedQuery) {
          return [];
        }

        return FREQUENT_CHAT_SUGGESTIONS
          .map((question, index) => ({
            question,
            index,
            score: scoreComposerSuggestionMatch(normalizedQuery, question),
          }))
          .filter((item) => item.score > 0)
          .sort((left, right) => {
            if (right.score !== left.score) {
              return right.score - left.score;
            }

            return left.index - right.index;
          })
          .slice(0, count)
          .map((item) => item.question);
      }

      function getComposerSuggestionButtons() {
        if (!composerSuggestionsList) {
          return [];
        }

        return Array.from(composerSuggestionsList.querySelectorAll('[data-composer-question]'));
      }

      function setActiveComposerSuggestion(index) {
        const suggestionButtons = getComposerSuggestionButtons();
        if (!suggestionButtons.length) {
          activeComposerSuggestionIndex = -1;
          return;
        }

        const nextIndex = Math.max(0, Math.min(index, suggestionButtons.length - 1));
        activeComposerSuggestionIndex = nextIndex;
        suggestionButtons.forEach((button, buttonIndex) => {
          const isActive = buttonIndex === nextIndex;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-selected', isActive ? 'true' : 'false');
          if (isActive) {
            button.scrollIntoView({ block: 'nearest' });
          }
        });
      }

      function renderComposerSuggestions(suggestions, labelText, activeIndex = -1, options = {}) {
        if (!composerSuggestions || !composerSuggestionsList) return;

        if (!suggestions.length) {
          hideComposerSuggestions();
          return;
        }

        if (composerSuggestionsLabelText) {
          composerSuggestionsLabelText.textContent = labelText;
        }

        updateComposerSuggestionPager(options);

        composerSuggestionsList.innerHTML = suggestions
          .map((question) => `
            <button
              type="button"
              class="composer-suggestion-btn"
              data-composer-question="${escapeHtml(question)}"
              aria-selected="false"
            >
              <i class="bi bi-chat-left-text"></i>
              <span>${options.queryText ? highlightComposerSuggestionText(question, options.queryText) : escapeHtml(question)}</span>
            </button>
          `)
          .join('');

        composerSuggestionsList.classList.remove('is-sliding-forward', 'is-sliding-backward');
        if (options.animateDirection === 'forward' || options.animateDirection === 'backward') {
          void composerSuggestionsList.offsetWidth;
          composerSuggestionsList.classList.add(
            options.animateDirection === 'forward' ? 'is-sliding-forward' : 'is-sliding-backward'
          );
        }

        composerSuggestions.hidden = false;
        if (activeIndex >= 0) {
          setActiveComposerSuggestion(activeIndex);
          return;
        }

        activeComposerSuggestionIndex = -1;
      }

      function selectComposerSuggestion(question) {
        const trimmedQuestion = String(question || '').trim();
        if (!trimmedQuestion || isSubmitting) return;

        hideComposerSuggestions();
        chatInput.value = '';
        submitMessage(trimmedQuestion);
      }

      function hideComposerSuggestions() {
        if (!composerSuggestions) return;
        composerSuggestions.hidden = true;
        composerSuggestionsAreFiltered = false;
        activeComposerSuggestionIndex = -1;
      }

      function showComposerSuggestions(options = {}) {
        if (!composerSuggestions || !composerSuggestionsList || isSubmitting) return;
        const currentQuery = String(chatInput.value || '').trim();
        if (!currentQuery || compactSuggestionSearchText(currentQuery).length < COMPOSER_SUGGESTION_MIN_QUERY_LENGTH) {
          hideComposerSuggestions();
          return;
        }

        const matchedSuggestions = getFilteredComposerSuggestions(currentQuery, 6);
        renderComposerSuggestions(matchedSuggestions, 'คำถามที่ตรงกับข้อความที่พิมพ์', -1, {
          isFiltered: true,
          queryText: currentQuery,
        });
      }

      function focusFirstAnswer(row) {
        if (!row) return;
        const topOffset = 10;
        const targetTop = Math.max(0, row.offsetTop - topOffset);
        chatMessages.scrollTo({ top: targetTop, behavior: 'smooth' });
      }

      function setHeaderCollapsed(collapsed) {
        if (!lawbotApp || !toggleHeaderButtons.length) return;
        lawbotApp.classList.toggle('headers-collapsed', collapsed);

        toggleHeaderButtons.forEach((button) => {
