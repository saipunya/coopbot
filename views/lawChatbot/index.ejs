    .lawbot-hero,
    .chat-shell,
    .quick-questions,
    .legalbot-site-footer {
      width: min(1180px, calc(100% - 2rem));
    }

    .lawbot-hero {
      display: none;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: center;
      margin-top: 0.8rem;
    }

    .lawbot-hero-brand {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      min-width: 0;
    }

    .lawbot-hero-icon {
      width: 4.1rem;
      height: 4.1rem;
      border-radius: 1rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(145deg, #4d85c7, #2f67ac);
      color: #fff;
      box-shadow: 0 14px 28px rgba(40, 91, 158, 0.24);
      flex: 0 0 auto;
    }

    .lawbot-hero-icon img {
      width: 2.85rem;
      height: 2.85rem;
      object-fit: contain;
    }

    .lawbot-hero h1 {
      margin: 0;
      color: #143f81;
      font-size: clamp(1.18rem, 2vw, 1.45rem);
      font-weight: 800;
    }

    .lawbot-hero p {
      margin: 0.22rem 0 0;
      color: #66758d;
      font-size: 0.96rem;
    }

    .lawbot-hero-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .lawbot-action-btn {
      min-height: 3.08rem;
      padding: 0.72rem 1.05rem;
      border-radius: 0.88rem;
      border: 1px solid rgba(178, 195, 218, 0.74);
      background: rgba(255, 255, 255, 0.88);
      color: #485a74;
      box-shadow: 0 12px 24px rgba(35, 66, 108, 0.09);
      display: inline-flex;
      align-items: center;
      gap: 0.55rem;
      font-weight: 700;
      text-decoration: none;
      transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
    }

    .lawbot-action-btn:hover,
    .lawbot-action-btn:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(75, 133, 199, 0.46);
      box-shadow: 0 16px 30px rgba(35, 66, 108, 0.13);
      color: #214b85;
      outline: none;
    }

    .lawbot-action-btn i {
      color: #2f70bd;
      font-size: 1.08rem;
    }

    .lawbot-action-btn-danger i {
      color: #f04438;
    }

    .chat-shell {
      border-radius: 1.1rem;
      border: 1px solid rgba(198, 213, 232, 0.92);
      background: rgba(255, 255, 255, 0.72);
      box-shadow: none;
      min-height: min(82dvh, 920px);
      overflow: hidden;
      position: relative;
      z-index: 1;
    }

    .chat-messages {
      min-height: calc(100dvh - 232px);
      padding: 1.2rem 1.35rem;
      gap: 1.05rem;
      background:
        radial-gradient(circle at 16% 22%, rgba(80, 139, 205, 0.08), transparent 26%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(247, 250, 254, 0.98));
    }

    .chat-day-pill {
      align-self: center;
      padding: 0.52rem 1.35rem;
      border-radius: 999px;
      background: #eef4fd;
      border: 1px solid #d5e2f5;
      color: #27456f;
      font-weight: 800;
      box-shadow: 0 8px 18px rgba(31, 78, 139, 0.06);
    }

    .message-row {
      gap: 0.9rem;
    }

    .message-avatar {
      width: 3.7rem;
      height: 3.7rem;
      border: 6px solid #fff;
      box-shadow: 0 10px 24px rgba(34, 63, 87, 0.14);
    }

    .message-avatar-bot .bot-avatar-icon {
      font-size: 1.42rem;
    }

    .message-avatar-bot .bot-avatar-badge {
      right: -0.32rem;
      bottom: 0.02rem;
      min-width: 1.58rem;
      height: 1.25rem;
      font-size: 0.58rem;
    }

    .message-avatar-user {
      background: radial-gradient(circle at 50% 28%, #7fa7db 0 20%, #1b57a4 42%, #123d83 78%);
      color: #fff;
      overflow: hidden;
    }

    .message-avatar-user img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
    }

    .bubble {
      border-radius: 1rem;
      padding: 1.08rem 1.34rem;
      max-width: min(78%, 820px);
      box-shadow: 0 12px 28px rgba(35, 66, 108, 0.11);
    }

    .bubble-user {
      background: linear-gradient(145deg, #477fc3, #336caf);
      border: 0;
      border-bottom-right-radius: 0.98rem;
      color: #fff;
      font-size: 1rem;
    }

    .bubble-bot {
      border: 1px solid rgba(221, 229, 240, 0.98);
      border-left: 0;
      background: #fff;
      border-bottom-left-radius: 0.98rem;
    }

    .bubble-bot .bubble-message {
      line-height: 0.3;
    }

    .bubble-assistant-name {
      margin-bottom: 0.64rem;
      font-size: 0.96rem;
      color: #174b8e;
    }

    .bot-answer-summary,
    .answer-bullet-card-content {
      color: #253653;
      line-height: 1.72;
      font-size: 0.97rem;
    }

    .answer-bullet-card {
      border: 1px solid rgba(214, 226, 242, 0.92);
      box-shadow: 0 8px 18px rgba(35, 66, 108, 0.06);
      background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      padding: 0.72rem 0.88rem;
      min-height: 0;
      border-radius: 0.86rem 0.86rem 0.86rem 0.28rem;
    }

    .answer-bullet-card::before {
      display: block;
      width: 3px;
      background: linear-gradient(180deg, rgba(69, 126, 195, 0.42), rgba(69, 126, 195, 0.12));
    }

    .answer-bullet-card::after {
      display: none;
      content: "";
    }

    .answer-bullet-card-content {
      padding-left: 0;
    }

    .bot-answer-section-title {
      font-weight: 700;
      color: #0f7a4e;
      margin-bottom: 0.40rem;
      background: transparent;
      padding: 0;
      border-radius: 0;
      font-size: 0.95rem;
    }

    .bot-reference-collapse-panel {
      background: #fff8ec;
      border-color: #f3d6a0;
      border-radius: 0.72rem;
    }

    .bot-reference-toggle {
      background: #fff8ec;
      border-color: #f3d6a0;
      color: #94611b;
      border-radius: 0.78rem;
      padding: 0.55rem 0.78rem;
    }

    .feedback-actions .feedback-icon-btn,
    .feedback-actions .btn-knowledge-suggestion,
    .feedback-actions .btn-admin-knowledge {
      border-radius: 0.62rem;
      background: #f8fbff;
      border-color: #dae5f2;
      color: #52657d;
    }

    .chat-input-wrap {
      margin: 0.9rem 1rem 1rem;
      padding: 0.72rem;
      border: 1.5px solid #94b8e7;
      border-radius: 1rem;
      background: rgba(255, 255, 255, 0.96);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.62);
    }

    .chat-input-wrap .input-group {
      gap: 0.65rem;
      align-items: stretch;
    }

    #chatInput {
      min-height: 3.25rem;
      border: 0;
      border-radius: 0.84rem !important;
      background: #fff;
      font-size: 1rem;
      padding-left: 0.82rem;
    }

    #voiceBtn,
    #debugBtn {
      min-width: 5.5rem;
      border-radius: 0.72rem !important;
      border-color: #cddbef;
      color: #315b91;
      font-weight: 700;
      background: #f8fbff;
    }

    #sendBtn {
      min-width: 8rem;
      border-radius: 0.72rem !important;
      border: 0;
      background: linear-gradient(145deg, #457ec3, #336caf);
      box-shadow: 0 12px 22px rgba(51, 108, 175, 0.2);
      font-weight: 800;
    }

    .composer-inline-only {
      display: none !important;
    }

    .composer-hint {
      justify-content: flex-end;
      color: #8a96a8;
      font-size: 0.82rem;
    }

    .quick-questions {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      flex-wrap: wrap;
      border: 0;
      background: transparent;
      box-shadow: none;
      backdrop-filter: none;
      margin-top: -0.1rem;
    }

    .quick-questions-title {
      color: #233d66;
      font-weight: 800;
      margin-right: 0.4rem;
    }

    .quick-btn {
      color: #3c4f6b;
      background: #f6f8fb;
      border-color: #d9e2ee;
      box-shadow: none;
      padding: 0.58rem 1.1rem;
    }

    .legalbot-site-footer {
      margin-top: auto;
      width: 100%;
      padding: 1rem clamp(1rem, 3vw, 2rem);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
      gap: 1rem;
      align-items: center;
      color: #fff;
      background: linear-gradient(135deg, #447fbf, #3c76b6);
      font-size: 0.86rem;
    }

    .legalbot-footer-links {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(0.8rem, 2.8vw, 2.2rem);
      flex-wrap: wrap;
      font-weight: 800;
    }

    .legalbot-footer-links a,
    .legalbot-footer-security {
      color: rgba(255, 255, 255, 0.92);
      text-decoration: none;
    }

    .legalbot-footer-security {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.6rem;
      font-weight: 800;
    }

    .legalbot-footer-security i {
      width: 2.1rem;
      height: 2.1rem;
      border-radius: 0.72rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #35c56e;
      box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.42);
    }

    @media (max-width: 991.98px) {
      .page-header {
        grid-template-columns: minmax(0, 1fr) auto;
      }

      .lawbot-hero,
      .lawbot-hero-actions {
        width: 100%;
      }

      .page-toolbar {
        width: auto;
      }

      .lawbot-hero {
        grid-template-columns: 1fr;
      }

      .lawbot-hero-actions {
        justify-content: flex-start;
      }

      .bubble {
        max-width: min(88%, 760px);
      }
    }

    @media (max-width: 767.98px) {
      .lawbot-app {
        height: auto;
        min-height: 100dvh;
        overflow: visible;
        gap: 0.48rem;
      }

      .page-header {
        --header-icon-size: 2.45rem;
        padding: 0.52rem 0.64rem;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        gap: 0.38rem;
      }

      .brand-title p {
        display: block;
        font-size: 0.68rem;
      }

      #onlineBadge {
        display: inline-flex;
      }

      #onlineBadge.status-chip {
        padding: 0.32rem;
        font-size: 0;
      }

      #onlineBadge i {
        font-size: 0.78rem;
      }

      .page-toolbar {
        width: auto;
        flex-wrap: nowrap;
        justify-content: flex-end;
      }

      .page-identity {
        min-width: 0;
        width: 2.54rem;
        height: 2.54rem;
        padding: 0.18rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0.95rem;
        cursor: pointer;
      }

      .page-identity:focus-visible {
        outline: 2px solid rgba(255, 255, 255, 0.88);
        outline-offset: 3px;
      }

      .page-identity::after {
        content: "";
        position: absolute;
        right: 0.24rem;
        bottom: 0.24rem;
        width: 0.62rem;
        height: 0.62rem;
        border-radius: 999px;
        background: #48d37a;
        border: 2px solid rgba(255, 255, 255, 0.94);
      }

      .page-identity-avatar {
        width: 2rem;
        height: 2rem;
        border-radius: 0.64rem;
        flex: 0 0 auto;
      }

      .page-identity-text,
      .page-identity-actions,
      .page-actions {
        display: none;
      }

      .page-identity .page-identity-actions {
        position: fixed;
        top: calc(env(safe-area-inset-top) + 3.35rem);
        right: 0.58rem;
        z-index: 1000;
        min-width: 10.8rem;
        padding: 0.5rem;
        border-radius: 0.9rem;
        border: 1px solid rgba(205, 219, 239, 0.92);
        background: rgba(255, 255, 255, 0.98);
        box-shadow: 0 18px 36px rgba(24, 62, 111, 0.2);
        flex-direction: column;
        gap: 0.42rem;
      }

      .page-identity .page-identity-actions::before {
        content: "";
        position: absolute;
        top: -0.42rem;
        right: 0.82rem;
        width: 0.78rem;
        height: 0.78rem;
        background: rgba(255, 255, 255, 0.98);
        border-left: 1px solid rgba(205, 219, 239, 0.92);
        border-top: 1px solid rgba(205, 219, 239, 0.92);
        transform: rotate(45deg);
      }

      .page-identity:hover .page-identity-actions,
      .page-identity:focus-within .page-identity-actions {
        display: flex;
      }

      .page-identity .page-identity-action {
        width: 100%;
        min-height: 2.28rem;
        justify-content: flex-start;
        border-radius: 0.7rem;
        border-color: rgba(58, 113, 181, 0.16);
        background: #f7fbff !important;
        color: #1c4f8e !important;
        font-size: 0.78rem;
        box-shadow: none;
      }

      .page-identity .page-identity-action.primary {
        background: linear-gradient(145deg, #457ec3, #336caf) !important;
        color: #fff !important;
      }

      .lawbot-hero,
      .chat-shell,
      .quick-questions {
        width: min(100% - 0.9rem, 1180px);
      }

      .lawbot-hero {
        margin-top: 0.2rem;
      }

      .lawbot-hero-actions {
        display: none;
      }

      .lawbot-action-btn {
        flex: 1 1 100%;
        justify-content: center;
      }

      .chat-shell {
        flex: initial;
        min-height: 0;
        border-radius: 0.9rem;
      }

      .chat-messages {
        min-height: calc(100dvh - 174px);
        padding: 0.85rem 0.7rem;
      }

      .message-avatar {
        width: 2.9rem;
        height: 2.9rem;
        border-width: 4px;
      }

      .message-row {
        gap: 0.55rem;
      }

      .bubble {
        max-width: 100%;
        padding: 0.9rem 0.92rem;
      }

      .answer-bullet-card {
        padding: 0.68rem 0.76rem;
      }

      .answer-bullet-card::after {
        display: none;
      }

      .chat-input-wrap {
        margin: 0.55rem;
      }

      #voiceBtn,
      #debugBtn,
      #sendBtn {
        min-width: 0;
        flex: 1 1 auto;
      }

      .legalbot-site-footer {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .legalbot-footer-security {
        justify-content: center;
      }
    }

