      font-size: clamp(0.9rem, 1.25vw, 1.08rem);
      letter-spacing: 0.01em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .brand-title p {
      display: block;
      margin: 0.08rem 0 0;
      color: rgba(255, 255, 255, 0.82);
      font-size: 0.76rem;
    }

    #onlineBadge.status-chip {
      color: #fff;
      background: rgba(255, 255, 255, 0.14);
      border-color: rgba(255, 255, 255, 0.34);
      padding: 0.42rem 0.7rem;
      font-size: 0.76rem;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    #onlineBadge i {
      color: #48d37a;
      filter: drop-shadow(0 0 5px rgba(72, 211, 122, 0.56));
    }

    .page-toolbar {
      gap: 0.58rem;
      overflow: visible;
      z-index: 190;
    }

    .page-identity {
      min-width: min(246px, 28vw);
      padding: 0.34rem 0.45rem;
      border-radius: 0.88rem;
