    .page-header {
      width: 100%;
      --header-icon-size: 2.82rem;
      --header-icon-radius: 999px;
      --header-icon-font-size: 1rem;
      border: 0;
      border-radius: 0;
      padding: 0.58rem clamp(0.82rem, 2.2vw, 1.45rem);
      color: #fff;
      background:
        linear-gradient(135deg, rgba(59, 122, 190, 0.98), rgba(74, 137, 199, 0.98)),
        radial-gradient(circle at 8% 8%, rgba(255, 255, 255, 0.22), transparent 28%);
      box-shadow: 0 12px 30px rgba(26, 72, 124, 0.18);
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: clamp(0.62rem, 1.4vw, 1.05rem);
      overflow: visible;
      position: relative;
      z-index: 180;
    }

    .page-header::before {
      background:
        radial-gradient(circle at 16% 50%, rgba(255, 255, 255, 0.16), transparent 20%),
        linear-gradient(90deg, rgba(255, 255, 255, 0.06), transparent 48%);
      pointer-events: none;
    }

    .brand-icon {
      background: rgba(255, 255, 255, 0.12);
      border: 2px solid rgba(255, 255, 255, 0.82);
      box-shadow: inset 0 0 0 2px rgba(255, 255, 255, 0.18), 0 10px 18px rgba(9, 44, 91, 0.16);
      overflow: hidden;
