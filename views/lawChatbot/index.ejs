                class="btn btn-admin-knowledge btn-sm"
                data-admin-knowledge="1"
                data-question="${escapeHtml(question)}"
                data-answer-shown="${escapeHtml(answerShown)}"
                data-target="${escapeHtml(target || selectedTarget)}"
              >บันทึกเข้าระบบทันที</button>
            `
          );
        }

        const answerActionsRow = container.querySelector('.bot-answer-actions-row');
        if (answerActionsRow) {
          answerActionsRow.appendChild(wrap);
          return;
        }

        container.appendChild(wrap);
      }

      function buildTimingDebugHtml(debug) {
        const timing = debug && debug.timing ? debug.timing : null;
        if (!timing) return '';

        const lines = [];
        if (typeof timing.databaseSearchMs === 'number') lines.push(`ค้นฐานข้อมูล ${timing.databaseSearchMs} ms`);
        if (typeof timing.internetSearchMs === 'number') lines.push(`ค้นอินเทอร์เน็ต ${timing.internetSearchMs} ms`);
        if (typeof timing.totalSourceCollectionMs === 'number') lines.push(`รวมค้นแหล่งข้อมูล ${timing.totalSourceCollectionMs} ms`);
        if (typeof timing.answerGenerationMs === 'number') lines.push(`สรุปคำตอบ ${timing.answerGenerationMs} ms`);
        if (typeof timing.totalReplyMs === 'number') lines.push(`รวมทั้งหมด ${timing.totalReplyMs} ms`);

        const sourceTierValue = debug && (debug.selectedSourceTierLabel || debug.selectedSourceTier)
          ? `แหล่งที่ใช้: ${escapeHtml(debug.selectedSourceTierLabel || debug.selectedSourceTier)}`
          : '';
        const sourceTablesValue = debug && Array.isArray(debug.sourceTables) && debug.sourceTables.length
          ? `ตารางที่ใช้: ${escapeHtml(debug.sourceTables.join(' | '))}`
          : '';
        const consideredSourceTablesValue = debug && Array.isArray(debug.consideredSourceTables) && debug.consideredSourceTables.length
          ? `ตารางที่พิจารณาแต่ไม่เลือก: ${escapeHtml(debug.consideredSourceTables.join(' | '))}`
          : '';
        const summary = lines.length ? escapeHtml(lines.join(' | ')) : '';
        if (!summary && !sourceTierValue && !sourceTablesValue && !consideredSourceTablesValue) return '';

        return `
          <div class="timing-debug">
            ${sourceTierValue ? `<div>${sourceTierValue}</div>` : ''}
            ${sourceTablesValue ? `<div>${sourceTablesValue}</div>` : ''}
            ${consideredSourceTablesValue ? `<div>${consideredSourceTablesValue}</div>` : ''}
            ${summary ? `<div>${summary}</div>` : ''}
          </div>
        `;
      }

      function looksLikeCurrentInfoQuestion(message) {
        return /(ล่าสุด|ปัจจุบัน|ขณะนี้|วันนี้|ตอนนี้|ประกาศใหม่|อัปเดต|update|news|ข่าว)/i.test(String(message || ''));
      }

      function buildLoadingBubbleHtml(text, hint = '') {
        const loadingAvatarConfig = getAssistantAvatarConfig(currentAssistantProfile);
        const assistantProfileHtml = buildAssistantProfileHtml(currentAssistantProfile);
        return `
          ${assistantProfileHtml}
          <span class="loading-status">
            <span class="loading-status-icon"><i class="bi ${loadingAvatarConfig.iconClass || 'bi-robot'}"></i></span>
            <span class="loading-status-text">
              <span class="loading-status-label">${escapeHtml(text || 'กำลังประมวลผลคำถาม')}</span>
              <span class="loading-status-dots" aria-hidden="true"><span></span><span></span><span></span></span>
            </span>
          </span>
          ${hint ? `<span class="loading-status-hint">${escapeHtml(hint)}</span>` : ''}
        `;
      }

      function updateLoadingBubbleStage(row, stage = {}) {
        if (!row) return;
        const messageNode = row.querySelector('.bubble-message');
        if (!messageNode) return;
        messageNode.innerHTML = buildLoadingBubbleHtml(stage.text || 'กำลังประมวลผลคำถาม', stage.hint || '');
      }

      function createLoadingBubbleController(row, message) {
        const timers = [];
        const normalizedMessage = String(message || '').trim();
        const stages = looksLikeCurrentInfoQuestion(normalizedMessage)
          ? [
              { delay: 0, text: 'กำลังค้นฐานข้อมูล...', hint: 'เริ่มจากข้อมูลภายในระบบก่อน' },
              { delay: 1400, text: 'กำลังสรุปคำตอบ...', hint: 'กำลังจัดเรียงสาระสำคัญให้อ่านง่าย' },
              { delay: 3200, text: 'กำลังตรวจสอบข้อมูลเพิ่มเติม...', hint: 'คำถามนี้อาจต้องเช็กข้อมูลล่าสุดเพิ่ม' }
            ]
          : [
              { delay: 0, text: 'กำลังค้นฐานข้อมูล...', hint: 'กำลังค้นหาข้อมูลที่เกี่ยวข้องในระบบ' },
              { delay: 1400, text: 'กำลังสรุปคำตอบ...', hint: 'กำลังจัดรูปคำตอบให้อ่านง่ายและตรงประเด็น' },
              { delay: 3200, text: 'กำลังรวบรวมสาระสำคัญเพิ่มเติม...', hint: 'หากคำถามซับซ้อน ระบบอาจใช้เวลาสักครู่' }
            ];

        stages.forEach((stage) => {
          const timerId = window.setTimeout(() => {
            updateLoadingBubbleStage(row, stage);
          }, stage.delay);
          timers.push(timerId);
        });

        return {
          dispose() {
            timers.forEach((timerId) => window.clearTimeout(timerId));
          }
        };
      }

      function addBubble(text, role, isLoading = false, highlightTerms = [], feedbackContext = null, shouldAutoScroll = true, restoreOptions = {}) {
        const displayText = role === 'bot' ? stripBotUiNoiseText(sanitizeDisplayText(text)) : String(text || '');
        const row = document.createElement('div');
        row.className = `message-row ${role === 'user' ? 'message-user' : 'message-bot'}`;
        const resolvedAssistantProfile = role === 'bot'
          ? updateAssistantProfile(
              (feedbackContext && feedbackContext.assistantProfile)
              || (restoreOptions && restoreOptions.assistantProfile)
              || currentAssistantProfile
            )
          : null;

        const avatar = document.createElement('div');
        if (role === 'user') {
          avatar.className = 'message-avatar message-avatar-user';
          avatar.innerHTML = signedInUserAvatarUrl
            ? `<img src="${escapeHtml(signedInUserAvatarUrl)}" alt="โปรไฟล์ผู้ใช้" />`
            : '<i class="bi bi-person-fill"></i>';
        } else {
          const botAvatarConfig = getAssistantAvatarConfig(resolvedAssistantProfile);
          avatar.className = `message-avatar message-avatar-bot ${botAvatarConfig.avatarClass || 'message-avatar-bot-free'}`;
          avatar.innerHTML = `
            <i class="bi ${botAvatarConfig.iconClass || 'bi-robot'} bot-avatar-icon"></i>
            <span class="bot-avatar-badge ${botAvatarConfig.badgeClass || 'bot-avatar-badge-free'}">${escapeHtml(botAvatarConfig.badgeText || 'BOT')}</span>
          `;
        }

        const bubbleVariantClass = feedbackContext && feedbackContext.variant === 'ai' ? ' bubble-ai' : '';
        const div = document.createElement('div');
        div.className = `bubble ${role === 'user' ? 'bubble-user' : 'bubble-bot'}${bubbleVariantClass}${isLoading ? ' bubble-loading' : ''}`;
        if (resolvedAssistantProfile) {
          div.dataset.assistantProfile = JSON.stringify(resolvedAssistantProfile);
        }
        const content = document.createElement('div');
        content.className = `bubble-content ${role === 'user' ? 'bubble-content-user' : ''}`;

        const message = document.createElement('span');
        message.className = 'bubble-message';
        if (role === 'bot' && isLoading) {
          message.innerHTML = buildLoadingBubbleHtml(displayText || 'กำลังประมวลผลคำถาม', 'กำลังค้นหาข้อมูลที่เกี่ยวข้องในระบบ');
        } else if (role === 'bot' && !isLoading) {
          if (restoreOptions && typeof restoreOptions.renderedHtml === 'string' && restoreOptions.renderedHtml) {
            message.innerHTML = sanitizeRenderedDisplayHtml(restoreOptions.renderedHtml);
          } else {
            message.innerHTML = formatBotMessageHtml(displayText, highlightTerms, feedbackContext || {});
          }
        } else if (restoreOptions && typeof restoreOptions.renderedHtml === 'string' && restoreOptions.renderedHtml) {
          message.innerHTML = sanitizeRenderedDisplayHtml(restoreOptions.renderedHtml);
        } else {
          message.textContent = displayText;
        }

        if (shouldShowAssistantBubbleHeader(role, isLoading, message.innerHTML)) {
          const assistantProfileHtml = buildAssistantProfileHtml(resolvedAssistantProfile);
          if (assistantProfileHtml) {
            content.insertAdjacentHTML('beforeend', assistantProfileHtml);
          }
        }

        content.appendChild(message);

        if (role === 'bot' && !isLoading && feedbackContext && feedbackContext.debug) {
          const timingHtml = buildTimingDebugHtml(feedbackContext.debug);
          if (timingHtml) {
            content.insertAdjacentHTML('beforeend', timingHtml);
          }
        }

        if (
          role === 'bot' &&
          !isLoading &&
          feedbackContext &&
          !feedbackContext.suppressKnowledgeActions &&
          !feedbackContext.guestLimitReached &&
          !feedbackContext.monthlyUsageLimitReached
        ) {
          attachFeedbackActions(content, {
            question: feedbackContext.question || '',
            answerShown: displayText,
            target: feedbackContext.target || selectedTarget,
          });
        }

        div.appendChild(content);

        if (role === 'user') {
          row.appendChild(div);
          row.appendChild(avatar);
        } else {
          row.appendChild(avatar);
          row.appendChild(div);
        }

        chatMessages.appendChild(row);
        if (shouldAutoScroll) autoScroll();
        return row;
      }

      function stripGuestLoginCtaHtml(html) {
        return String(html || '').replace(/<div class="bot-inline-actions">[\s\S]*?<\/div>/gi, '').trim();
      }

      function isGuestLimitMessage(text) {
        return /ใช้สิทธิ์ถามคำถามในโหมด (guest|ผู้เยี่ยมชม) ครบ 2 ครั้งแล้ว/i.test(String(text || ''));
      }

      function normalizeChatTarget(value) {
        return value === 'group' ? 'group' : value === 'coop' ? 'coop' : 'all';
      }

      function getPendingChatStorage() {
        try {
          if (window.sessionStorage) return window.sessionStorage;
        } catch (_) {}

        try {
          if (window.localStorage) return window.localStorage;
        } catch (_) {}

        return null;
      }

      function clearPendingPostLoginChat() {
        const storage = getPendingChatStorage();
        if (!storage) return;

        try {
          storage.removeItem(POST_LOGIN_PENDING_CHAT_KEY);
        } catch (_) {}
      }

      function savePendingPostLoginChat(message, target) {
        const storage = getPendingChatStorage();
        const trimmedMessage = String(message || '').trim();
        if (!storage || !trimmedMessage) return;

        try {
          storage.setItem(POST_LOGIN_PENDING_CHAT_KEY, JSON.stringify({
            message: trimmedMessage,
            target: normalizeChatTarget(target),
            createdAt: Date.now()
          }));
        } catch (_) {}
      }

      function consumePendingPostLoginChat() {
        if (!isSignedInUser) return null;

        const storage = getPendingChatStorage();
        if (!storage) return null;

        try {
          const raw = storage.getItem(POST_LOGIN_PENDING_CHAT_KEY);
          if (!raw) return null;

          storage.removeItem(POST_LOGIN_PENDING_CHAT_KEY);
          const parsed = JSON.parse(raw);
          const message = String(parsed && parsed.message ? parsed.message : '').trim();
          const createdAt = Number(parsed && parsed.createdAt ? parsed.createdAt : 0);
          if (!message) return null;
          if (createdAt && Date.now() - createdAt > POST_LOGIN_PENDING_CHAT_MAX_AGE_MS) {
            return null;
          }

          return {
            message,
            target: normalizeChatTarget(parsed && parsed.target ? parsed.target : 'all')
          };
        } catch (_) {
          return null;
        }
      }

      function removeGuestLimitHistoryPairs(items) {
        const sanitized = [];

        (Array.isArray(items) ? items : []).forEach((item) => {
          if (!item || (item.role !== 'user' && item.role !== 'bot')) return;

          if (item.role === 'bot' && isGuestLimitMessage(item.text)) {
            const previousItem = sanitized[sanitized.length - 1];
            if (previousItem && previousItem.role === 'user') {
              sanitized.pop();
            }
            return;
          }

          sanitized.push(item);
        });

        return sanitized;
      }

      function clearRecentChatCache() {
        try {
          [CHAT_CACHE_KEY, ...LEGACY_CHAT_CACHE_KEYS].forEach((key) => localStorage.removeItem(key));
        } catch (_) {}
      }

      function saveRecentChats() {
        if (!ENABLE_CHAT_CACHE) {
          clearRecentChatCache();
          return;
        }

        const items = Array.from(chatMessages.querySelectorAll('.bubble'))
          .filter((node) => !node.classList.contains('bubble-loading'))
          .map((node) => {
            const role = node.classList.contains('bubble-user') ? 'user' : 'bot';
            const messageNode = node.querySelector('.bubble-message');
            let assistantProfile = null;

            if (role === 'bot' && node.dataset.assistantProfile) {
              try {
                assistantProfile = normalizeAssistantProfile(JSON.parse(node.dataset.assistantProfile));
              } catch (_) {
                assistantProfile = null;
              }
            }

            return {
              text: messageNode ? messageNode.textContent || '' : node.textContent || '',
              renderedHtml: messageNode ? messageNode.innerHTML : node.innerHTML,
              role,
              assistantProfile,
            };
          })
          .slice(-CHAT_CACHE_LIMIT);
        localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify(items));
      }

      function shouldReformatBotMessageFromText(item = {}) {
        if (!item || item.role !== 'bot') {
          return false;
        }

        const text = String(item.text || '').trim();
        const renderedHtml = String(item.renderedHtml || '').trim();

        if (!text) {
          return false;
        }

        if (!/class=\"bot-answer-main\"/i.test(renderedHtml)) {
          return true;
        }

        if (!hasReferenceMarker(text)) {
          return false;
        }

        return !/data-reference-toggle=\"1\"|class=\"bot-reference-toggle\"/i.test(renderedHtml);
      }

      function restoreRecentChats(options = {}) {
        try {
          clearRecentChatCache();
          if (!ENABLE_CHAT_CACHE) return;
          const raw = localStorage.getItem(CHAT_CACHE_KEY);
          if (!raw) return;
          const parsed = JSON.parse(raw);
          if (!Array.isArray(parsed)) return;
          const restoredItems = isSignedInUser
            ? removeGuestLimitHistoryPairs(parsed)
            : parsed;

          if (isSignedInUser && restoredItems.length !== parsed.length) {
            localStorage.setItem(CHAT_CACHE_KEY, JSON.stringify(restoredItems.slice(-CHAT_CACHE_LIMIT)));
          }

          restoredItems.forEach((item) => {
            if (!item || (item.role !== 'user' && item.role !== 'bot')) return;

            if (shouldReformatBotMessageFromText(item)) {
              addBubble(item.text || '', item.role, false, [], {
                assistantProfile: item.assistantProfile || null,
              });
              return;
            }

            if (typeof item.renderedHtml === 'string' && item.renderedHtml) {
              const restoredHtml = isSignedInUser && item.role === 'bot'
                ? stripGuestLoginCtaHtml(item.renderedHtml)
                : item.renderedHtml;
              if (!restoredHtml) return;
              addBubble(item.text || '', item.role, false, [], {
                assistantProfile: item.assistantProfile || null,
              }, true, {
                renderedHtml: sanitizeRenderedDisplayHtml(restoredHtml),
                assistantProfile: item.assistantProfile || null,
              });
              return;
            }

            if (item.text) {
              addBubble(item.text, item.role, false, [], {
                assistantProfile: item.assistantProfile || null,
              });
            }
          });
        } catch (_) {}
      }

      function removeLoadingBubble() {
        const loadingBubble = chatMessages.querySelector('.bubble-loading');
        if (loadingBubble && loadingBubble.parentElement) {
          loadingBubble.parentElement.remove();
        }
      }

      async function submitMessage(message, options = {}) {
        const trimmed = String(message || '').trim();
        if (!trimmed) return;
        hideComposerSuggestions();

        if (recognition && isListening) {
          shouldSubmitVoiceOnEnd = false;
          recognition.stop();
        }

        isSubmitting = true;
        updateSendButtonState();
        if (!options.skipUserBubble) {
          addBubble(trimmed, 'user');
        }
        const loadingRow = addBubble('กำลังค้นฐานข้อมูล...', 'bot', true);
        const loadingController = createLoadingBubbleController(loadingRow, trimmed);
        let timeoutId = null;

        try {
          const controller = new AbortController();
          timeoutId = setTimeout(() => controller.abort(), 30000);
          const response = await fetch('/law-chatbot/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              message: trimmed,
              target: options.target || selectedTarget,
              debug: Boolean(options.debug),
              continueFromPrevious: Boolean(options.continueFromPrevious),
              continuationToken: typeof options.continuationToken === 'string' ? options.continuationToken : '',
              guestDeviceHint: isSignedInUser ? '' : buildGuestDeviceHint()
            }),
            signal: controller.signal
          });
          clearTimeout(timeoutId);
          const data = await response.json();
          updateAssistantProfile(data && data.assistantProfile ? data.assistantProfile : null);
          if (!response.ok && data && (data.noticeRequired || data.signInRequired) && (data.redirectPath || data.signInPath)) {
            window.location.href = data.redirectPath || data.signInPath;
            return;
          }

          loadingController.dispose();
          removeLoadingBubble();
          const answerText = data && typeof data.answer === 'string' ? data.answer.trim() : '';
          const dbHighlightTerms = data && Array.isArray(data.highlightTerms) && data.highlightTerms.length
            ? data.highlightTerms
            : buildHighlightTerms(trimmed);

          if (data && data.guestLimitReached) {
            savePendingPostLoginChat(trimmed, selectedTarget);
          } else {
            clearPendingPostLoginChat();
          }

          if (answerText) {
            const botRow = addBubble(answerText, 'bot', false, dbHighlightTerms, {
              question: trimmed,
              target: options.target || selectedTarget,
              variant: 'db',
              debug: data && data.debug ? data.debug : null,
              usedFollowUpContext: Boolean(data && data.usedFollowUpContext),
              guestLimitReached: Boolean(data && data.guestLimitReached),
              monthlyUsageLimitReached: Boolean(data && data.monthlyUsageLimitReached),
              questionCount: data && typeof data.questionCount !== 'undefined' ? data.questionCount : null,
              questionLimit: data && typeof data.questionLimit !== 'undefined' ? data.questionLimit : null,
              signInPath: data && typeof data.signInPath === 'string' ? data.signInPath : '',
              freeAiPreview: data && data.freeAiPreview ? data.freeAiPreview : null,
              continuation: data && data.continuation ? data.continuation : null,
              responseMeta: data && data.responseMeta ? data.responseMeta : null,
              assistantProfile: data && data.assistantProfile ? data.assistantProfile : currentAssistantProfile
            });
            focusFirstAnswer(botRow);
          }

          saveRecentChats();
          return data;
        } catch (error) {
          loadingController.dispose();
          removeLoadingBubble();
          const fallbackMessage = error && error.name === 'AbortError'
            ? 'ระบบใช้เวลานานเกินไป กรุณาลองใหม่อีกครั้ง'
            : 'ขออภัยครับ ระบบไม่สามารถประมวลผลคำถามได้ในขณะนี้ กรุณาลองใหม่อีกครั้ง';
          const botRow = addBubble(fallbackMessage, 'bot', false, [], {
            question: trimmed,
            target: options.target || selectedTarget,
            variant: 'db',
            suppressKnowledgeActions: true,
            assistantProfile: currentAssistantProfile
          });
          focusFirstAnswer(botRow);
          return null;
        } finally {
          if (timeoutId) {
            clearTimeout(timeoutId);
          }
          isSubmitting = false;
          updateSendButtonState();
          chatInput.focus();
          if (SpeechRecognition && !isListening) {
            setVoiceStatus('กดปุ่มไมค์เพื่อเริ่มค้นหาด้วยเสียง');
          }
          saveRecentChats();
        }
      }

      chatMessages.addEventListener('click', async (event) => {
        const referenceToggle = event.target.closest('[data-reference-toggle="1"]');
        if (referenceToggle) {
          window.setTimeout(() => {
            syncReferenceToggleState(referenceToggle, referenceToggle.getAttribute('aria-expanded') === 'true');
          }, 0);
        }

        const continuationButton = event.target.closest('[data-continue-answer="1"]');
        if (continuationButton) {
          if (isSubmitting) return;

          continuationButton.disabled = true;
          const continuationResponse = await submitMessage(continuationButton.dataset.question || '', {
            skipUserBubble: true,
            continueFromPrevious: true,
            continuationToken: continuationButton.dataset.continuationToken || '',
            target: continuationButton.dataset.target || selectedTarget
          });

          if (!continuationResponse) {
            continuationButton.disabled = false;
            return;
          }

          const continuationWrap = continuationButton.closest('.bot-continuation-actions');
          if (continuationWrap) {
            continuationWrap.remove();
          }
          return;
        }

        const freeAiPreviewButton = event.target.closest('[data-free-ai-preview="1"]');
        if (freeAiPreviewButton) {
          if (isSubmitting) return;
          freeAiPreviewButton.disabled = true;
          await submitMessage(freeAiPreviewButton.dataset.question || '', {
            aiPreview: true,
            skipUserBubble: true,
            target: freeAiPreviewButton.dataset.target || selectedTarget
          });
          return;
        }

        const feedbackButton = event.target.closest('[data-feedback-action="1"]');
        if (feedbackButton) {
          const wrap = feedbackButton.closest('.feedback-actions');
          if (!wrap || wrap.dataset.feedbackSent === '1') return;

          const question = feedbackButton.dataset.question || '';
          const answerShown = feedbackButton.dataset.answerShown || '';
          const target = feedbackButton.dataset.target || selectedTarget;
          const source = feedbackButton.dataset.source || '';
          const sourceLabel = feedbackButton.dataset.sourceLabel || '';
          const isHelpful = feedbackButton.dataset.helpful === '1';

          try {
            await submitFeedback({ question, answerShown, isHelpful, target, source, sourceLabel });
            wrap.dataset.feedbackSent = '1';
            wrap.innerHTML = '<span class="text-success small">ขอบคุณสำหรับข้อเสนอแนะ</span>';
          } catch (_) {
            wrap.innerHTML = '<span class="text-danger small">บันทึกข้อเสนอแนะไม่สำเร็จ</span>';
          }
          return;
        }

        const adminKnowledgeButton = event.target.closest('[data-admin-knowledge="1"]');
        if (adminKnowledgeButton) {
          const wrap = adminKnowledgeButton.closest('.feedback-actions');
          if (!wrap || wrap.dataset.adminKnowledgeSaving === '1') return;

          wrap.dataset.adminKnowledgeSaving = '1';
          adminKnowledgeButton.disabled = true;

          try {
            const result = await saveKnowledgeFromChat({
              question: adminKnowledgeButton.dataset.question || '',
              answerShown: adminKnowledgeButton.dataset.answerShown || '',
              target: adminKnowledgeButton.dataset.target || selectedTarget
            });

            if (result && !result.cancelled) {
              wrap.insertAdjacentHTML(
                'beforeend',
                '<span class="text-primary small">บันทึกเป็นคำถามแนะนำแล้ว</span>'
              );
              adminKnowledgeButton.remove();
            } else {
              adminKnowledgeButton.disabled = false;
            }
          } catch (_) {
            wrap.insertAdjacentHTML(
              'beforeend',
              '<span class="text-danger small">บันทึกคำตอบที่ถูกต้องไม่สำเร็จ</span>'
            );
            adminKnowledgeButton.disabled = false;
          } finally {
            delete wrap.dataset.adminKnowledgeSaving;
          }
        }

        const knowledgeSuggestionButton = event.target.closest('[data-knowledge-suggestion="1"]');
        if (knowledgeSuggestionButton) {
          const wrap = knowledgeSuggestionButton.closest('.feedback-actions');
          if (!wrap || wrap.dataset.knowledgeSuggestionSaving === '1') return;

          wrap.dataset.knowledgeSuggestionSaving = '1';
          knowledgeSuggestionButton.disabled = true;

          try {
            const result = await saveKnowledgeSuggestionFromChat({
              question: knowledgeSuggestionButton.dataset.question || '',
              target: knowledgeSuggestionButton.dataset.target || selectedTarget
            });

            if (result && !result.cancelled) {
              wrap.insertAdjacentHTML(
                'beforeend',
                '<span class="text-primary small">ส่งข้อเสนอให้ผู้ดูแลอนุมัติเป็นคำถามแนะนำแล้ว</span>'
              );
              knowledgeSuggestionButton.remove();
            } else {
              knowledgeSuggestionButton.disabled = false;
            }
          } catch (_) {
            wrap.insertAdjacentHTML(
              'beforeend',
              '<span class="text-danger small">ส่งข้อเสนอคำตอบไม่สำเร็จ</span>'
            );
            knowledgeSuggestionButton.disabled = false;
          } finally {
            delete wrap.dataset.knowledgeSuggestionSaving;
          }
        }
      });

      chatMessages.addEventListener('shown.bs.collapse', (event) => {
        const collapse = event.target.closest('.bot-reference-collapse');
        if (!collapse) {
          return;
        }

        const button = chatMessages.querySelector(`[data-reference-toggle="1"][aria-controls="${collapse.id}"]`);
        syncReferenceToggleState(button, true);
      });

      chatMessages.addEventListener('hidden.bs.collapse', (event) => {
        const collapse = event.target.closest('.bot-reference-collapse');
        if (!collapse) {
          return;
        }

        const button = chatMessages.querySelector(`[data-reference-toggle="1"][aria-controls="${collapse.id}"]`);
        syncReferenceToggleState(button, false);
      });

      if (adminKnowledgeForm) {
        adminKnowledgeForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          const payload = {
            question: String(adminKnowledgeQuestionInput.value || '').trim(),
            target: String(adminKnowledgeTargetInput.value || '').trim() === 'group' ? 'group' : 'coop',
            lawNumber: String(adminKnowledgeLawNumberInput.value || '').trim(),
            title: String(adminKnowledgeTitleInput.value || '').trim(),
            content: String(adminKnowledgeContentInput.value || '').trim(),
            sourceNote: String(adminKnowledgeSourceNoteInput.value || '').trim(),
          };

          if (!payload.title || !payload.content) {
            setAdminKnowledgeAlert('กรุณากรอกหัวข้อและคำตอบที่ถูกต้องก่อนบันทึก');
            return;
          }

          setAdminKnowledgeAlert('');
          adminKnowledgeSubmitBtn.disabled = true;
          adminKnowledgeSubmitBtn.textContent = 'กำลังบันทึก...';

          try {
            const response = await fetch('/law-chatbot/admin-knowledge', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });

            const data = await response.json();
            if (!response.ok || !data || !data.success) {
              throw new Error((data && data.message) || 'ไม่สามารถบันทึกคำตอบที่ถูกต้องได้');
            }

            if (pendingAdminKnowledgeResolve) {
              pendingAdminKnowledgeResolve(data);
              pendingAdminKnowledgeResolve = null;
            }

            adminKnowledgeModal.hide();
          } catch (error) {
            setAdminKnowledgeAlert(error.message || 'ไม่สามารถบันทึกคำตอบที่ถูกต้องได้');
            adminKnowledgeSubmitBtn.disabled = false;
            adminKnowledgeSubmitBtn.textContent = 'บันทึกเป็นคำถามแนะนำ';
          }
        });
      }

      if (adminKnowledgeModalElement) {
        adminKnowledgeModalElement.addEventListener('hidden.bs.modal', () => {
          if (pendingAdminKnowledgeResolve) {
            pendingAdminKnowledgeResolve({ cancelled: true });
            pendingAdminKnowledgeResolve = null;
          }
          if (adminKnowledgeForm) {
            adminKnowledgeForm.reset();
          }
          setAdminKnowledgeAlert('');
          if (adminKnowledgeSubmitBtn) {
            adminKnowledgeSubmitBtn.disabled = false;
            adminKnowledgeSubmitBtn.textContent = 'บันทึกเป็นคำถามแนะนำ';
          }
        });
      }

      if (knowledgeSuggestionVoiceBtn) {
        knowledgeSuggestionVoiceBtn.addEventListener('click', () => {
          if (!SpeechRecognition) {
            setKnowledgeSuggestionAlert('เบราว์เซอร์นี้ไม่รองรับการกรอกข้อความด้วยเสียง');
            return;
          }

          ensureSuggestionRecognition();
          if (!suggestionRecognition) return;

          if (isSuggestionListening) {
            suggestionRecognition.stop();
            return;
          }

          setKnowledgeSuggestionAlert('');
          try {
            suggestionRecognition.start();
          } catch (_) {
            setKnowledgeSuggestionAlert('ไม่สามารถเริ่มรับข้อความเสียงได้ ลองใหม่อีกครั้ง');
          }
        });
      }

      if (knowledgeSuggestionForm) {
        knowledgeSuggestionForm.addEventListener('submit', async (event) => {
          event.preventDefault();
          const payload = {
            title: String(knowledgeSuggestionTitleInput.value || '').trim(),
            question: String(knowledgeSuggestionTitleInput.value || '').trim(),
            target: String(knowledgeSuggestionTargetInput.value || '').trim() === 'group' ? 'group' : 'coop',
            content: String(knowledgeSuggestionContentInput.value || '').trim(),
            sourceReference: String((knowledgeSuggestionSourceReferenceInput && knowledgeSuggestionSourceReferenceInput.value) || '').trim(),
            sourceType: String(knowledgeSuggestionSourceTypeInput.value || '').trim() === 'voice' ? 'voice' : 'text',
          };

          if (!payload.title || !payload.content) {
            setKnowledgeSuggestionAlert('กรุณากรอกหัวข้อและคำตอบที่ต้องการเสนอ');
            return;
          }

          setKnowledgeSuggestionAlert('');
          knowledgeSuggestionSubmitBtn.disabled = true;
          knowledgeSuggestionSubmitBtn.textContent = 'กำลังส่ง...';

          try {
            const response = await fetch('/law-chatbot/knowledge-suggestion', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });

            const data = await response.json();
            if (!response.ok || !data || !data.success) {
              throw new Error((data && data.message) || 'ไม่สามารถส่งข้อเสนอคำตอบได้');
            }

            if (pendingKnowledgeSuggestionResolve) {
              pendingKnowledgeSuggestionResolve(data);
              pendingKnowledgeSuggestionResolve = null;
            }

            knowledgeSuggestionModal.hide();
          } catch (error) {
            setKnowledgeSuggestionAlert(error.message || 'ไม่สามารถส่งข้อเสนอคำตอบได้');
            knowledgeSuggestionSubmitBtn.disabled = false;
            knowledgeSuggestionSubmitBtn.textContent = 'ส่งให้ผู้ดูแลตรวจสอบ';
          }
        });
      }

      if (knowledgeSuggestionModalElement) {
        knowledgeSuggestionModalElement.addEventListener('hidden.bs.modal', () => {
          if (isSuggestionListening && suggestionRecognition) {
            suggestionRecognition.stop();
          }
          if (pendingKnowledgeSuggestionResolve) {
            pendingKnowledgeSuggestionResolve({ cancelled: true });
            pendingKnowledgeSuggestionResolve = null;
          }
          if (knowledgeSuggestionForm) {
            knowledgeSuggestionForm.reset();
          }
          if (knowledgeSuggestionSourceTypeInput) {
            knowledgeSuggestionSourceTypeInput.value = 'text';
          }
          setKnowledgeSuggestionAlert('');
          if (knowledgeSuggestionSubmitBtn) {
            knowledgeSuggestionSubmitBtn.disabled = false;
            knowledgeSuggestionSubmitBtn.textContent = 'ส่งให้ผู้ดูแลตรวจสอบ';
          }
          if (knowledgeSuggestionVoiceBtn) {
            knowledgeSuggestionVoiceBtn.innerHTML = '<i class="bi bi-mic-fill"></i> พูดเพื่อกรอกข้อความ';
          }
        });
      }

      chatForm.addEventListener('submit', (event) => {
        event.preventDefault();
        const currentMessage = chatInput.value;
        chatInput.value = '';
        submitMessage(currentMessage);
      });

      if (debugBtn) {
        debugBtn.addEventListener('click', () => {
          const currentMessage = chatInput.value;
          chatInput.value = '';
          submitMessage(currentMessage, { debug: true });
        });
      }

      voiceBtn.addEventListener('click', () => {
        hideComposerSuggestions();
        if (!SpeechRecognition) {
          setVoiceStatus('เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง', true);
          return;
        }

        if (!recognition) initVoiceRecognition();
        if (!recognition) return;

        if (isListening) {
          recognition.stop();
          return;
        }

        if (isSubmitting) return;

        try {
          setVoiceStatus('กำลังเปิดไมโครโฟน...');
          recognition.start();
        } catch (_) {
          setVoiceStatus('ไม่สามารถเริ่มไมโครโฟนได้ ลองใหม่อีกครั้ง', true);
        }
      });

      if (chatInput) {
        chatInput.addEventListener('input', () => {
          showComposerSuggestions();
        });

        chatInput.addEventListener('keydown', (event) => {
          const suggestionButtons = getComposerSuggestionButtons();
          const suggestionsVisible = Boolean(composerSuggestions && !composerSuggestions.hidden && suggestionButtons.length);

          if ((event.key === 'ArrowDown' || event.key === 'ArrowUp') && suggestionsVisible) {
            event.preventDefault();
            const direction = event.key === 'ArrowDown' ? 1 : -1;
            const nextIndex = activeComposerSuggestionIndex >= 0
              ? activeComposerSuggestionIndex + direction
              : direction > 0
                ? 0
                : suggestionButtons.length - 1;
            const wrappedIndex = (nextIndex + suggestionButtons.length) % suggestionButtons.length;
            setActiveComposerSuggestion(wrappedIndex);
            return;
          }

          if (event.key === 'Enter' && suggestionsVisible && activeComposerSuggestionIndex >= 0) {
            event.preventDefault();
            const activeSuggestion = suggestionButtons[activeComposerSuggestionIndex];
            if (activeSuggestion) {
              selectComposerSuggestion(activeSuggestion.dataset.composerQuestion || '');
            }
            return;
          }

          if (event.key === 'Escape') {
            hideComposerSuggestions();
          }
        });
      }

      if (composerSuggestionsList) {
        composerSuggestionsList.addEventListener('click', (event) => {
          const suggestionButton = event.target.closest('[data-composer-question]');
          if (!suggestionButton) return;

          const question = String(suggestionButton.dataset.composerQuestion || '').trim();
          selectComposerSuggestion(question);
        });
      }

      if (composerSuggestionsPrevBtn) {
        composerSuggestionsPrevBtn.addEventListener('click', () => {
          goToPreviousComposerSuggestionPage();
        });
      }

      if (composerSuggestionsNextBtn) {
        composerSuggestionsNextBtn.addEventListener('click', () => {
          goToNextComposerSuggestionPage();
        });
      }

      if (composerSuggestions) {
        composerSuggestions.addEventListener('touchstart', (event) => {
          if (!canPageComposerSuggestions() || !event.touches || event.touches.length !== 1) {
            return;
          }

          composerSuggestionTouchStartX = event.touches[0].clientX;
          composerSuggestionTouchStartY = event.touches[0].clientY;
        }, { passive: true });

        composerSuggestions.addEventListener('touchend', (event) => {
          if (!canPageComposerSuggestions() || !event.changedTouches || event.changedTouches.length !== 1) {
            return;
          }

          const deltaX = event.changedTouches[0].clientX - composerSuggestionTouchStartX;
          const deltaY = event.changedTouches[0].clientY - composerSuggestionTouchStartY;
          const horizontalThreshold = 45;
          const verticalThreshold = 28;

          if (Math.abs(deltaX) < horizontalThreshold || Math.abs(deltaY) > Math.abs(deltaX) || Math.abs(deltaY) > verticalThreshold) {
            return;
          }

          if (deltaX < 0) {
            goToNextComposerSuggestionPage();
            return;
          }

          goToPreviousComposerSuggestionPage();
        }, { passive: true });
      }

      document.addEventListener('click', (event) => {
        if (!chatForm || chatForm.contains(event.target)) {
          return;
        }
        hideComposerSuggestions();
      });

      mobileMenuButtons.forEach((button) => button.addEventListener('click', () => {
        const isOpen = lawbotApp && lawbotApp.classList.contains('mobile-menu-open');
        setMobileMenuOpen(!isOpen);
      }));

      mobileSidebarCloseTargets.forEach((target) => target.addEventListener('click', () => {
        setMobileMenuOpen(false);
      }));

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setMobileMenuOpen(false);
        }
      });

      quickButtons.forEach((button) => button.addEventListener('click', () => submitMessage(button.dataset.question || '')));

      clearChatButtons.forEach((button) => button.addEventListener('click', async () => {
        hideComposerSuggestions();
        await resetConversationContext();
        chatMessages.innerHTML = '';
        clearRecentChatCache();
        clearPendingPostLoginChat();
        addBubble(buildAssistantWelcomeText({ afterClear: true, assistantProfile: currentAssistantProfile }), 'bot', false, [], {
          assistantProfile: currentAssistantProfile,
        }, true, {
          renderedHtml: buildAssistantWelcomeHtml({ afterClear: true, assistantProfile: currentAssistantProfile }),
          assistantProfile: currentAssistantProfile,
        });
      }));

      toggleHeaderButtons.forEach((button) => button.addEventListener('click', () => {
        if (!lawbotApp) return;
          const collapsed = lawbotApp && lawbotApp.classList.contains('headers-collapsed');
          setHeaderCollapsed(!collapsed);
        }));

      togglePlanRibbonButtons.forEach((button) => button.addEventListener('click', () => {
        if (!lawbotApp || !planRibbon) return;
        const collapsed = lawbotApp.classList.contains('plan-ribbon-collapsed');
        setPlanRibbonCollapsed(!collapsed);
      }));

      window.addEventListener('beforeinstallprompt', (event) => {
        event.preventDefault();
        deferredInstallPrompt = event;
        updateInstallButtons();
      });

      installBtn.addEventListener('click', async () => {
        if (!deferredInstallPrompt) return;
        deferredInstallPrompt.prompt();
        await deferredInstallPrompt.userChoice;
        deferredInstallPrompt = null;
        updateInstallButtons();
      });

      window.addEventListener('appinstalled', () => {
        deferredInstallPrompt = null;
        updateInstallButtons();
      });

      window.addEventListener('online', setOnlineState);
      window.addEventListener('offline', setOnlineState);

      setOnlineState();
      updateInstallButtons();
      updateVoiceButton();
      updateSendButtonState();
      setHeaderCollapsed(localStorage.getItem(HEADER_COLLAPSE_KEY) === '1');
      setPlanRibbonCollapsed(getInitialPlanRibbonCollapsed());
      if (SpeechRecognition) {
        initVoiceRecognition();
      }
      const pendingPostLoginChat = consumePendingPostLoginChat();
      restoreRecentChats();
      if (!chatMessages.querySelector('.bubble')) {
        addBubble(buildAssistantWelcomeText({ assistantProfile: currentAssistantProfile }), 'bot', false, [], {
          assistantProfile: currentAssistantProfile,
        }, true, {
          renderedHtml: buildAssistantWelcomeHtml({ assistantProfile: currentAssistantProfile }),
          assistantProfile: currentAssistantProfile,
        });
      }
      if (pendingPostLoginChat && pendingPostLoginChat.message) {
        selectedTarget = pendingPostLoginChat.target;
        window.setTimeout(() => {
          submitMessage(pendingPostLoginChat.message);
        }, 180);
      }

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw-law-chatbot.js').catch(() => {});
        });
      }
    })();
  </script>
</body>
</html>
