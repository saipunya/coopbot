<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="<%= themeColor || '#2f5f7a' %>" />
  <meta name="application-name" content="กฎหมายสหกรณ์" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="กฎหมายสหกรณ์" />
  <link rel="manifest" href="<%= manifestPath || '/manifest-law-chatbot.json' %>" />
  <link rel="icon" type="image/png" sizes="192x192" href="/icon/robot-icon-192.png" />
  <link rel="apple-touch-icon" href="/icon/robot-icon-180.png" />
  <title><%= title || 'แชตบอทกฎหมายสหกรณ์' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg-start: #e6eef6;
      --bg-end: #f5f9fc;
      --surface: #ffffff;
      --surface-elevated: rgba(255, 255, 255, 0.88);
      --surface-soft: #f1f6fb;
      --primary: #15547a;
      --primary-strong: #0f4667;
      --primary-soft: #d2e8f7;
      --text-main: #1f2a37;
      --text-sub: #5d6a79;
      --border: #d8e2ea;
      --ok: #1d7a52;
      --warn: #8b2e2e;
      --bubble-user-start: #1e7fb4;
      --bubble-user-end: #15557b;
      --bubble-bot-border: #c6dff0;
      --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      --chat-watermark-image: url('/icon/coop-rope-watermark.svg');
      --plan-shell-glow: rgba(43, 132, 187, 0.14);
      --plan-band-start: rgba(210, 232, 247, 0.78);
      --plan-band-end: rgba(255, 255, 255, 0.38);
      --plan-chip-bg: rgba(255, 255, 255, 0.72);
      --plan-chip-ink: #0f4667;
    }

    body[data-bot-plan="free"] {
      --primary: #1e6f9d;
      --primary-strong: #164d70;
      --primary-soft: #d7edf9;
      --bubble-user-start: #1f86bc;
      --bubble-user-end: #14577e;
      --plan-shell-glow: rgba(49, 128, 181, 0.16);
      --plan-band-start: rgba(215, 237, 249, 0.82);
      --plan-band-end: rgba(255, 255, 255, 0.4);
      --plan-icon-start: #2b9fd6;
      --plan-icon-end: #1a6e9e;
      --plan-accent: #2b9fd6;
      --plan-accent-soft: rgba(43, 159, 214, 0.10);
      --plan-highlight-border: rgba(43, 159, 214, 0.18);
      --plan-highlight-icon: #1a7fb5;
    }

    body[data-bot-plan="pro"] {
      --primary: #0f6d64;
      --primary-strong: #09483f;
      --primary-soft: #d7f0ea;
      --bubble-user-start: #188979;
      --bubble-user-end: #0d6054;
      --bubble-bot-border: #bfdfd8;
      --plan-shell-glow: rgba(15, 109, 100, 0.16);
      --plan-band-start: rgba(215, 240, 234, 0.86);
      --plan-band-end: rgba(255, 255, 255, 0.42);
      --plan-chip-ink: #09483f;
      --plan-icon-start: #14a38e;
      --plan-icon-end: #0a6b5e;
      --plan-accent: #14a38e;
      --plan-accent-soft: rgba(20, 163, 142, 0.10);
      --plan-highlight-border: rgba(20, 163, 142, 0.18);
      --plan-highlight-icon: #0d7f6e;
    }

    body[data-bot-plan="premium"] {
      --primary: #8b5a17;
      --primary-strong: #5e3810;
      --primary-soft: #f7ead2;
      --bubble-user-start: #bc8540;
      --bubble-user-end: #8b5a17;
      --bubble-bot-border: #ead6af;
      --plan-shell-glow: rgba(183, 134, 47, 0.18);
      --plan-band-start: rgba(247, 234, 210, 0.88);
      --plan-band-end: rgba(255, 250, 242, 0.46);
      --plan-chip-ink: #5e3810;
      --plan-icon-start: #d4952a;
      --plan-icon-end: #a16b14;
      --plan-accent: #c48820;
      --plan-accent-soft: rgba(196, 136, 32, 0.10);
      --plan-highlight-border: rgba(196, 136, 32, 0.18);
      --plan-highlight-icon: #a16b14;
    }

    html, body {
      margin: 0;
      padding: 0;
      font-family: 'Sarabun', sans-serif;
      min-height: 100%;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      overscroll-behavior-y: none;
      background:
        radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
        radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
        linear-gradient(160deg, var(--bg-start), var(--bg-end));
      background-attachment: fixed;
      color: var(--text-main);
    }

    .lawbot-app {
      width: 100%;
      max-width: 1240px;
      margin: 0 auto;
      padding: 0.75rem;
      padding-top: max(0.7rem, env(safe-area-inset-top));
      padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.8rem;
    }

    .floating-controls {
      position: fixed;
      top: calc(env(safe-area-inset-top) + 0.6rem);
      right: 0.75rem;
      z-index: 80;
      display: inline-flex;
      align-items: center;
      gap: 0.72rem;
    }

    .header-toggle-btn {
      border-radius: 999px;
      box-shadow: 0 8px 18px rgba(34, 63, 87, 0.2);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.42rem;
      padding: 0.58rem 1.02rem;
      font-size: 0.86rem;
      min-height: 2.85rem;
      min-width: 2.85rem;
      touch-action: manipulation;
    }

    .header-toggle-btn span {
      white-space: nowrap;
    }

    .clear-chat-btn {
      border-radius: 999px;
      box-shadow: 0 8px 18px rgba(139, 46, 46, 0.16);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.42rem;
      padding: 0.58rem 0.95rem;
      font-size: 0.8rem;
      min-height: 2.85rem;
      min-width: 2.85rem;
      font-weight: 700;
      touch-action: manipulation;
    }

    .clear-chat-btn span {
      white-space: nowrap;
    }

    .lawbot-app.headers-collapsed .page-header {
      display: none;
    }

    .lawbot-app.headers-collapsed .chat-header {
      display: none !important;
    }

    .lawbot-app.headers-collapsed .chat-shell {
      min-height: 0;
      flex: 1;
    }

    @media (min-width: 768px) {
      .plan-ribbon-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        grid-column: 1 / -1;
      }

      .plan-ribbon-toggle-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.42rem;
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        border: 1px solid rgba(21, 84, 122, 0.12);
        background: rgba(255, 255, 255, 0.72);
        color: var(--primary-strong);
        box-shadow: 0 8px 18px rgba(34, 63, 87, 0.08);
        font-size: 0.82rem;
        font-weight: 700;
        backdrop-filter: blur(8px);
      }

      .plan-ribbon-toggle-btn:hover,
      .plan-ribbon-toggle-btn:focus-visible {
        background: rgba(255, 255, 255, 0.9);
        color: var(--primary-strong);
        border-color: rgba(21, 84, 122, 0.18);
      }

      .plan-ribbon-body {
        display: contents;
      }

      .lawbot-app.plan-ribbon-collapsed .plan-ribbon {
        grid-template-columns: 1fr;
        padding-top: 0.78rem;
        padding-bottom: 0.78rem;
      }

      .lawbot-app.plan-ribbon-collapsed .plan-ribbon-body {
        display: none;
      }
    }

    .page-header {
      width: min(1160px, 100%);
      --header-icon-size: 2.08rem;
      --header-icon-radius: 999px;
      --header-icon-font-size: 0.86rem;
      border-radius: 1rem;
      padding: 0.46rem 0.54rem;
      border: 1px solid rgba(255, 255, 255, 0.72);
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(245, 249, 252, 0.9));
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(16px);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.58rem;
      position: relative;
      overflow: hidden;
    }

    .page-header::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, var(--plan-shell-glow), transparent 34%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.46), transparent 48%);
      pointer-events: none;
    }

    .plan-ribbon {
      width: min(1160px, 100%);
      border-radius: 1rem;
      padding: 0.9rem 1rem;
      background: linear-gradient(135deg, var(--plan-band-start), var(--plan-band-end));
      border: 1px solid rgba(255, 255, 255, 0.72);
      box-shadow: 0 16px 34px rgba(18, 52, 77, 0.11);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 0.9rem;
      align-items: center;
      overflow: hidden;
      position: relative;
    }

    .plan-ribbon::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top right, rgba(255, 255, 255, 0.36), transparent 32%);
      pointer-events: none;
    }

    .plan-ribbon > * {
      position: relative;
      z-index: 1;
    }

    .plan-ribbon-copy {
      display: grid;
      gap: 0.35rem;
    }

    .plan-ribbon-title {
      margin: 0;
      font-size: clamp(1rem, 1.7vw, 1.2rem);
      color: var(--primary-strong);
    }

    .plan-ribbon-text {
      margin: 0;
      color: var(--text-sub);
    }

    .plan-ribbon-note {
      display: inline-flex;
      align-items: flex-start;
      gap: 0.55rem;
      width: fit-content;
      max-width: 100%;
      margin-top: 0.15rem;
      padding: 0.65rem 0.85rem;
      border-radius: 0.9rem;
      background: rgba(255, 255, 255, 0.66);
      border: 1px solid rgba(255, 255, 255, 0.74);
      color: var(--primary-strong);
      font-size: 0.83rem;
      line-height: 0.20;
    }

    .plan-ribbon-note i {
      margin-top: 0.05rem;
      font-size: 0.95rem;
      flex: 0 0 auto;
    }

    .plan-ribbon-stats {
      display: flex;
      gap: 0.7rem;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .plan-ribbon-stat {
      min-width: 150px;
      border-radius: 0.9rem;
      padding: 0.75rem 0.85rem;
      background: rgba(255, 255, 255, 0.62);
      border: 1px solid rgba(255, 255, 255, 0.68);
    }

    .plan-ribbon-stat span {
      display: block;
      font-size: 0.78rem;
      color: var(--text-sub);
    }

    .plan-ribbon-stat strong {
      display: block;
      margin-top: 0.2rem;
      font-size: 1rem;
      color: var(--primary-strong);
    }

    /* ── Plan-specific brand icon ── */
    body[data-bot-plan="pro"] .brand-icon {
      background: linear-gradient(145deg, var(--plan-icon-start, #14a38e), var(--plan-icon-end, #0a6b5e));
      box-shadow: 0 8px 18px rgba(10, 107, 94, 0.18);
    }
    body[data-bot-plan="premium"] .brand-icon {
      background: linear-gradient(145deg, var(--plan-icon-start, #d4952a), var(--plan-icon-end, #a16b14));
      box-shadow: 0 8px 18px rgba(161, 107, 20, 0.18);
    }

    /* ── Plan ribbon chip per-plan icons ── */
    .plan-ribbon-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
      width: fit-content;
      padding: 0.38rem 0.82rem;
      border-radius: 999px;
      background: var(--plan-chip-bg);
      color: var(--plan-chip-ink);
      font-size: 0.82rem;
      font-weight: 700;
    }
    body[data-bot-plan="pro"] .plan-ribbon-chip {
      background: rgba(20, 163, 142, 0.12);
      border: 1px solid rgba(20, 163, 142, 0.18);
    }
    body[data-bot-plan="premium"] .plan-ribbon-chip {
      background: linear-gradient(135deg, rgba(212, 149, 42, 0.14), rgba(255, 215, 100, 0.10));
      border: 1px solid rgba(196, 136, 32, 0.22);
    }

    /* ── Plan ribbon decorative shimmer (premium) ── */
    body[data-bot-plan="premium"] .plan-ribbon::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(120deg, transparent 30%, rgba(255, 215, 100, 0.08) 50%, transparent 70%);
      pointer-events: none;
      animation: planShimmer 4s ease-in-out infinite;
    }
    @keyframes planShimmer {
      0%, 100% { opacity: 0.4; }
      50% { opacity: 1; }
    }

    /* ── Plan feature highlights ── */
    .plan-highlights {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 0.65rem;
      margin-top: 0.55rem;
    }

    .plan-highlight-card {
      display: flex;
      align-items: flex-start;
      gap: 0.55rem;
      padding: 0.68rem 0.82rem;
      border-radius: 0.82rem;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid var(--plan-highlight-border, rgba(21, 84, 122, 0.12));
      backdrop-filter: blur(8px);
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .plan-highlight-card:hover {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.06);
    }

    .plan-highlight-icon {
      width: 2rem;
      height: 2rem;
      border-radius: 0.55rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
      font-size: 0.88rem;
      color: var(--plan-highlight-icon, var(--primary));
      background: var(--plan-accent-soft, rgba(21, 84, 122, 0.08));
    }

    .plan-highlight-text {
      font-size: 0.82rem;
      line-height: 1.42;
      color: var(--text-main);
    }

    /* ── Plan usage quick-stat bar ── */
    .plan-ribbon-usage-bar {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      margin-top: 0.35rem;
    }

    .plan-ribbon-usage-track {
      flex: 1;
      height: 0.42rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.06);
      overflow: hidden;
    }

    .plan-ribbon-usage-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--plan-accent, var(--primary)), var(--primary-strong));
      transition: width 400ms ease;
    }

    .plan-ribbon-usage-label {
      font-size: 0.72rem;
      color: var(--text-sub);
      white-space: nowrap;
    }

    /* ── Plan upgrade nudge inside ribbon ── */
    .plan-ribbon-upgrade {
      display: inline-flex;
      align-items: center;
      gap: 0.42rem;
      width: fit-content;
      margin-top: 0.3rem;
      padding: 0.42rem 0.82rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
      text-decoration: none;
      color: #fff;
      background: linear-gradient(135deg, var(--primary), var(--primary-strong));
      box-shadow: 0 8px 18px rgba(0, 0, 0, 0.12);
      transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .plan-ribbon-upgrade:hover,
    .plan-ribbon-upgrade:focus-visible {
      transform: translateY(-1px);
      box-shadow: 0 10px 22px rgba(0, 0, 0, 0.16);
      color: #fff;
    }

    .page-brand {
      display: flex;
      align-items: center;
      gap: 0.58rem;
      min-width: 0;
      position: relative;
      z-index: 1;
    }

    .brand-icon {
      width: var(--header-icon-size);
      height: var(--header-icon-size);
      border-radius: var(--header-icon-radius);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(145deg, #2b84bb, #0f4667);
      color: #fff;
      font-size: var(--header-icon-font-size);
      line-height: 1;
      border: 1px solid rgba(255, 255, 255, 0.72);
      box-shadow: 0 10px 20px rgba(15, 70, 103, 0.18), 0 0 0 3px rgba(255, 255, 255, 0.36);
      flex: 0 0 auto;
    }

    .brand-title {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.08rem;
    }

    .brand-heading {
      display: flex;
      align-items: center;
      gap: 0.42rem;
      min-width: 0;
    }

    .brand-title h6 {
      margin: 0;
      font-size: clamp(0.92rem, 1.4vw, 1.05rem);
      line-height: 1.06;
      color: var(--primary-strong);
      flex: 0 1 auto;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .brand-title p {
      display: none;
    }

    .page-toolbar {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.32rem;
      min-width: 0;
      padding: 0;
      border: none;
      background: transparent;
      box-shadow: none;
      position: relative;
      z-index: 1;
    }

    .page-toolbar-divider {
      width: 1px;
      align-self: center;
      height: 1.55rem;
      background: linear-gradient(180deg, rgba(21, 84, 122, 0.04), rgba(21, 84, 122, 0.16), rgba(21, 84, 122, 0.04));
      flex: 0 0 auto;
    }

    .page-identity {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.42rem;
      min-width: 0;
      padding: 0.24rem 0.3rem;
      border-radius: 0.82rem;
      border: 1px solid rgba(21, 84, 122, 0.08);
      background: rgba(255, 255, 255, 0.54);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.46);
      flex: 0 1 320px;
    }

    .page-identity-avatar {
      width: var(--header-icon-size);
      height: var(--header-icon-size);
      border-radius: var(--header-icon-radius);
      overflow: hidden;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      background: linear-gradient(145deg, var(--primary), var(--primary-strong));
      border: 1px solid rgba(255, 255, 255, 0.78);
      box-shadow: 0 8px 18px rgba(15, 70, 103, 0.16), 0 0 0 3px rgba(255, 255, 255, 0.34);
      flex: 0 0 auto;
      font-size: var(--header-icon-font-size);
      line-height: 1;
    }

    .page-identity-avatar img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
      transform: scale(1.04);
      filter: contrast(1.05) saturate(1.06);
      image-rendering: -webkit-optimize-contrast;
    }

    .page-identity-admin .page-identity-avatar {
      background: linear-gradient(145deg, #b9851f, #8f5f11);
    }

    .page-identity-guest .page-identity-avatar {
      background: linear-gradient(145deg, #6f879b, #56697c);
    }

    .page-identity-text {
      min-width: 0;
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 0.3rem;
      flex: 1 1 auto;
    }

    .page-identity-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 1.1rem;
      padding: 0.08rem 0.4rem;
      border-radius: 999px;
      background: rgba(21, 84, 122, 0.08);
      color: var(--primary-strong);
      font-size: 0.62rem;
      font-weight: 700;
      flex: 0 0 auto;
      letter-spacing: 0.02em;
    }

    .page-identity-name {
      font-size: 0.82rem;
      line-height: 1.05;
      color: var(--primary-strong);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .page-identity-meta {
      display: none;
    }

    .page-identity-actions {
      display: flex;
      flex-wrap: nowrap;
      gap: 0.24rem;
      margin-top: 0;
      justify-content: flex-end;
    }

    .page-identity-action {
      border-radius: 999px;
      min-height: 1.7rem;
      padding: 0.26rem 0.54rem;
      font-size: 0.68rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      text-decoration: none;
      border: 1px solid rgba(21, 84, 122, 0.14);
      background: rgba(255, 255, 255, 0.78);
      color: var(--primary-strong);
      box-shadow: none;
      white-space: nowrap;
    }

    .page-identity-action.primary {
      background: linear-gradient(145deg, var(--primary), var(--primary-strong));
      border-color: transparent;
      color: #fff;
    }

    .page-identity-action:hover,
    .page-identity-action:focus-visible {
      transform: translateY(-1px);
      box-shadow: 0 6px 14px rgba(34, 63, 87, 0.08);
      color: inherit;
    }

    .page-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.24rem;
      flex-wrap: nowrap;
      padding-left: 0.04rem;
    }

    .icon-chip-btn {
      width: 1.95rem;
      height: 1.95rem;
      padding: 0;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
    }

    .page-actions .icon-chip-btn {
      border: 1px solid rgba(21, 84, 122, 0.12) !important;
      background: rgba(255, 255, 255, 0.62) !important;
      color: var(--primary-strong) !important;
