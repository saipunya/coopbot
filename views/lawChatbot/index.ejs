      align-items: center;
      gap: 0.58rem;
    }

    .header-assistant-icon {
      width: 2.54rem;
      height: 2.54rem;
      border-radius: 0.78rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: 0 8px 18px rgba(9, 44, 91, 0.16);
      flex: 0 0 auto;
    }

    .header-assistant-icon img {
      width: 1.92rem;
      height: 1.92rem;
      object-fit: contain;
    }

    .header-assistant-copy {
      min-width: 0;
      display: grid;
      gap: 0.06rem;
    }

    .header-assistant-copy strong,
    .header-assistant-copy span {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .header-assistant-copy strong {
      color: #fff;
      font-size: 0.96rem;
      font-weight: 800;
      line-height: 1.15;
    }

    .header-assistant-copy span {
      color: rgba(255, 255, 255, 0.8);
      font-size: 0.74rem;
      line-height: 1.2;
    }

    .header-assistant-actions {
      display: inline-flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.42rem;
      flex: 0 0 auto;
    }

    .header-action-btn {
      width: 2.32rem;
      height: 2.32rem;
      border-radius: 0.72rem;
      border: 1px solid rgba(255, 255, 255, 0.28);
      background: rgba(255, 255, 255, 0.14);
      color: #fff;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-decoration: none;
      transition: transform 140ms ease, background 140ms ease, border-color 140ms ease;
    }

    .header-action-btn:hover,
    .header-action-btn:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(255, 255, 255, 0.48);
      background: rgba(255, 255, 255, 0.22);
