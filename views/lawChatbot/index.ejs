      function setVoiceStatus(text = '', isError = false) {
        if (!voiceStatus) return;
        voiceStatus.textContent = text;
        voiceStatus.classList.toggle('text-danger', !!isError);
        voiceStatus.classList.toggle('text-muted', !isError);
      }

      function updateVoiceButton() {
        if (!voiceBtn) return;

        if (!SpeechRecognition) {
          voiceBtn.disabled = true;
          setVoiceStatus('เบราว์เซอร์นี้ไม่รองรับการค้นหาด้วยเสียง', true);
          return;
        }

        voiceBtn.disabled = false;
        voiceBtn.classList.toggle('voice-btn-listening', isListening);
        voiceBtn.innerHTML = isListening ? '<i class="bi bi-stop-fill"></i>' : '<i class="bi bi-mic-fill"></i>';
        voiceBtn.title = isListening ? 'หยุดฟังเสียง' : 'ค้นหาด้วยเสียง';
        voiceBtn.setAttribute('aria-label', isListening ? 'หยุดฟังเสียง' : 'ค้นหาด้วยเสียง');
      }

      function updateSendButtonState() {
        sendBtn.disabled = isListening || isSubmitting;
        if (debugBtn) {
          debugBtn.disabled = isListening || isSubmitting;
        }
      }

      function initVoiceRecognition() {
        if (!SpeechRecognition || recognition) return;

        recognition = new SpeechRecognition();
        recognition.lang = 'th-TH';
        recognition.interimResults = true;
        recognition.continuous = false;
        recognition.maxAlternatives = 1;

        let finalTranscript = '';

        recognition.onstart = () => {
          isListening = true;
          finalTranscript = '';
          shouldSubmitVoiceOnEnd = true;
          setVoiceStatus('กำลังฟัง... พูดคำค้นหาได้เลย');
          updateVoiceButton();
        };

        recognition.onresult = (event) => {
          let interimTranscript = '';
          for (let i = event.resultIndex; i < event.results.length; i += 1) {
            const result = event.results[i];
            const text = result[0] && result[0].transcript ? result[0].transcript : '';
            if (result.isFinal) finalTranscript += `${text} `;
            else interimTranscript += text;
          }
          chatInput.value = `${finalTranscript}${interimTranscript}`.trim();
        };

        recognition.onerror = (event) => {
          isListening = false;
          shouldSubmitVoiceOnEnd = false;
          updateVoiceButton();

          const errorMap = {
            'not-allowed': 'ไม่ได้รับอนุญาตไมโครโฟน กรุณาอนุญาตสิทธิ์การใช้ไมค์',
            'service-not-allowed': 'ไม่สามารถใช้ไมโครโฟนได้ในอุปกรณ์นี้',
            'audio-capture': 'ไม่พบไมโครโฟน',
            'no-speech': 'ไม่ได้ยินเสียงพูด ลองใหม่อีกครั้ง',
            network: 'เครือข่ายมีปัญหาในการรับเสียง'
          };

          setVoiceStatus(errorMap[event.error] || 'เกิดข้อผิดพลาดในการค้นหาด้วยเสียง', true);
        };

        recognition.onend = () => {
          const hasText = String(chatInput.value || '').trim().length > 0;
          const keepTranscript = shouldSubmitVoiceOnEnd && hasText;

          isListening = false;
          shouldSubmitVoiceOnEnd = false;
          updateVoiceButton();

          if (keepTranscript) {
            setVoiceStatus('ถอดเสียงสำเร็จ กรุณากดปุ่มส่ง');
            chatInput.focus();
            return;
          }

          if (!hasText) setVoiceStatus('กดปุ่มไมค์เพื่อเริ่มค้นหาด้วยเสียง');
        };
      }

      function escapeHtml(text) {
        return String(text || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function escapeRegExp(text) {
        return String(text || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      function replaceUserVisibleAiTerms(text) {
        return String(text || '').replace(/\bsuper bot\b/gi, 'AI');
      }

      function sanitizeRenderedDisplayHtml(html) {
        const rawHtml = String(html || '');
        if (!rawHtml || typeof document === 'undefined') {
          return replaceUserVisibleAiTerms(rawHtml);
        }

        const template = document.createElement('template');
        template.innerHTML = rawHtml;

        const walker = document.createTreeWalker(template.content, NodeFilter.SHOW_TEXT);
        let node = walker.nextNode();
        while (node) {
          node.textContent = stripBotUiNoiseText(replaceUserVisibleAiTerms(node.textContent || ''));
          node = walker.nextNode();
        }

        template.content.querySelectorAll(
          '.bot-inline-actions, .bot-limit-cta-panel, .bot-login-cta, .bot-ai-preview-cta, .bot-upgrade-cta, .bot-upgrade-cta-prominent, .bot-inline-note, .feedback-actions, .answer-origin-chip'
        ).forEach((element) => element.remove());

        return template.innerHTML;
      }

      function normalizeProtectedDisplayLineBreaks(text) {
        return String(text || '')
          .replace(/[\u200B-\u200D\u2060\uFEFF]/g, '')
          .replace(
            /((?:พ\.ศ\.?|ค\.ศ\.?|(?:[\u0E01-\u0E2E]{1,2}\.){2,}))\s*[\r\n]+\s*(?=[0-9๐-๙]{4}(?:\b|$))/gu,
            '$1 '
          );
      }

      function shouldBreakBeforeClauseMarker(contextText, currentLineText) {
        const context = String(contextText || '').replace(/\s+/g, ' ').trim();
        const currentLine = String(currentLineText || '').replace(/\s+/g, ' ').trim();

        if (!context) {
          return false;
        }

        if (/(?:ตาม|ในกรณีตาม|ตามข้อ|ตามวรรค|ตามอนุมาตรา|หรือ)\s*$/u.test(context)) {
          return false;
        }

        if (
          /^(?:ข้อ|มาตรา|หมวด|ส่วน|บท)\s*[0-9๐-๙]+(?:\/[0-9๐-๙]+)?(?:\s|$)/u.test(currentLine)
          && !/[0-9๐-๙]\s*$/u.test(currentLine)
        ) {
          return true;
        }

        if (
          /(?:ดังนี้|ดังต่อไปนี้|ต่อไปนี้|มีกรณีดังต่อไปนี้|มีเหตุดังต่อไปนี้|เหตุหนึ่งเหตุใดต่อไปนี้|ได้แก่)\s*$/u.test(
            context,
          )
        ) {
          return true;
        }

        return /^\([0-9๐-๙]{1,3}\)/u.test(currentLine);
      }

      function normalizeClauseMarkerLineBreaks(text) {
        const raw = String(text || '');
        if (!raw) {
          return raw;
        }

        let result = '';
        let lastIndex = 0;
        const markerPattern = /\s+\([0-9๐-๙]{1,3}\)/gu;

        raw.replace(markerPattern, (match, offset) => {
          const leadingSegment = raw.slice(lastIndex, offset);
          result += leadingSegment;

          const contextText = result.slice(-80);
          const currentLineText = result.split('\n').pop() || '';
          const markerText = String(match || '').trim();

          if (shouldBreakBeforeClauseMarker(contextText, currentLineText)) {
            result = result.replace(/[ \t]+$/g, '');
            result += `\n${markerText}`;
          } else {
            result += ` ${markerText}`;
          }

          lastIndex = offset + match.length;
          return match;
        });

        result += raw.slice(lastIndex);
        return result;
      }

      function sanitizeDisplayText(text) {
        return normalizeClauseMarkerLineBreaks(replaceUserVisibleAiTerms(normalizeProtectedDisplayLineBreaks(text)))
          .replace(/(^|\n)\s*ข้อมูลที่พบจากฐานข้อมูลกฎหมาย(?:\s*\([^)]*\))?:?\s*(?=\n|$)/gu, '$1')
          .replace(/(^|\n)\s*\/\/\s*/g, '$1')
          .replace(/(^|[\s(])\/\/(?=[\s)]|$)/g, '$1')
          .replace(/[ \t]{2,}/g, ' ')
          .replace(
            /(มาตรา\s*[0-9๐-๙]+(?:\/[0-9๐-๙]+)?)\s*(?:\r?\n\s*)?((?:\([0-9๐-๙]{1,3}\)\s*){1,})/gu,
            (_, sectionRef, subsectionRefs) => `${sectionRef}${String(subsectionRefs || '').replace(/\s+/g, '')}`
          )
          .replace(/\n{3,}/g, '\n\n')
          .trim();
      }

      function stripBotUiNoiseText(text) {
        const raw = String(text || '')
          .replace(/\r\n?/g, '\n')
          .trim();
        if (!raw) {
          return raw;
        }

        const noisePatterns = [
          /^หากต้องการ(?:เจาะลึกต่อ|ข้อมูลเพิ่มเติม|เพิ่มเติม)\s*พิมพ์:/iu,
          /^(?:คำอธิบายเพิ่มเติม|อธิบายเพิ่มเติม|แสดงรายละเอียด|รายละเอียด|ใจความทั้งหมด|ฉันไม่เข้าใจ|แจ้งเพิ่มเติม)$/iu,
        ];

        const filteredLines = raw
          .split('\n')
          .map((line) => line.trim())
          .filter(Boolean)
          .filter((line) => !noisePatterns.some((pattern) => pattern.test(line)));

        return filteredLines.join('\n').trim();
      }

      function shouldMergeBulletContinuationLine(currentLine, nextLine) {
        const current = sanitizeDisplayText(currentLine).replace(/\s+/g, ' ').trim();
        const next = sanitizeDisplayText(nextLine).replace(/\s+/g, ' ').trim();

        if (!current || !next) {
          return false;
        }

        const endsWithProtectedAbbreviation =
          /(?:พ\.ศ\.?|ค\.ศ\.?|(?:[\u0E01-\u0E2E]{1,2}\.){2,})$/u.test(current);
        const nextStartsWithYear =
          /^(?:[0-9๐-๙]{4})(?:\b|$)/u.test(next);

        return endsWithProtectedAbbreviation && nextStartsWithYear;
      }

      function mergeProtectedBulletLines(lines) {
        const merged = [];

        for (let index = 0; index < lines.length; index += 1) {
          const current = String(lines[index] || '').trim();
          const next = String(lines[index + 1] || '').trim();

          if (!current) {
            continue;
          }

          if (next && shouldMergeBulletContinuationLine(current, next)) {
            merged.push(`${current} ${next}`.replace(/\s+/g, ' ').trim());
            index += 1;
            continue;
          }

          merged.push(current);
        }

        return merged;
      }

      function buildHighlightTerms(query) {
        const source = String(query || '').trim();
        if (!source) return [];
        const terms = new Set([source]);
        source
          .split(/\s+/)
          .map((part) => part.trim())
          .filter((part) => part.length >= 2)
          .forEach((part) => terms.add(part));
        return Array.from(terms).sort((a, b) => b.length - a.length);
      }

      function buildGuestDeviceHint() {
        const nav = window.navigator || {};
        const screenInfo = window.screen || {};
        const timezone = (() => {
          try {
            return Intl.DateTimeFormat().resolvedOptions().timeZone || '';
          } catch (_) {
            return '';
          }
