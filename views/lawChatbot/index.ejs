          : "ผู้เยี่ยมชม";
      const headerUserRole = currentUser
        ? "ผู้ดูแลระบบ"
        : isGoogleUser
          ? "ผู้ใช้ Google"
          : "ผู้เยี่ยมชม";
      const headerUserMeta = currentUser
        ? "ผู้ดูแลระบบ"
        : isGoogleUser
          ? ((signedInUser && signedInUser.email) || "เข้าสู่ระบบด้วย Google")
          : "ยังไม่ได้เข้าสู่ระบบ";
      const headerUserImage = !currentUser && isGoogleUser && signedInUser
        ? (signedInUser.picture || signedInUser.avatarUrl || "")
        : "";
      const headerUserIcon = currentUser
        ? "bi-shield-lock-fill"
        : isGoogleUser
          ? "bi-person-badge-fill"
          : "bi-person-circle";
      const botPackageVariant = currentUser ? "admin" : "free";
      const sidebarRecentItems = (
        Array.isArray(data && data.suggestedQuestions) && data.suggestedQuestions.length
          ? data.suggestedQuestions
              .map((item) => String((item && (item.questionText || item.question || item.text)) || "").trim())
              .filter(Boolean)
              .slice(0, 5)
          : [
              "สมาชิกออกจากสหกรณ์ ต้องทำอย่างไร?",
              "อำนาจหน้าที่ของคณะกรรมการดำเนินการสหกรณ์",
