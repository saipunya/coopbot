      function formatAiSummaryHtml(text, terms) {
        const raw = String(text || '');
        const allLines = raw.split('\n').map((l) => l.trimEnd());

        let headerLine = '';
        let bodyLines = allLines;
        if (allLines.length && /^[🤖🧠]/.test(allLines[0])) {
          headerLine = allLines[0];
          bodyLines = allLines.slice(1);
        }

        const sections = [];
        let current = null;
        bodyLines.forEach((line) => {
          const sub = line.match(/^ {2,}-\s+(.+)$/) || line.match(/^\t-\s+(.+)$/);
          const top = !sub && line.match(/^-\s+(.+)$/);
          if (top) {
            current = { title: top[1].trim(), items: [] };
            sections.push(current);
          } else if (sub && current) {
            current.items.push(sub[1].trim());
          } else if (line.trim() && current) {
            current.items.push(line.trim());
          }
        });

        let html = '';
        if (headerLine) {
          html += `<div class="ai-summary-header">${escapeHtml(headerLine)}</div>`;
        }

        if (sections.length) {
          sections.forEach((section) => {
            const icon = AI_SECTION_ICONS[section.title] || '📌';
            const titleHtml = applyHighlightHtml(section.title, terms);
            const itemsHtml = section.items
              .map((item) => buildBulletCardItemHtml(item, terms, 'ai'))
              .join('');
            html += `<div class="ai-section"><span class="ai-section-title">${icon} ${titleHtml}</span>`;
            if (itemsHtml) html += `<ul class="ai-bullets">${itemsHtml}</ul>`;
            html += `</div>`;
          });
        } else {
          html += applyHighlightHtml(bodyLines.join('\n'), terms);
        }

        return html;
      }

