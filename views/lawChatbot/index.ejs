            button.title = 'ซ่อนส่วนหัวของระบบ';
            button.setAttribute('aria-label', 'ซ่อนส่วนหัวของระบบ');
          }
        });

        localStorage.setItem(HEADER_COLLAPSE_KEY, collapsed ? '1' : '0');
      }

      function setPlanRibbonCollapsed(collapsed) {
        if (!lawbotApp || !togglePlanRibbonButtons.length) return;
        lawbotApp.classList.toggle('plan-ribbon-collapsed', collapsed);

        togglePlanRibbonButtons.forEach((button) => {
          button.setAttribute('aria-pressed', collapsed ? 'true' : 'false');

          if (collapsed) {
            button.innerHTML = '<i class="bi bi-layout-sidebar-inset"></i><span>แสดงแพ็กเกจ</span>';
            button.title = 'แสดงรายละเอียดแพ็กเกจ';
            button.setAttribute('aria-label', 'แสดงรายละเอียดแพ็กเกจ');
          } else {
            button.innerHTML = '<i class="bi bi-layout-sidebar-reverse"></i><span>ซ่อนแพ็กเกจ</span>';
            button.title = 'ซ่อนรายละเอียดแพ็กเกจ';
            button.setAttribute('aria-label', 'ซ่อนรายละเอียดแพ็กเกจ');
          }
        });

        localStorage.setItem(PLAN_RIBBON_COLLAPSE_KEY, collapsed ? '1' : '0');
      }

      function getInitialPlanRibbonCollapsed() {
        const storedValue = localStorage.getItem(PLAN_RIBBON_COLLAPSE_KEY);
        if (storedValue === '1') return true;
        if (storedValue === '0') return false;
        return window.matchMedia('(min-width: 768px)').matches;
      }

      function isStandaloneMode() {
        return window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;
      }

      function updateInstallButtons() {
        const inStandalone = isStandaloneMode();
        const canInstall = !inStandalone;

        if (installBtn) {
          installBtn.style.display = canInstall ? 'inline-flex' : 'none';
          installBtn.disabled = !deferredInstallPrompt;
          installBtn.title = deferredInstallPrompt
            ? 'ติดตั้งแอปลงหน้าจอหลัก'
            : 'ระบบกำลังรอคำสั่งติดตั้งจากเบราว์เซอร์';
          installBtn.setAttribute('aria-label', installBtn.title);
