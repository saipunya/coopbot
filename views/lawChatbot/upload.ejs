<%- include("../partials/header", { title, page }) %>

<style>
  .upload-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.8fr);
    gap: 1rem;
    align-items: stretch;
  }
  .upload-hero .card {
    margin-bottom: 0;
  }
  .upload-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent-strong);
    background: var(--accent-soft);
    padding: 0.45rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 0.85rem;
  }
  .upload-title {
    margin: 0 0 0.45rem;
    color: var(--accent-strong);
    font-size: clamp(1.55rem, 2.8vw, 2.1rem);
    line-height: 1.15;
  }
  .upload-lead {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
  }
  .upload-stat-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 252, 0.92));
  }
  .upload-stat-row {
    display: grid;
    gap: 0.9rem;
  }
  .upload-stat {
    padding: 0.95rem 1rem;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.88);
  }
  .upload-stat strong {
    display: block;
    margin-top: 0.25rem;
    font-size: 1.55rem;
    color: var(--accent-strong);
  }
  .upload-form {
    margin-top: 1rem;
    padding: 1.15rem;
    border-radius: 18px;
    background: rgba(241, 246, 251, 0.9);
    border: 1px solid var(--line);
  }
  .upload-form input[type="file"] {
    padding: 0.8rem;
    background: #fff;
  }
  .alert-note {
    padding: 0.9rem 1rem;
    border-radius: 14px;
    margin: 0.9rem 0 0;
    border: 1px solid transparent;
    font-weight: 700;
  }
  .alert-note.error {
    background: #fce9e7;
    border-color: #f1b8b1;
    color: #9b2c22;
  }
  .alert-note.success {
    background: #e8f7ee;
    border-color: #b8e3c8;
    color: #1f6a3a;
  }
  .soft-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.8rem;
  }
  .soft-list li {
    padding: 0.95rem 1rem;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.78);
  }
  .upload-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.75rem;
    margin-top: 0.45rem;
    font-size: 0.88rem;
    color: var(--subtle);
  }
  .type-chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    padding: 0;
    list-style: none;
  }
  .type-chip-list li {
    padding: 0.5rem 0.8rem;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    border: 1px solid rgba(21, 84, 122, 0.14);
    font-size: 0.83rem;
  }
  .section-toolbar {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .section-toolbar form {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }
  .section-toolbar select {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.7rem 0.82rem;
    font: inherit;
    background: #fff;
    color: var(--text);
  }
  .pagination-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .pagination-summary {
    color: var(--subtle);
    font-size: 0.92rem;
  }
  .pagination-links {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .pagination-link,
  .pagination-current,
  .pagination-ellipsis {
    min-width: 2.4rem;
    padding: 0.58rem 0.82rem;
    border-radius: 12px;
    text-align: center;
    font-weight: 700;
  }
  .pagination-link {
    background: #eef4f8;
    color: var(--accent-strong);
    text-decoration: none;
    border: 1px solid var(--line);
  }
  .pagination-current {
    background: var(--accent-strong);
    color: #fff;
    border: 1px solid var(--accent-strong);
  }
  .pagination-ellipsis {
    color: var(--subtle);
  }
  @media (max-width: 820px) {
    .upload-hero {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 620px) {
    .upload-form {
      padding: 0.95rem;
    }

    .upload-stat strong {
      font-size: 1.35rem;
    }

    .type-chip-list {
      gap: 0.5rem;
    }

    .type-chip-list li {
      width: fit-content;
      max-width: 100%;
    }

    .section-toolbar {
      justify-content: stretch;
    }

    .section-toolbar form,
    .section-toolbar select,
    .section-toolbar button {
      width: 100%;
    }

    .pagination-bar {
      flex-direction: column;
      align-items: stretch;
    }

    .pagination-links {
      justify-content: center;
    }
  }
</style>

<section class="upload-hero">
  <section class="card">
    <div class="upload-kicker">กฎหมายสหกรณ์และกลุ่มเกษตรกร</div>
    <h1 class="upload-title">อัปโหลดเอกสารเพื่อเสริมฐานความรู้ของแชตบอท</h1>
    <p class="upload-lead">นำเข้าไฟล์ PDF, DOC หรือ DOCX เพื่อให้ระบบอ่านเนื้อหา แยกข้อความ และเตรียมข้อมูลไว้สำหรับใช้ตอบคำถามในหน้าแชทให้แม่นยำขึ้น</p>

    <% if (errorMessage) { %>
      <div class="alert-note error"><%= errorMessage %></div>
    <% } %>
    <% if (successMessage) { %>
      <div class="alert-note success"><%= successMessage %></div>
    <% } %>

    <form class="upload-form" action="<%= data.uploadPath %>" method="post" enctype="multipart/form-data">
      <input type="hidden" name="returnTo" value="<%= returnPath %>" />
      <label for="lawPdf">เลือกไฟล์เอกสาร</label>
      <input id="lawPdf" type="file" name="lawPdf" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" required />
      <p style="margin-top: -0.2rem;">ขนาดไฟล์สูงสุด <strong><%= data.maxUploadMb %> MB</strong></p>
      <button type="submit">อัปโหลดเอกสาร</button>
    </form>
  </section>

  <section class="card upload-stat-card">
    <div>
      <h2 style="margin-top: 0; color: var(--accent-strong);">สถานะข้อมูล</h2>
      <p>ภาพรวมของเอกสารที่ถูกเตรียมไว้สำหรับใช้ตอบคำถามในระบบ</p>
    </div>
    <div class="upload-stat-row">
      <div class="upload-stat">
        ไฟล์ที่อัปโหลดแล้ว
        <strong><%= data.uploadedPdfCount %></strong>
      </div>
      <div class="upload-stat">
        จำนวน chunk ทั้งหมด
        <strong><%= data.uploadedChunkCount %></strong>
      </div>
    </div>
  </section>
</section>

<section class="card">
  <h2 style="margin-top: 0; color: var(--accent-strong);">ประเภทไฟล์ที่รองรับ</h2>
  <ul class="type-chip-list">
    <% data.acceptedTypes.forEach((type) => { %>
      <li><%= type %></li>
    <% }) %>
  </ul>
</section>

<section class="card">
  <h2 style="margin-top: 0; color: var(--accent-strong);">รายการอัปโหลดล่าสุด</h2>
  <div class="section-toolbar">
    <form action="/law-chatbot/upload" method="get">
      <input type="hidden" name="page" value="1" />
      <label for="uploadPerPage">จำนวนรายการต่อหน้า</label>
      <select id="uploadPerPage" name="perPage" aria-label="จำนวนรายการอัปโหลดต่อหน้า">
        <% [10, 20, 50].forEach((size) => { %>
          <option value="<%= size %>" <%= Number(data.pagination?.pageSize || 10) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
        <% }) %>
      </select>
      <button type="submit">แสดงผล</button>
    </form>
  </div>
  <ul class="soft-list">
    <% if (data.uploadedFiles.length === 0) { %>
      <li>ยังไม่มีรายการอัปโหลด</li>
    <% } %>
    <% data.uploadedFiles.forEach((file) => { %>
      <li>
        <strong><%= file.originalname %></strong>
        <div class="upload-meta">
          <% if (file.documentNumber) { %>
            <span>เลขที่ <%= file.documentNumber %></span>
          <% } %>
          <% if (file.documentDateText) { %>
            <span>ลงวันที่ <%= file.documentDateText %></span>
          <% } %>
          <span><%= file.mimetype %></span>
          <span><%= file.size %> ไบต์</span>
          <span><%= file.insertedChunkCount || 0 %> ชิ้นข้อมูล</span>
          <span>สถานะ <%= file.status === 'queued' ? 'รอประมวลผล' : (file.status || '-') %></span>
        </div>
        <% if (file.processingMessage) { %>
          <div class="upload-meta"><span><%= file.processingMessage %></span></div>
        <% } %>
      </li>
    <% }) %>
  </ul>
  <%- include("../admin/partials/pagination", { pagination: data.pagination, basePath: "/law-chatbot/upload", query: { perPage: data.pagination?.pageSize || 10 }, pageKey: "page", itemLabel: "รายการอัปโหลด" }) %>
</section>

<%- include("../partials/footer") %>
