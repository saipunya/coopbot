<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <style>
      :root {
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --surface: rgba(255, 255, 255, 0.92);
        --primary: #15547a;
        --primary-strong: #0f4667;
        --primary-soft: #d2e8f7;
        --text-main: #1f2a37;
        --text-sub: #5d6a79;
        --border: #d8e2ea;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      }
      body {
        margin: 0;
        font-family: 'Sarabun', Arial, sans-serif;
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        color: var(--text-main);
      }
      .wrap {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
      }
      .card {
        width: min(440px, 100%);
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: 1.5rem;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      input {
        width: 100%;
        padding: 0.95rem 1rem;
        border: 1px solid #c9d9e6;
        border-radius: 14px;
        margin: 0.4rem 0 1rem;
        box-sizing: border-box;
      }
      input:focus {
        outline: none;
        border-color: #6aa6cc;
        box-shadow: 0 0 0 0.18rem rgba(47, 127, 184, 0.14);
      }
      button {
        width: 100%;
        padding: 0.95rem 1rem;
        border: none;
        border-radius: 14px;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .google-btn {
        display: inline-flex;
        width: 100%;
        align-items: center;
        justify-content: center;
        gap: 0.65rem;
        padding: 0.95rem 1rem;
        margin-top: 0.85rem;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: #fff;
        color: var(--text-main);
        font-weight: 700;
        text-decoration: none;
      }
      .google-btn:hover {
        background: #f7fbff;
      }
      .error {
        color: #b42318;
        font-weight: 700;
      }
      .success {
        color: #1d7a52;
        font-weight: 700;
      }
      .muted {
        color: var(--text-sub);
      }
      .divider {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 1rem 0 0.2rem;
        color: var(--text-sub);
        font-size: 0.88rem;
      }
      .divider::before,
      .divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: var(--border);
      }
      .back {
        display: inline-block;
        margin-top: 1rem;
        color: var(--primary);
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="wrap">
      <section class="card">
        <p class="muted">Admin Area</p>
        <h1>เข้าสู่ระบบผู้ดูแล</h1>
        <% if (successMessage) { %>
          <p class="success"><%= successMessage %></p>
        <% } %>
        <% if (errorMessage) { %>
          <p class="error"><%= errorMessage %></p>
        <% } %>
        <form action="/admin/login" method="post">
          <label for="username">Username</label>
          <input id="username" name="username" type="text" required />

          <label for="password">Password</label>
          <input id="password" name="password" type="password" required />

          <button type="submit">Login</button>
        </form>
        <% if (googleLoginEnabled) { %>
          <div class="divider">หรือ</div>
          <a class="google-btn" href="/auth/google">
            <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
              <path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.7 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.1 29.3 4 24 4 12.9 4 4 12.9 4 24s8.9 20 20 20 20-8.9 20-20c0-1.2-.1-2.3-.4-3.5z"/>
              <path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15.1 18.9 12 24 12c3 0 5.8 1.1 7.9 3l5.7-5.7C34.1 6.1 29.3 4 24 4c-7.7 0-14.4 4.3-17.7 10.7z"/>
              <path fill="#4CAF50" d="M24 44c5.2 0 10-2 13.6-5.2l-6.3-5.3C29.2 35.1 26.7 36 24 36c-5.3 0-9.8-3.3-11.5-8l-6.5 5C9.3 39.5 16.1 44 24 44z"/>
              <path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-1 2.9-3 5.2-5.6 6.7l.1-.1 6.3 5.3C35.7 39.7 44 34 44 24c0-1.2-.1-2.3-.4-3.5z"/>
            </svg>
            เข้าสู่ระบบด้วย Google
          </a>
        <% } %>
        <a class="back" href="/law-chatbot">กลับไปหน้าแชต</a>
      </section>
    </div>
  </body>
</html>
