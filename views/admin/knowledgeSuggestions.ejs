<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { margin: 0; font-family: 'Sarabun', Arial, sans-serif; background: linear-gradient(160deg, #e6eef6, #f5f9fc); color: #1f2a37; }
      .shell { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; padding: 1.5rem 0 3rem; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid #d8e2ea; border-radius: 20px; box-shadow: 0 18px 45px rgba(18,52,77,0.16); padding: 1.25rem; margin-bottom: 1rem; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:1rem; position:relative; overflow:hidden; }
      .topbar::before { content:""; position:absolute; inset:0; background: radial-gradient(circle at top left, rgba(255,255,255,0.36), transparent 30%), linear-gradient(135deg, rgba(255,255,255,0.16), transparent 44%); pointer-events:none; }
      .topbar > * { position:relative; z-index:1; }
      .topbar a { color: #0f4667; text-decoration:none; font-weight:700; }
      .alert { padding: 0.9rem 1rem; border-radius: 14px; margin-bottom: 1rem; }
      .alert.success { background:#e8f7ee; color:#1f6a3a; border:1px solid #b8e3c8; }
      .alert.error { background:#fce9e7; color:#9b2c22; border:1px solid #f1b8b1; }
      .tab-row { display:flex; gap:0.75rem; flex-wrap:wrap; }
      .tab-row a { text-decoration:none; font-weight:700; color:#0f4667; padding:0.72rem 1rem; border-radius:14px; border:1px solid #d8e2ea; background:#eef4f8; }
      .tab-row a.active { background:#0f5f8f; border-color:#0f5f8f; color:#fff; }
      .grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:1rem; }
      .metric-card { position:relative; overflow:hidden; }
      .metric-card::before { content:""; position:absolute; inset:0 0 auto; height:4px; background: linear-gradient(90deg, #c88a00, transparent 85%); }
      .metric { font-size: 1.8rem; font-weight: 700; color: #0f4667; margin: 0.3rem 0 0; }
      .section-note { color:#5d6a79; line-height:1.7; }
      .form-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:0.9rem; }
      .field label { display:block; font-weight:700; margin-bottom:0.35rem; }
      .field input, .field select, .field textarea { width:100%; box-sizing:border-box; border:1px solid #c9d8e4; border-radius:14px; padding:0.8rem 0.9rem; font:inherit; background:#fff; color:#1f2a37; }
      .field textarea { min-height:130px; resize:vertical; }
      .primary-btn, .secondary-btn { border:none; border-radius:12px; padding:0.72rem 0.95rem; color:#fff; font:inherit; font-weight:700; cursor:pointer; }
      .primary-btn { background:#0f5f8f; }
      .secondary-btn { background:#607180; }
      .section-toolbar { display:flex; justify-content:flex-end; gap:0.75rem; flex-wrap:wrap; margin-bottom:1rem; }
      .section-toolbar form { display:flex; align-items:center; gap:0.65rem; flex-wrap:wrap; }
      .section-toolbar select { border:1px solid #c9d8e4; border-radius:12px; padding:0.62rem 0.82rem; font:inherit; background:#fff; color:#1f2a37; }
      .section-toolbar button { border:none; border-radius:12px; padding:0.66rem 0.9rem; font:inherit; font-weight:700; color:#fff; background:#0f5f8f; cursor:pointer; }
      .soft-list { list-style:none; padding:0; margin:0; display:grid; gap:0.8rem; }
      .soft-list li { padding:0.95rem 1rem; border:1px solid #d8e2ea; border-radius:16px; background: rgba(255,255,255,0.82); min-width:0; }
      .list-item-title, .list-item-body, .suggestion-meta, .editor-summary, .section-note { overflow-wrap:anywhere; word-break:break-word; }
      .list-item-title { display:block; color:#0f4667; line-height:1.5; }
      .suggestion-meta { margin-top:0.45rem; color:#5d6a79; font-size:0.92rem; line-height:1.6; }
      .list-item-body { margin-top:0.6rem; color:#1f2a37; white-space:pre-line; line-height:1.7; }
      .suggestion-editor { margin-top:0.9rem; padding:0.95rem; border:1px solid #d8e2ea; border-radius:16px; background:rgba(241,246,251,0.82); }
      details.suggestion-editor { padding:0.85rem 0.95rem; }
      .editor-summary { cursor:pointer; font-weight:700; color:#0f4667; list-style:none; display:flex; align-items:center; gap:0.55rem; }
      .editor-summary::-webkit-details-marker { display:none; }
      .editor-summary::before { content:"+"; width:1.3rem; height:1.3rem; border-radius:999px; display:inline-flex; align-items:center; justify-content:center; background:#d2e8f7; color:#0f4667; font-weight:700; flex:0 0 auto; }
      details[open] > .editor-summary::before { content:"-"; }
      .editor-body { margin-top:0.9rem; }
      .suggestion-actions, .knowledge-actions { display:flex; gap:0.65rem; flex-wrap:wrap; margin-top:0.9rem; }
      .pagination-bar { display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; margin-top:1rem; }
      .pagination-summary { color:#5d6a79; font-size:0.92rem; }
      .pagination-links { display:flex; align-items:center; gap:0.45rem; flex-wrap:wrap; }
      .pagination-link, .pagination-current, .pagination-ellipsis { min-width:2.4rem; padding:0.58rem 0.82rem; border-radius:12px; text-align:center; font-weight:700; }
      .pagination-link { background:#eef4f8; color:#0f4667; text-decoration:none; border:1px solid #d8e2ea; }
      .pagination-current { background:#0f5f8f; color:#fff; border:1px solid #0f5f8f; }
      .pagination-ellipsis { color:#5d6a79; }
      @media (max-width: 820px) {
        .shell { width: min(100%, calc(100% - 1rem)); padding: 0.75rem 0 1.4rem; }
        .card, .topbar { padding: 1rem; }
        .topbar { flex-direction: column; align-items: stretch; }
        .field input, .field select, .field textarea, .primary-btn, .secondary-btn, .section-toolbar select, .section-toolbar button { font-size:16px; }
        .section-toolbar, .suggestion-actions, .knowledge-actions, .pagination-bar { flex-direction:column; align-items:stretch; }
        .section-toolbar form, .section-toolbar select, .section-toolbar button, .suggestion-actions form, .suggestion-actions button, .knowledge-actions form, .knowledge-actions button { width:100%; }
        .pagination-links { justify-content:center; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="card topbar">
        <div>
          <h1 style="margin:0; color:#0f4667;">ข้อเสนอคำตอบจากผู้ใช้งาน</h1>
          <p style="margin:0.35rem 0 0; color:#5d6a79;">ตรวจทาน แก้ไข และอนุมัติข้อเสนอจากผู้ใช้งานในหน้าเฉพาะแยกจาก dashboard</p>
        </div>
        <a href="/admin">กลับหน้าแดชบอร์ด</a>
      </section>

      <section class="card">
        <%- include("partials/knowledgeAdminTabs", { activeTab: "knowledge-suggestions" }) %>
      </section>

      <section class="grid">
        <article class="card metric-card"><div>รอตรวจสอบ</div><div class="metric"><%= data.pendingSuggestionCount %></div></article>
        <article class="card metric-card"><div>feedback อัตโนมัติ</div><div class="metric"><%= data.pendingSuggestionSourceTypeCounts?.auto_feedback || 0 %></div></article>
        <article class="card metric-card"><div>ระบบตอบไม่ได้</div><div class="metric"><%= data.pendingSuggestionSourceTypeCounts?.auto_no_answer || 0 %></div></article>
        <article class="card metric-card"><div>เพิ่มวันนี้: feedback</div><div class="metric"><%= data.createdTodaySuggestionSourceTypeCounts?.auto_feedback || 0 %></div></article>
        <article class="card metric-card"><div>เพิ่มวันนี้: ตอบไม่ได้</div><div class="metric"><%= data.createdTodaySuggestionSourceTypeCounts?.auto_no_answer || 0 %></div></article>
      </section>

      <section class="card">
        <h2 style="margin-top:0; color:#0f4667;">รายการข้อเสนอที่รอตรวจสอบ</h2>
        <p class="section-note">เมื่ออนุมัติ ระบบจะนำข้อมูลฉบับล่าสุดจากฟอร์มแก้ไขด้านล่างไปบันทึกลงรายการคำถามแนะนำทันที และหากข้อเสนอนี้มาจากผู้ใช้ฟรีที่ลงชื่อเข้าใช้ ระบบจะเพิ่มสิทธิ์ถามฟรีให้อีก 1 ครั้งต่อเดือน</p>
        <div class="section-toolbar">
          <form action="/admin/knowledge-suggestions" method="get">
            <input type="hidden" name="page" value="1" />
            <label for="sourceType">ช่องทาง</label>
            <select id="sourceType" name="sourceType" aria-label="กรองประเภทข้อเสนอที่รอตรวจสอบ">
              <% (data.pendingSuggestionSourceTypeOptions || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(data.pendingSuggestionSourceTypeFilter || 'all') === option.value ? 'selected' : '' %>><%= option.label %></option>
              <% }) %>
            </select>
            <label for="perPage">จำนวนรายการต่อหน้า</label>
            <select id="perPage" name="perPage" aria-label="จำนวนข้อเสนอที่รอตรวจสอบต่อหน้า">
              <% [8, 16, 24].forEach((size) => { %>
                <option value="<%= size %>" <%= Number(data.pendingSuggestionsPagination?.pageSize || 12) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
              <% }) %>
            </select>
            <button type="submit">แสดงผล</button>
          </form>
        </div>
        <ul class="soft-list">
          <% if (data.pendingSuggestions.length === 0) { %>
            <li>ยังไม่มีข้อเสนอคำตอบที่รออนุมัติในตัวกรองนี้</li>
          <% } %>
          <% data.pendingSuggestions.forEach((item) => { %>
            <li>
              <strong class="list-item-title"><%= item.title %></strong>
              <div class="suggestion-meta">
                ใช้กับ: <%= item.target === 'group' ? 'กลุ่มเกษตรกร' : 'สหกรณ์' %>
                <% if (item.sourceType) { %> | ช่องทาง:
                  <%= item.sourceType === 'voice'
                    ? 'เสียง'
                    : item.sourceType === 'auto_feedback'
                      ? 'feedback อัตโนมัติ'
                      : item.sourceType === 'auto_no_answer'
                        ? 'คำถามที่ระบบตอบไม่ได้'
                        : 'ข้อความ' %>
                <% } %>
                <% if (item.submittedBy) { %> | ผู้เสนอ: <%= item.submittedBy %><% } %>
                <% if (item.createdAt) { %> | ส่งเมื่อ: <%= item.createdAt %><% } %>
              </div>
              <div class="list-item-body"><%= item.content %></div>
              <% if (item.sourceReference) { %>
                <div class="suggestion-meta">แหล่งอ้างอิง: <%= item.sourceReference %></div>
              <% } %>
              <details class="suggestion-editor" open>
                <summary class="editor-summary">แก้ไขข้อเสนอก่อนอนุมัติ</summary>
                <div class="editor-body">
                  <form action="/admin/knowledge-suggestions/update" method="post">
                    <input type="hidden" name="id" value="<%= item.id %>" />
                    <input type="hidden" name="returnTo" value="<%= returnPath %>" />
                    <div class="form-grid">
                      <div class="field">
                        <label for="suggestion-target-<%= item.id %>">ประเภทข้อมูล</label>
                        <select id="suggestion-target-<%= item.id %>" name="target" required>
                          <option value="coop" <%= item.target === 'coop' ? 'selected' : '' %>>สหกรณ์</option>
                          <option value="group" <%= item.target === 'group' ? 'selected' : '' %>>กลุ่มเกษตรกร</option>
                        </select>
                      </div>
                      <div class="field">
                        <label for="suggestion-title-<%= item.id %>">หัวข้อ</label>
                        <input id="suggestion-title-<%= item.id %>" name="title" type="text" value="<%= item.title %>" required />
                      </div>
                    </div>
                    <div class="field" style="margin-top:0.9rem;">
                      <label for="suggestion-content-<%= item.id %>">รายละเอียดคำตอบ</label>
                      <textarea id="suggestion-content-<%= item.id %>" name="content" required><%= item.content %></textarea>
                    </div>
                    <div class="field" style="margin-top:0.9rem;">
                      <label for="suggestion-source-reference-<%= item.id %>">แหล่งอ้างอิง</label>
                      <textarea id="suggestion-source-reference-<%= item.id %>" name="sourceReference" placeholder="เช่น มาตรา 12 พ.ร.บ.สหกรณ์ พ.ศ. 2542"><%= item.sourceReference || '' %></textarea>
                    </div>
                    <div class="field" style="margin-top:0.9rem;">
                      <label for="suggestion-review-note-<%= item.id %>">หมายเหตุการตรวจทาน</label>
                      <input id="suggestion-review-note-<%= item.id %>" name="reviewNote" type="text" value="<%= item.reviewNote || '' %>" placeholder="เช่น ปรับถ้อยคำก่อนบันทึกเป็นคำถามแนะนำ" />
                    </div>
                    <div class="suggestion-actions">
                      <button class="secondary-btn" type="submit">บันทึกการแก้ไขก่อน</button>
                    </div>
                  </form>
                </div>
              </details>
              <div class="knowledge-actions">
                <% if (item.sourceType === 'auto_no_answer') { %>
                <form action="/admin/knowledge-suggestions/save-as-knowledge" method="post" onsubmit="return confirm('ยืนยันการบันทึกข้อเสนอนี้เป็นฐานความรู้ และนำออกจากคิวตรวจข้อเสนอใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= returnPath %>" />
                  <button class="primary-btn" type="submit">บันทึกเป็นฐานความรู้</button>
                </form>
                <% } %>
                <form action="/admin/knowledge-suggestions/approve" method="post" onsubmit="return confirm('ยืนยันการอนุมัติและบันทึกเป็นคำถามแนะนำจากข้อมูลฉบับล่าสุดใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= returnPath %>" />
                  <button class="primary-btn" type="submit">อนุมัติและบันทึกเป็นคำถามแนะนำ</button>
                </form>
                <form action="/admin/knowledge-suggestions/reject" method="post" onsubmit="return confirm('ยืนยันการปฏิเสธข้อเสนอนี้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= returnPath %>" />
                  <button class="secondary-btn" type="submit">ปฏิเสธ</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
        <%- include("partials/pagination", { pagination: data.pendingSuggestionsPagination, basePath: "/admin/knowledge-suggestions", query: { perPage: data.pendingSuggestionsPagination?.pageSize || 12, sourceType: data.pendingSuggestionSourceTypeFilter || 'all' }, pageKey: "page", itemLabel: "ข้อเสนอที่รอตรวจสอบ" }) %>
      </section>
    </div>
  </body>
</html>
