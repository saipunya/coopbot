<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { font-family: "Sarabun", Arial, sans-serif; background: #f4f8fb; color: #1f2a37; }
      .page-shell { max-width: 1180px; margin: 0 auto; padding: 1.5rem 1rem 3rem; }
      .card { border-color: #d8e2ea; box-shadow: 0 10px 30px rgba(18, 52, 77, 0.08); }
      .query-cell { max-width: 520px; white-space: normal; overflow-wrap: anywhere; }
      .badge-soft { background: #e8f1fb; color: #24557e; }
      .empty-state { border: 1px dashed #b8c8d6; background: #fff; border-radius: 0.75rem; padding: 2rem; text-align: center; color: #5d6a79; }
    </style>
  </head>
  <body>
    <main class="page-shell">
      <% if (successMessage) { %><div class="alert alert-success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert alert-danger"><%= errorMessage %></div><% } %>

      <section class="card mb-3">
        <div class="card-body d-flex flex-column flex-lg-row justify-content-between gap-3">
          <div>
            <div class="badge badge-soft mb-2">Admin</div>
            <h1 class="h3 mb-1">Search Miss Logs</h1>
            <p class="text-secondary mb-0">อ่านจาก <code>logs/search-misses.jsonl</code> แล้ว group คำถามซ้ำ เรียงจากจำนวนครั้งมากไปน้อย</p>
          </div>
          <div class="d-flex align-items-start gap-2">
            <a class="btn btn-outline-secondary" href="/admin">กลับหน้าแดชบอร์ด</a>
            <a class="btn btn-outline-primary" href="/admin/suggested-questions">Q&A</a>
          </div>
        </div>
      </section>

      <section class="card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center gap-3 mb-3">
            <h2 class="h5 mb-0">คำถามที่ค้นไม่เจอ / คะแนนต่ำ</h2>
            <span class="badge text-bg-primary"><%= groupedMisses.length %> query groups</span>
          </div>

          <% if (!groupedMisses.length) { %>
            <div class="empty-state">
              ยังไม่มี search miss log หรือยังไม่พบรายการที่อ่านได้จากไฟล์ JSONL
            </div>
          <% } else { %>
            <div class="table-responsive">
              <table class="table align-middle">
                <thead>
                  <tr>
                    <th>คำถาม</th>
                    <th class="text-end">จำนวนครั้ง</th>
                    <th>ล่าสุด</th>
                    <th>Reason ล่าสุด</th>
                    <th class="text-end">Confidence</th>
                    <th>Top result ล่าสุด</th>
                    <th class="text-end">จัดการ</th>
                  </tr>
                </thead>
                <tbody>
                  <% groupedMisses.forEach((item) => { %>
                    <tr>
                      <td class="query-cell">
                        <strong><%= item.query %></strong>
                        <% if (item.normalizedQuery && item.normalizedQuery !== item.query) { %>
                          <div class="small text-secondary"><%= item.normalizedQuery %></div>
                        <% } %>
                      </td>
                      <td class="text-end"><span class="badge text-bg-dark"><%= item.count %></span></td>
                      <td class="small"><%= item.latestTimestamp || "-" %></td>
                      <td><span class="badge text-bg-warning"><%= item.latestReason || "-" %></span></td>
                      <td class="text-end"><%= item.latestConfidence === "" ? "-" : item.latestConfidence %></td>
                      <td class="small">
                        <%= item.latestTopResultKeyword || "-" %>
                        <% if (item.latestTopResultScore) { %>
                          <span class="text-secondary">(<%= item.latestTopResultScore %>)</span>
                        <% } %>
                      </td>
                      <td class="text-end">
                        <div class="d-inline-flex gap-2">
                          <a class="btn btn-sm btn-primary" href="/admin/search-misses/new-faq?query=<%= encodeURIComponent(item.query) %>">เพิ่มเข้า Q&A</a>
                          <form action="/admin/search-misses/delete" method="post" onsubmit="return confirm('ลบ query นี้ออกจาก search miss log ใช่หรือไม่');">
                            <input type="hidden" name="query" value="<%= item.query %>" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">ลบออกจาก log</button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
        </div>
      </section>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
