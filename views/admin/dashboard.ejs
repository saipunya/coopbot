<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --surface: rgba(255, 255, 255, 0.88);
        --surface-strong: #ffffff;
        --surface-soft: #f1f6fb;
        --primary: #15547a;
        --primary-strong: #0f4667;
        --primary-soft: #d2e8f7;
        --text-main: #1f2a37;
        --text-sub: #5d6a79;
        --border: #d8e2ea;
        --ok: #1d7a52;
        --warn: #8b2e2e;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: 'Sarabun', Arial, sans-serif;
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        background-attachment: fixed;
        color: var(--text-main);
      }
      .shell {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.4rem 0 3rem;
      }
      .topbar, .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
      }
      .hero-title {
        margin: 0;
        color: var(--primary-strong);
        font-size: clamp(1.45rem, 2.6vw, 2rem);
      }
      .hero-subtitle {
        margin: 0.28rem 0 0;
        color: var(--text-sub);
        line-height: 1.6;
      }
      .topbar-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.45rem 0.78rem;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary-strong);
        font-weight: 700;
        font-size: 0.82rem;
        margin-bottom: 0.75rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }
      .card {
        padding: 1.25rem;
        margin-bottom: 1rem;
      }
      .metric-card {
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 252, 0.92));
      }
      .metric-label {
        margin: 0;
        color: var(--text-sub);
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.35rem 0 0;
        color: var(--primary-strong);
      }
      .logout-btn {
        border: none;
        border-radius: 14px;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        padding: 0.85rem 1.05rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      ul {
        padding-left: 1.2rem;
      }
      a {
        color: var(--primary-strong);
      }
      h2 {
        color: var(--primary-strong);
      }
      p {
        color: var(--text-sub);
      }
      .alert {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        margin-bottom: 1rem;
        border: 1px solid transparent;
        box-shadow: 0 8px 20px rgba(18, 52, 77, 0.08);
      }
      .alert.success {
        background: #e8f7ee;
        border-color: #b8e3c8;
        color: #1f6a3a;
      }
      .alert.error {
        background: #fce9e7;
        border-color: #f1b8b1;
        color: #9b2c22;
      }
      .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.9rem;
      }
      .field label {
        display: block;
        font-weight: 700;
        margin-bottom: 0.35rem;
      }
      .field input,
      .field select,
      .field textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid #c9d8e4;
        border-radius: 14px;
        padding: 0.8rem 0.9rem;
        font: inherit;
        background: var(--surface-strong);
        color: var(--text-main);
      }
      .field textarea {
        min-height: 130px;
        resize: vertical;
      }
      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        outline: none;
        border-color: #6aa6cc;
        box-shadow: 0 0 0 0.18rem rgba(47, 127, 184, 0.14);
      }
      .primary-btn {
        border: none;
        border-radius: 14px;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        padding: 0.9rem 1.1rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .knowledge-list li {
        margin-bottom: 0.8rem;
      }
      .knowledge-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.85rem;
        gap: 0.65rem;
        flex-wrap: wrap;
      }
      .danger-btn {
        border: none;
        border-radius: 12px;
        background: linear-gradient(145deg, #b63d2f, #922f24);
        color: #fff;
        padding: 0.7rem 0.9rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(146, 47, 36, 0.18);
      }
      .secondary-btn {
        border: none;
        border-radius: 12px;
        background: linear-gradient(145deg, #7c8c98, #607180);
        color: #fff;
        padding: 0.7rem 0.9rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(96, 113, 128, 0.16);
      }
      .suggestion-meta {
        margin-top: 0.45rem;
        color: var(--text-sub);
        font-size: 0.92rem;
        line-height: 1.6;
      }
      .soft-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.8rem;
      }
      .soft-list li {
        padding: 0.95rem 1rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.76);
      }
      .quick-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding: 0;
        margin: 0;
        list-style: none;
      }
      .quick-links a {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
        padding: 0.7rem 0.95rem;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary-strong);
        border: 1px solid rgba(21, 84, 122, 0.14);
        font-weight: 700;
      }
      .section-note {
        margin-top: -0.15rem;
        margin-bottom: 1rem;
      }
      @media (max-width: 760px) {
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% if (successMessage) { %>
        <div class="alert success"><%= successMessage %></div>
      <% } %>
      <% if (errorMessage) { %>
        <div class="alert error"><%= errorMessage %></div>
      <% } %>

      <section class="topbar">
        <div>
          <div class="topbar-badge">Admin Dashboard</div>
          <h1 class="hero-title"><%= user.name %></h1>
          <p class="hero-subtitle"><%= user.position %> | <%= user.username %></p>
        </div>
        <form action="/admin/logout" method="post">
          <button class="logout-btn" type="submit">Logout</button>
        </form>
      </section>

      <section class="grid">
        <article class="card metric-card">
          <p class="metric-label">Total uploads</p>
          <p class="metric"><%= uploadData.uploadedPdfCount %></p>
        </article>
        <article class="card metric-card">
          <p class="metric-label">Total chunks</p>
          <p class="metric"><%= uploadData.uploadedChunkCount %></p>
        </article>
        <article class="card metric-card">
          <p class="metric-label">Total feedback</p>
          <p class="metric"><%= feedbackData.feedbackCount %></p>
        </article>
      </section>

      <section class="card">
        <h2>Recent uploads</h2>
        <p class="section-note">เอกสารล่าสุดที่ถูกนำเข้าเพื่อใช้เป็นฐานความรู้ของแชตบอท</p>
        <ul class="soft-list">
          <% if (uploadData.uploadedFiles.length === 0) { %>
            <li>ยังไม่มีรายการอัปโหลดใน session นี้</li>
          <% } %>
          <% uploadData.uploadedFiles.forEach((file) => { %>
            <li>
              <%= file.originalname %>
              <% if (file.documentNumber) { %> - เลขที่ <%= file.documentNumber %><% } %>
              <% if (file.documentDateText) { %> - ลงวันที่ <%= file.documentDateText %><% } %>
              - <%= file.insertedChunkCount || 0 %> chunks
            </li>
          <% }) %>
        </ul>
      </section>

      <section class="card">
        <h2>Quick links</h2>
        <ul class="quick-links">
          <li><a href="/law-chatbot">หน้าแชตสาธารณะ</a></li>
          <li><a href="/law-chatbot/upload">หน้าจัดการอัปโหลด</a></li>
          <li><a href="/law-chatbot/feedback">หน้าดู feedback</a></li>
          <li><a href="#knowledge-management">จัดการความรู้แชตบอท</a></li>
          <li><a href="#knowledge-suggestions">ตรวจข้อเสนอจากผู้ใช้งาน</a></li>
        </ul>
      </section>

      <section class="card" id="knowledge-management">
        <h2>เพิ่มหรือแก้ไขความรู้สำหรับตอบคำถาม</h2>
        <p class="section-note">
          ใช้หน้านี้เพื่อเพิ่มข้อมูลที่ถูกต้องลงในฐานข้อมูล เมื่อ AI ตอบไม่ตรงข้อเท็จจริง ระบบจะนำข้อมูลชุดนี้ไปช่วยตอบในรอบถัดไป
        </p>
        <form action="/admin/knowledge" method="post">
          <div class="form-grid">
            <div class="field">
              <label for="target">ประเภทข้อมูล</label>
              <select id="target" name="target" required>
                <% knowledgeData.targets.forEach((target) => { %>
                  <option value="<%= target.value %>"><%= target.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="lawNumber">เลขอ้างอิง / หมวด</label>
              <input id="lawNumber" name="lawNumber" type="text" placeholder="เช่น หมวดสมาชิก หรือ ข้อ 12" />
            </div>
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="title">หัวข้อ</label>
            <input id="title" name="title" type="text" placeholder="เช่น การรับสมาชิกสหกรณ์" required />
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="content">รายละเอียดความรู้ / คำตอบที่ถูกต้อง</label>
            <textarea id="content" name="content" placeholder="พิมพ์ข้อมูลที่ต้องการให้บอทใช้เป็นหลักเมื่อมีคนถามเรื่องนี้" required></textarea>
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="sourceNote">หมายเหตุ / แหล่งที่มา</label>
            <input id="sourceNote" name="sourceNote" type="text" placeholder="เช่น มาตรา 15, เอกสารประชุม, หรือคำชี้แจงจากผู้เชี่ยวชาญ" />
          </div>
          <div style="margin-top: 1rem;">
            <button class="primary-btn" type="submit">บันทึกความรู้ลงฐานข้อมูล</button>
          </div>
        </form>
      </section>

      <section class="card">
        <h2>ความรู้ที่บันทึกล่าสุด</h2>
        <p>ทั้งหมด <strong><%= knowledgeData.knowledgeCount %></strong> รายการ</p>
        <ul class="knowledge-list soft-list">
          <% if (knowledgeData.recentKnowledge.length === 0) { %>
            <li>ยังไม่มีความรู้ที่เพิ่มเข้าฐานข้อมูล</li>
          <% } %>
          <% knowledgeData.recentKnowledge.forEach((item) => { %>
            <li>
              <strong><%= item.title %></strong>
              <% if (item.lawNumber) { %> - <%= item.lawNumber %><% } %>
              <br />
              <small>
                ใช้กับ: <%= item.target === 'group' ? 'กลุ่มเกษตรกร' : 'สหกรณ์' %>
                <% if (item.sourceNote) { %> | แหล่งที่มา: <%= item.sourceNote %><% } %>
              </small>
              <br />
              <%= item.content %>
              <div class="knowledge-actions">
                <form action="/admin/knowledge/delete" method="post" onsubmit="return confirm('ยืนยันการลบข้อมูลฐานความรู้นี้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <button class="danger-btn" type="submit">ลบรายการนี้</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      </section>

      <section class="card" id="knowledge-suggestions">
        <h2>ข้อเสนอคำตอบจากผู้ใช้งาน</h2>
        <p>รอตรวจสอบ <strong><%= knowledgeData.pendingSuggestionCount %></strong> รายการ</p>
        <ul class="knowledge-list soft-list">
          <% if (knowledgeData.pendingSuggestions.length === 0) { %>
            <li>ยังไม่มีข้อเสนอคำตอบที่รออนุมัติ</li>
          <% } %>
          <% knowledgeData.pendingSuggestions.forEach((item) => { %>
            <li>
              <strong><%= item.title %></strong>
              <div class="suggestion-meta">
                ใช้กับ: <%= item.target === 'group' ? 'กลุ่มเกษตรกร' : 'สหกรณ์' %>
                <% if (item.sourceType) { %> | ช่องทาง: <%= item.sourceType === 'voice' ? 'เสียง' : 'ข้อความ' %><% } %>
                <% if (item.createdAt) { %> | ส่งเมื่อ: <%= item.createdAt %><% } %>
              </div>
              <div style="margin-top: 0.6rem; color: var(--text-main); white-space: pre-line;"><%= item.content %></div>
              <div class="knowledge-actions">
                <form action="/admin/knowledge-suggestions/approve" method="post" onsubmit="return confirm('ยืนยันการอนุมัติและนำเข้าฐานความรู้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <button class="primary-btn" type="submit">อนุมัติและนำเข้า</button>
                </form>
                <form action="/admin/knowledge-suggestions/reject" method="post" onsubmit="return confirm('ยืนยันการปฏิเสธข้อเสนอนี้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <button class="secondary-btn" type="submit">ปฏิเสธ</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
      </section>
    </div>
  </body>
</html>
