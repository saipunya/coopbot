<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --surface: rgba(255, 255, 255, 0.88);
        --surface-strong: #ffffff;
        --surface-soft: #f1f6fb;
        --primary: #15547a;
        --primary-strong: #0f4667;
        --primary-soft: #d2e8f7;
        --text-main: #1f2a37;
        --text-sub: #5d6a79;
        --border: #d8e2ea;
        --ok: #1d7a52;
        --warn: #8b2e2e;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: 'Sarabun', Arial, sans-serif;
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        background-attachment: fixed;
        color: var(--text-main);
      }
      .shell {
        width: min(1080px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.4rem 0 3rem;
      }
      .topbar, .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        position: relative;
        overflow: hidden;
      }
      .topbar::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.38), transparent 32%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 42%);
        pointer-events: none;
      }
      .topbar > * {
        position: relative;
        z-index: 1;
      }
      .hero-title {
        margin: 0;
        color: var(--primary-strong);
        font-size: clamp(1.45rem, 2.6vw, 2rem);
      }
      .hero-subtitle {
        margin: 0.28rem 0 0;
        color: var(--text-sub);
        line-height: 1.6;
      }
      .topbar-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.45rem 0.78rem;
        border-radius: 999px;
        background: var(--primary-soft);
        color: var(--primary-strong);
        font-weight: 700;
        font-size: 0.82rem;
        margin-bottom: 0.75rem;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }
      .card {
        padding: 1.25rem;
        margin-bottom: 1rem;
      }
      .metric-card {
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 252, 0.92));
      }
      .metric-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 4px;
        background: linear-gradient(90deg, #0f5f8f, transparent 85%);
      }
      .metric-card.payment::before {
        background: linear-gradient(90deg, #8c5d1f, transparent 85%);
      }
      .metric-card.feedback::before {
        background: linear-gradient(90deg, #0f695f, transparent 85%);
      }
      .metric-label {
        margin: 0;
        color: var(--text-sub);
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.35rem 0 0;
        color: var(--primary-strong);
      }
      .logout-btn {
        border: none;
        border-radius: 14px;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        padding: 0.85rem 1.05rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      ul {
        padding-left: 1.2rem;
      }
      a {
        color: var(--primary-strong);
      }
      h2 {
        color: var(--primary-strong);
      }
      p {
        color: var(--text-sub);
      }
      .alert {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        margin-bottom: 1rem;
        border: 1px solid transparent;
        box-shadow: 0 8px 20px rgba(18, 52, 77, 0.08);
      }
      .alert.success {
        background: #e8f7ee;
        border-color: #b8e3c8;
        color: #1f6a3a;
      }
      .alert.error {
        background: #fce9e7;
        border-color: #f1b8b1;
        color: #9b2c22;
      }
      .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.9rem;
      }
      .field label {
        display: block;
        font-weight: 700;
        margin-bottom: 0.35rem;
      }
      .field input,
      .field select,
      .field textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid #c9d8e4;
        border-radius: 14px;
        padding: 0.8rem 0.9rem;
        font: inherit;
        background: var(--surface-strong);
        color: var(--text-main);
      }
      .field input[type="checkbox"] {
        width: auto;
        padding: 0;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }
      .field textarea {
        min-height: 130px;
        resize: vertical;
      }
      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        outline: none;
        border-color: #6aa6cc;
        box-shadow: 0 0 0 0.18rem rgba(47, 127, 184, 0.14);
      }
      .primary-btn {
        border: none;
        border-radius: 14px;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        padding: 0.9rem 1.1rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .knowledge-list li {
        margin-bottom: 0.8rem;
        min-width: 0;
      }
      .knowledge-list strong,
      .soft-list li,
      .knowledge-meta,
      .suggestion-meta,
      .editor-summary,
      .section-note,
      .subtle-text,
      .quick-links a {
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .list-item-title {
        display: block;
        color: var(--primary-strong);
        line-height: 1.5;
      }
      .list-item-body {
        margin-top: 0.6rem;
        color: var(--text-main);
        white-space: pre-line;
        line-height: 1.7;
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .knowledge-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 0.85rem;
        gap: 0.65rem;
        flex-wrap: wrap;
      }
      .danger-btn {
        border: none;
        border-radius: 12px;
        background: linear-gradient(145deg, #b63d2f, #922f24);
        color: #fff;
        padding: 0.7rem 0.9rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(146, 47, 36, 0.18);
      }
      .secondary-btn {
        border: none;
        border-radius: 12px;
        background: linear-gradient(145deg, #7c8c98, #607180);
        color: #fff;
        padding: 0.7rem 0.9rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(96, 113, 128, 0.16);
      }
      .suggestion-meta {
        margin-top: 0.45rem;
        color: var(--text-sub);
        font-size: 0.92rem;
        line-height: 1.6;
      }
      .suggestion-editor {
        margin-top: 0.9rem;
        padding: 0.95rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(241, 246, 251, 0.82);
      }
      details.suggestion-editor {
        padding: 0.85rem 0.95rem;
      }
      .editor-summary {
        cursor: pointer;
        font-weight: 700;
        color: var(--primary-strong);
        list-style: none;
        display: flex;
        align-items: center;
        gap: 0.55rem;
      }
      .editor-summary::-webkit-details-marker {
        display: none;
      }
      .editor-summary::before {
        content: "+";
        width: 1.3rem;
        height: 1.3rem;
        border-radius: 999px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--primary-soft);
        color: var(--primary-strong);
        font-weight: 700;
        flex: 0 0 auto;
      }
      details[open] > .editor-summary::before {
        content: "-";
      }
      .editor-body {
        margin-top: 0.9rem;
        min-width: 0;
      }
      .knowledge-meta {
        margin-top: 0.45rem;
        color: var(--text-sub);
        font-size: 0.92rem;
        line-height: 1.6;
      }
      .suggestion-editor .field textarea {
        min-height: 160px;
      }
      .suggestion-actions {
        display: flex;
        gap: 0.65rem;
        flex-wrap: wrap;
        margin-top: 0.9rem;
      }
      .suggestion-actions form {
        margin: 0;
      }
      .soft-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.8rem;
      }
      .soft-list li {
        padding: 0.95rem 1rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.76);
        min-width: 0;
      }
      .quick-links {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 0.75rem;
        padding: 0;
        margin: 0;
        list-style: none;
      }
      .quick-links a {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
        padding: 0.7rem 0.95rem;
        border-radius: 18px;
        background: var(--primary-soft);
        color: var(--primary-strong);
        border: 1px solid rgba(21, 84, 122, 0.14);
        font-weight: 700;
        min-height: 100%;
      }
      .section-note {
        margin-top: -0.15rem;
        margin-bottom: 1rem;
      }
      .status-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        align-items: center;
        margin-bottom: 0.9rem;
      }
      .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.48rem 0.82rem;
        border-radius: 999px;
        font-size: 0.84rem;
        font-weight: 700;
      }
      .status-pill.enabled {
        background: #e8f7ee;
        color: #1f6a3a;
      }
      .status-pill.disabled {
        background: #fff1dd;
        color: #8c5c17;
      }
      .status-pill.override {
        background: #fce9e7;
        color: #9b2c22;
      }
      .status-pill.info {
        background: #e8f1fb;
        color: #24557e;
      }
      .system-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .subtle-text {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.7;
      }
      .pagination-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
      }
      .pagination-summary {
        color: var(--text-sub);
        font-size: 0.92rem;
      }
      .pagination-links {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        flex-wrap: wrap;
      }
      .pagination-link,
      .pagination-current,
      .pagination-ellipsis {
        min-width: 2.4rem;
        padding: 0.58rem 0.82rem;
        border-radius: 12px;
        text-align: center;
        font-weight: 700;
      }
      .pagination-link {
        background: var(--surface-soft);
        color: var(--primary-strong);
        text-decoration: none;
        border: 1px solid var(--border);
      }
      .pagination-current {
        background: var(--primary);
        color: #fff;
        border: 1px solid var(--primary);
      }
      .pagination-ellipsis {
        color: var(--text-sub);
      }
      .section-toolbar {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
      }
      .section-toolbar form {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        flex-wrap: wrap;
      }
      .section-toolbar select {
        border: 1px solid #c9d8e4;
        border-radius: 12px;
        padding: 0.62rem 0.82rem;
        font: inherit;
        background: var(--surface-strong);
        color: var(--text-main);
      }
      .section-toolbar button {
        border: none;
        border-radius: 12px;
        padding: 0.66rem 0.9rem;
        font: inherit;
        font-weight: 700;
        color: #fff;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        cursor: pointer;
      }
      @media (max-width: 760px) {
        .shell {
          width: min(100%, calc(100% - 1rem));
          padding: 0.75rem 0 1.4rem;
        }
        .card,
        .topbar {
          padding: 1rem;
          flex-direction: column;
          align-items: stretch;
        }
        .topbar-badge {
          margin-bottom: 0.55rem;
        }
        .hero-subtitle {
          line-height: 1.5;
        }
        .grid,
        .form-grid,
        .quick-links {
          grid-template-columns: 1fr;
        }
        .field input,
        .field select,
        .field textarea,
        .logout-btn,
        .primary-btn,
        .secondary-btn,
        .danger-btn {
          font-size: 16px;
        }
        .status-row,
        .system-actions,
        .suggestion-actions,
        .pagination-bar {
          flex-direction: column;
          align-items: stretch;
        }
        .status-pill,
        .quick-links a {
          width: 100%;
          justify-content: center;
        }
        .knowledge-actions {
          justify-content: stretch;
        }
        .knowledge-actions form,
        .suggestion-actions form,
        .suggestion-actions button {
          width: 100%;
        }
        .logout-btn,
        .primary-btn,
        .secondary-btn,
        .danger-btn {
          width: 100%;
        }
        .pagination-links {
          justify-content: center;
        }
        .section-toolbar {
          justify-content: stretch;
        }
        .section-toolbar form {
          width: 100%;
        }
        .section-toolbar select,
        .section-toolbar button {
          width: 100%;
        }
        .list-item-title {
          font-size: 0.96rem;
        }
        .list-item-body,
        .knowledge-meta,
        .suggestion-meta,
        .editor-summary,
        .section-note,
        .subtle-text {
          font-size: 0.9rem;
        }
      }

      @media (max-width: 420px) {
        .hero-title {
          font-size: 1.35rem;
        }
        .topbar-badge {
          width: fit-content;
          max-width: 100%;
        }
        .metric {
          font-size: 1.7rem;
        }
        .soft-list li,
        .suggestion-editor,
        details.suggestion-editor {
          padding-left: 0.85rem;
          padding-right: 0.85rem;
        }
        .list-item-title {
          font-size: 0.92rem;
        }
        .list-item-body,
        .knowledge-meta,
        .suggestion-meta,
        .editor-summary {
          font-size: 0.86rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% 
        const dashboardQuery = {
          sqPage: knowledgeData.suggestedQuestionsPagination?.page || dashboardPages?.sqPage || 1,
          knowledgePage: knowledgeData.knowledgePagination?.page || dashboardPages?.knowledgePage || 1,
          pendingPage: knowledgeData.pendingSuggestionsPagination?.page || dashboardPages?.pendingPage || 1,
          sqPerPage: knowledgeData.suggestedQuestionsPagination?.pageSize || dashboardPages?.sqPerPage || 8,
          knowledgePerPage: knowledgeData.knowledgePagination?.pageSize || dashboardPages?.knowledgePerPage || 8,
          pendingPerPage: knowledgeData.pendingSuggestionsPagination?.pageSize || dashboardPages?.pendingPerPage || 8,
        };
        const dashboardBaseQueryString = new URLSearchParams(dashboardQuery).toString();
        const dashboardBasePath = `/admin${dashboardBaseQueryString ? `?${dashboardBaseQueryString}` : ''}`;
        const suggestedManagementReturnTo = `${dashboardBasePath}#frequent-questions-management`;
        const suggestedLibraryReturnTo = `${dashboardBasePath}#frequent-questions-library`;
        const knowledgeManagementReturnTo = `${dashboardBasePath}#knowledge-management`;
        const knowledgeLibraryReturnTo = `${dashboardBasePath}#knowledge-library`;
        const knowledgeSuggestionsReturnTo = `${dashboardBasePath}#knowledge-suggestions`;
      %>
      <% if (successMessage) { %>
        <div class="alert success"><%= successMessage %></div>
      <% } %>
      <% if (errorMessage) { %>
        <div class="alert error"><%= errorMessage %></div>
      <% } %>

      <section class="topbar">
        <div>
          <div class="topbar-badge">แดชบอร์ดผู้ดูแล</div>
          <h1 class="hero-title"><%= user.name %></h1>
          <p class="hero-subtitle"><%= user.position %> | <%= user.username %></p>
        </div>
        <form action="/admin/logout" method="post">
          <button class="logout-btn" type="submit">ออกจากระบบ</button>
        </form>
      </section>

      <section class="grid">
        <article class="card metric-card">
          <p class="metric-label">ไฟล์ที่อัปโหลดทั้งหมด</p>
          <p class="metric"><%= uploadData.uploadedPdfCount %></p>
        </article>
        <article class="card metric-card">
          <p class="metric-label">ชิ้นข้อมูลทั้งหมด</p>
          <p class="metric"><%= uploadData.uploadedChunkCount %></p>
        </article>
        <article class="card metric-card feedback">
          <p class="metric-label">ข้อเสนอแนะทั้งหมด</p>
          <p class="metric"><%= feedbackData.feedbackCount %></p>
        </article>
        <article class="card metric-card payment">
          <p class="metric-label">คำขอชำระเงินที่รอพิจารณา</p>
          <p class="metric"><%= paymentRequestData.pendingCount %></p>
          <p style="margin: 0.45rem 0 0;">
            <a href="/admin/payment-requests">เปิดหน้าตรวจคำขออัปเกรดแพ็กเกจ</a>
          </p>
        </article>
      </section>

      <section class="card">
        <h2>โหมดสรุปคำตอบด้วย AI</h2>
        <p class="section-note">
          เปิดหรือปิดการใช้ AI สำหรับสรุปคำตอบได้จากหน้านี้ เมื่อปิด ระบบจะยังค้นข้อมูลจากฐานข้อมูลและเอกสารในระบบตามปกติ แต่จะไม่เรียก AI และจะไม่ใช้อินเทอร์เน็ต fallback ค่าจะถูกเก็บไว้ในฐานข้อมูลของ environment นั้น หาก dev และ production ใช้คนละฐานข้อมูล จะตั้งค่าแยกกัน
        </p>
        <div class="status-row">
          <span class="status-pill <%= aiSettings.effectiveEnabled ? 'enabled' : 'disabled' %>">
            <%= aiSettings.effectiveEnabled ? 'AI สรุปคำตอบเปิดใช้งานอยู่' : 'โหมดค้นฐานข้อมูลเท่านั้น' %>
          </span>
          <span class="status-pill <%= aiSettings.configuredEnabled ? 'enabled' : 'disabled' %>">
            ตั้งค่าจาก Admin: <%= aiSettings.configuredEnabled ? 'เปิด' : 'ปิด' %>
          </span>
          <span class="status-pill info">ค้นฐานข้อมูลยังใช้งานได้</span>
          <% if (aiSettings.envMockAi) { %>
            <span class="status-pill override">Env override: USE_MOCK_AI=true</span>
          <% } %>
        </div>
        <p class="subtle-text">
          <% if (aiSettings.updatedAt) { %>
            อัปเดตล่าสุดโดย <strong><%= aiSettings.updatedBy || "admin" %></strong> เมื่อ <strong><%= aiSettings.updatedAt %></strong>
          <% } else { %>
            ยังไม่เคยมีการเปลี่ยนสถานะจากหน้า Admin ระบบจะถือว่า AI เปิดใช้งานตามค่าเริ่มต้น
          <% } %>
        </p>
        <% if (aiSettings.envMockAi) { %>
          <p class="subtle-text" style="margin-top: 0.55rem;">
            ขณะนี้ env ตั้งค่าให้ใช้ mock response อยู่ ดังนั้นแม้เปิด AI จาก Admin แล้ว ระบบจะยังตอบแบบ mock และจะยังไม่ค้นข้อมูลจริงหรือเรียก AI จนกว่าจะปิด <code>USE_MOCK_AI</code>
          </p>
        <% } %>
        <div class="system-actions" style="margin-top: 1rem;">
          <form action="/admin/settings/ai" method="post">
            <input type="hidden" name="enabled" value="<%= aiSettings.configuredEnabled ? 'false' : 'true' %>" />
            <button class="<%= aiSettings.configuredEnabled ? 'secondary-btn' : 'primary-btn' %>" type="submit">
              <%= aiSettings.configuredEnabled ? 'ปิด AI สรุปคำตอบชั่วคราว' : 'เปิด AI สรุปคำตอบกลับมาใช้งาน' %>
            </button>
          </form>
        </div>
      </section>

      <section class="card">
        <h2>อัปโหลดล่าสุด</h2>
        <p class="section-note">เอกสารล่าสุดที่ถูกนำเข้าเพื่อใช้เป็นฐานความรู้ของแชตบอท</p>
        <ul class="soft-list">
          <% if (uploadData.uploadedFiles.length === 0) { %>
            <li>ยังไม่มีรายการอัปโหลดใน session นี้</li>
          <% } %>
          <% uploadData.uploadedFiles.forEach((file) => { %>
            <li>
              <%= file.originalname %>
              <% if (file.documentNumber) { %> - เลขที่ <%= file.documentNumber %><% } %>
              <% if (file.documentDateText) { %> - ลงวันที่ <%= file.documentDateText %><% } %>
              - <%= file.insertedChunkCount || 0 %> ชิ้นข้อมูล
            </li>
          <% }) %>
        </ul>
      </section>

      <section class="card">
        <h2>ลิงก์ด่วน</h2>
        <ul class="quick-links">
          <li><a href="/law-chatbot">หน้าแชตสาธารณะ</a></li>
          <li><a href="/admin/users">จัดการแพ็กเกจผู้ใช้งาน</a></li>
          <li><a href="/admin/guest-usage">ตรวจ guest usage และการกันรีเซ็ตสิทธิ์</a></li>
          <li><a href="/law-chatbot/upload">หน้าจัดการอัปโหลด</a></li>
          <li><a href="/law-chatbot/feedback">หน้าดูข้อเสนอแนะ</a></li>
          <li><a href="/admin/payment-requests">ตรวจคำขออัปเกรดแพ็กเกจ <% if (paymentRequestData.pendingCount > 0) { %>(<%= paymentRequestData.pendingCount %> รออนุมัติ)<% } %></a></li>
          <li><a href="#frequent-questions-management">จัดการคำถามแนะนำ / คำถามที่พบบ่อย</a></li>
          <li><a href="#knowledge-management">จัดการความรู้แชตบอท</a></li>
          <li><a href="#knowledge-suggestions">ตรวจข้อเสนอจากผู้ใช้งาน</a></li>
        </ul>
      </section>

      <section class="card" id="frequent-questions-management">
        <h2>จัดการคำถามแนะนำ / คำถามที่พบบ่อย</h2>
        <p class="section-note">
          คำถามชุดนี้จะถูกใช้แสดงในกล่องคำถามแนะนำเหนือช่องพิมพ์ และถ้าผู้ใช้ถามตรงกับคำถามที่กำหนดไว้ ระบบจะใช้คำตอบที่บันทึกไว้ล่วงหน้าได้ทันที
        </p>
        <p>
          ทั้งหมด <strong><%= knowledgeData.suggestedQuestionCount %></strong> รายการ
          <% if (Number(knowledgeData.activeSuggestedQuestionCount || 0) > 0) { %>
            | ใช้งานอยู่ <strong><%= knowledgeData.activeSuggestedQuestionCount %></strong> รายการ
          <% } %>
        </p>
        <form action="/admin/suggested-questions" method="post">
          <input type="hidden" name="returnTo" value="<%= suggestedManagementReturnTo %>" />
          <div class="form-grid">
            <div class="field">
              <label for="suggestedQuestionTarget">ประเภทข้อมูล</label>
              <select id="suggestedQuestionTarget" name="target" required>
                <% (knowledgeData.suggestedQuestionTargets || []).forEach((target) => { %>
                  <option value="<%= target.value %>"><%= target.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="suggestedQuestionDisplayOrder">ลำดับการแสดง</label>
              <input id="suggestedQuestionDisplayOrder" name="displayOrder" type="number" min="0" step="1" value="0" />
            </div>
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="suggestedQuestionText">คำถามแนะนำ</label>
            <input
              id="suggestedQuestionText"
              name="questionText"
              type="text"
              placeholder="เช่น มาตรา 12 ของ พ.ร.บ.สหกรณ์ คืออะไร"
              required
            />
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="suggestedQuestionAnswer">คำตอบที่บันทึกไว้</label>
            <textarea
              id="suggestedQuestionAnswer"
              name="answerText"
              placeholder="พิมพ์คำตอบที่ต้องการให้ระบบใช้ทันทีเมื่อผู้ใช้ถามตรงกับคำถามนี้"
              required
            ></textarea>
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label style="display: inline-flex; align-items: center; gap: 0.45rem;">
              <input type="hidden" name="isActive" value="0" />
              <input type="checkbox" name="isActive" value="1" checked />
              <span>เปิดใช้งานคำถามนี้ทันที</span>
            </label>
          </div>
          <div style="margin-top: 1rem;">
            <button class="primary-btn" type="submit">บันทึกคำถามแนะนำ</button>
          </div>
        </form>
      </section>

      <section class="card" id="frequent-questions-library">
        <h2>รายการคำถามแนะนำที่ตั้งค่าไว้</h2>
        <div class="section-toolbar">
          <form action="/admin" method="get">
            <input type="hidden" name="knowledgePage" value="<%= dashboardQuery.knowledgePage %>" />
            <input type="hidden" name="pendingPage" value="<%= dashboardQuery.pendingPage %>" />
            <input type="hidden" name="knowledgePerPage" value="<%= dashboardQuery.knowledgePerPage %>" />
            <input type="hidden" name="pendingPerPage" value="<%= dashboardQuery.pendingPerPage %>" />
            <input type="hidden" name="sqPage" value="1" />
            <label for="sqPerPage" class="subtle-text">จำนวนรายการต่อหน้า</label>
            <select id="sqPerPage" name="sqPerPage" aria-label="จำนวนรายการคำถามแนะนำต่อหน้า">
              <% [8, 16, 24].forEach((size) => { %>
                <option value="<%= size %>" <%= Number(dashboardQuery.sqPerPage || 8) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
              <% }) %>
            </select>
            <button type="submit" formaction="/admin#frequent-questions-library">แสดงผล</button>
          </form>
        </div>
        <ul class="knowledge-list soft-list">
          <% if (!knowledgeData.suggestedQuestions || knowledgeData.suggestedQuestions.length === 0) { %>
            <li>ยังไม่มีคำถามแนะนำที่ผู้ดูแลสร้างไว้</li>
          <% } %>
          <% (knowledgeData.suggestedQuestions || []).forEach((item) => { %>
            <li>
              <strong class="list-item-title"><%= item.questionText %></strong>
              <div class="knowledge-meta">
                ใช้กับ:
                <%= item.target === 'group' ? 'กลุ่มเกษตรกร' : item.target === 'coop' ? 'สหกรณ์' : 'ทุกประเภท' %>
                | สถานะ:
                <%= item.isActive ? 'เปิดใช้งาน' : 'ปิดใช้งาน' %>
                | ลำดับ: <%= Number(item.displayOrder || 0) %>
                <% if (item.updatedAt) { %> | แก้ไขล่าสุด: <%= item.updatedAt %><% } %>
              </div>
              <div class="list-item-body"><%= item.answerText %></div>
              <details class="suggestion-editor">
                <summary class="editor-summary">แก้ไขคำถามแนะนำนี้</summary>
                <div class="editor-body">
                  <form action="/admin/suggested-questions/update" method="post">
                    <input type="hidden" name="id" value="<%= item.id %>" />
                    <input type="hidden" name="returnTo" value="<%= suggestedLibraryReturnTo %>" />
                    <div class="form-grid">
                      <div class="field">
                        <label for="suggested-target-<%= item.id %>">ประเภทข้อมูล</label>
                        <select id="suggested-target-<%= item.id %>" name="target" required>
                          <% (knowledgeData.suggestedQuestionTargets || []).forEach((target) => { %>
                            <option value="<%= target.value %>" <%= item.target === target.value ? 'selected' : '' %>><%= target.label %></option>
                          <% }) %>
                        </select>
                      </div>
                      <div class="field">
                        <label for="suggested-display-order-<%= item.id %>">ลำดับการแสดง</label>
                        <input
                          id="suggested-display-order-<%= item.id %>"
                          name="displayOrder"
                          type="number"
                          min="0"
                          step="1"
                          value="<%= Number(item.displayOrder || 0) %>"
                        />
                      </div>
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="suggested-question-text-<%= item.id %>">คำถามแนะนำ</label>
                      <input id="suggested-question-text-<%= item.id %>" name="questionText" type="text" value="<%= item.questionText %>" required />
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="suggested-answer-text-<%= item.id %>">คำตอบที่บันทึกไว้</label>
                      <textarea id="suggested-answer-text-<%= item.id %>" name="answerText" required><%= item.answerText %></textarea>
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label style="display: inline-flex; align-items: center; gap: 0.45rem;">
                        <input type="hidden" name="isActive" value="0" />
                        <input type="checkbox" name="isActive" value="1" <%= item.isActive ? 'checked' : '' %> />
                        <span>เปิดใช้งานคำถามนี้</span>
                      </label>
                    </div>
                    <div class="suggestion-actions">
                      <button class="secondary-btn" type="submit">บันทึกการแก้ไข</button>
                    </div>
                  </form>
                </div>
              </details>
              <div class="knowledge-actions">
                <form action="/admin/suggested-questions/delete" method="post" onsubmit="return confirm('ยืนยันการลบคำถามแนะนำนี้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= suggestedLibraryReturnTo %>" />
                  <button class="danger-btn" type="submit">ลบรายการนี้</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
        <%- include("partials/pagination", { pagination: knowledgeData.suggestedQuestionsPagination, basePath: "/admin", query: dashboardQuery, pageKey: "sqPage", anchor: "frequent-questions-library", itemLabel: "รายการคำถามแนะนำ" }) %>
      </section>

      <section class="card" id="knowledge-management">
        <h2>เพิ่มหรือแก้ไขความรู้สำหรับตอบคำถาม</h2>
        <p class="section-note">
          ใช้หน้านี้เพื่อเพิ่มข้อมูลที่ถูกต้องลงในฐานข้อมูล เมื่อ AI ตอบไม่ตรงข้อเท็จจริง ระบบจะนำข้อมูลชุดนี้ไปช่วยตอบในรอบถัดไป
        </p>
        <form action="/admin/knowledge" method="post">
          <input type="hidden" name="returnTo" value="<%= knowledgeManagementReturnTo %>" />
          <div class="form-grid">
            <div class="field">
              <label for="target">ประเภทข้อมูล</label>
              <select id="target" name="target" required>
                <% knowledgeData.targets.forEach((target) => { %>
                  <option value="<%= target.value %>"><%= target.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="lawNumber">เลขอ้างอิง / หมวด</label>
              <input id="lawNumber" name="lawNumber" type="text" placeholder="เช่น หมวดสมาชิก หรือ ข้อ 12" />
            </div>
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="title">หัวข้อ</label>
            <input id="title" name="title" type="text" placeholder="เช่น การรับสมาชิกสหกรณ์" required />
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="content">รายละเอียดความรู้ / คำตอบที่ถูกต้อง</label>
            <textarea id="content" name="content" placeholder="พิมพ์ข้อมูลที่ต้องการให้บอทใช้เป็นหลักเมื่อมีคนถามเรื่องนี้" required></textarea>
          </div>
          <div class="field" style="margin-top: 0.9rem;">
            <label for="sourceNote">หมายเหตุ / แหล่งที่มา</label>
            <input id="sourceNote" name="sourceNote" type="text" placeholder="เช่น มาตรา 15, เอกสารประชุม, หรือคำชี้แจงจากผู้เชี่ยวชาญ" />
          </div>
          <div style="margin-top: 1rem;">
            <button class="primary-btn" type="submit">บันทึกความรู้ลงฐานข้อมูล</button>
          </div>
        </form>
      </section>

      <section class="card" id="knowledge-library">
        <h2>ความรู้ที่บันทึกล่าสุด</h2>
        <p>ทั้งหมด <strong><%= knowledgeData.knowledgeCount %></strong> รายการ</p>
        <div class="section-toolbar">
          <form action="/admin" method="get">
            <input type="hidden" name="sqPage" value="<%= dashboardQuery.sqPage %>" />
            <input type="hidden" name="pendingPage" value="<%= dashboardQuery.pendingPage %>" />
            <input type="hidden" name="sqPerPage" value="<%= dashboardQuery.sqPerPage %>" />
            <input type="hidden" name="pendingPerPage" value="<%= dashboardQuery.pendingPerPage %>" />
            <input type="hidden" name="knowledgePage" value="1" />
            <label for="knowledgePerPage" class="subtle-text">จำนวนรายการต่อหน้า</label>
            <select id="knowledgePerPage" name="knowledgePerPage" aria-label="จำนวนรายการฐานความรู้ต่อหน้า">
              <% [8, 16, 24].forEach((size) => { %>
                <option value="<%= size %>" <%= Number(dashboardQuery.knowledgePerPage || 8) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
              <% }) %>
            </select>
            <button type="submit" formaction="/admin#knowledge-library">แสดงผล</button>
          </form>
        </div>
        <ul class="knowledge-list soft-list">
          <% if (knowledgeData.recentKnowledge.length === 0) { %>
            <li>ยังไม่มีความรู้ที่เพิ่มเข้าฐานข้อมูล</li>
          <% } %>
          <% knowledgeData.recentKnowledge.forEach((item) => { %>
            <li>
              <strong class="list-item-title"><%= item.title %></strong>
              <% if (item.lawNumber) { %> - <%= item.lawNumber %><% } %>
              <div class="knowledge-meta">
                ใช้กับ: <%= item.target === 'group' ? 'กลุ่มเกษตรกร' : 'สหกรณ์' %>
                <% if (item.sourceNote) { %> | แหล่งที่มา: <%= item.sourceNote %><% } %>
                <% if (item.updatedAt) { %> | แก้ไขล่าสุด: <%= item.updatedAt %><% } %>
              </div>
              <div class="list-item-body"><%= item.content %></div>
              <details class="suggestion-editor">
                <summary class="editor-summary">แก้ไขข้อมูลฐานความรู้นี้</summary>
                <div class="editor-body">
                  <form action="/admin/knowledge/update" method="post">
                    <input type="hidden" name="id" value="<%= item.id %>" />
                    <input type="hidden" name="returnTo" value="<%= knowledgeLibraryReturnTo %>" />
                    <div class="form-grid">
                      <div class="field">
                        <label for="knowledge-target-<%= item.id %>">ประเภทข้อมูล</label>
                        <select id="knowledge-target-<%= item.id %>" name="target" required>
                          <option value="coop" <%= item.target === 'coop' ? 'selected' : '' %>>สหกรณ์</option>
                          <option value="group" <%= item.target === 'group' ? 'selected' : '' %>>กลุ่มเกษตรกร</option>
                        </select>
                      </div>
                      <div class="field">
                        <label for="knowledge-law-number-<%= item.id %>">เลขอ้างอิง / หมวด</label>
                        <input
                          id="knowledge-law-number-<%= item.id %>"
                          name="lawNumber"
                          type="text"
                          value="<%= item.lawNumber || '' %>"
                          placeholder="เช่น มาตรา 15 หรือ หมวดสมาชิก"
                        />
                      </div>
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="knowledge-title-<%= item.id %>">หัวข้อ</label>
                      <input id="knowledge-title-<%= item.id %>" name="title" type="text" value="<%= item.title %>" required />
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="knowledge-content-<%= item.id %>">รายละเอียดความรู้ / คำตอบที่ถูกต้อง</label>
                      <textarea id="knowledge-content-<%= item.id %>" name="content" required><%= item.content %></textarea>
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="knowledge-source-note-<%= item.id %>">หมายเหตุ / แหล่งที่มา</label>
                      <input
                        id="knowledge-source-note-<%= item.id %>"
                        name="sourceNote"
                        type="text"
                        value="<%= item.sourceNote || '' %>"
                        placeholder="เช่น มาตรา 15, เอกสารประชุม, หรือคำชี้แจงจากผู้เชี่ยวชาญ"
                      />
                    </div>
                    <div class="suggestion-actions">
                      <button class="secondary-btn" type="submit">บันทึกการแก้ไข</button>
                    </div>
                  </form>
                </div>
              </details>
              <div class="knowledge-actions">
                <form action="/admin/knowledge/delete" method="post" onsubmit="return confirm('ยืนยันการลบข้อมูลฐานความรู้นี้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= knowledgeLibraryReturnTo %>" />
                  <button class="danger-btn" type="submit">ลบรายการนี้</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
        <%- include("partials/pagination", { pagination: knowledgeData.knowledgePagination, basePath: "/admin", query: dashboardQuery, pageKey: "knowledgePage", anchor: "knowledge-library", itemLabel: "รายการฐานความรู้" }) %>
      </section>

      <section class="card" id="knowledge-suggestions">
        <h2>ข้อเสนอคำตอบจากผู้ใช้งาน</h2>
        <p>รอตรวจสอบ <strong><%= knowledgeData.pendingSuggestionCount %></strong> รายการ</p>
        <div class="section-toolbar">
          <form action="/admin" method="get">
            <input type="hidden" name="sqPage" value="<%= dashboardQuery.sqPage %>" />
            <input type="hidden" name="knowledgePage" value="<%= dashboardQuery.knowledgePage %>" />
            <input type="hidden" name="sqPerPage" value="<%= dashboardQuery.sqPerPage %>" />
            <input type="hidden" name="knowledgePerPage" value="<%= dashboardQuery.knowledgePerPage %>" />
            <input type="hidden" name="pendingPage" value="1" />
            <label for="pendingPerPage" class="subtle-text">จำนวนรายการต่อหน้า</label>
            <select id="pendingPerPage" name="pendingPerPage" aria-label="จำนวนข้อเสนอที่รอตรวจสอบต่อหน้า">
              <% [8, 16, 24].forEach((size) => { %>
                <option value="<%= size %>" <%= Number(dashboardQuery.pendingPerPage || 8) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
              <% }) %>
            </select>
            <button type="submit" formaction="/admin#knowledge-suggestions">แสดงผล</button>
          </form>
        </div>
        <ul class="knowledge-list soft-list">
          <% if (knowledgeData.pendingSuggestions.length === 0) { %>
            <li>ยังไม่มีข้อเสนอคำตอบที่รออนุมัติ</li>
          <% } %>
          <% knowledgeData.pendingSuggestions.forEach((item) => { %>
            <li>
              <strong class="list-item-title"><%= item.title %></strong>
              <div class="suggestion-meta">
                ใช้กับ: <%= item.target === 'group' ? 'กลุ่มเกษตรกร' : 'สหกรณ์' %>
                <% if (item.sourceType) { %> | ช่องทาง: <%= item.sourceType === 'voice' ? 'เสียง' : 'ข้อความ' %><% } %>
                <% if (item.createdAt) { %> | ส่งเมื่อ: <%= item.createdAt %><% } %>
              </div>
              <div class="list-item-body"><%= item.content %></div>
              <details class="suggestion-editor" open>
                <summary class="editor-summary">แก้ไขข้อเสนอก่อนอนุมัติ</summary>
                <div class="editor-body">
                  <form action="/admin/knowledge-suggestions/update" method="post">
                    <input type="hidden" name="id" value="<%= item.id %>" />
                    <input type="hidden" name="returnTo" value="<%= knowledgeSuggestionsReturnTo %>" />
                    <div class="form-grid">
                      <div class="field">
                        <label for="suggestion-target-<%= item.id %>">ประเภทข้อมูล</label>
                        <select id="suggestion-target-<%= item.id %>" name="target" required>
                          <option value="coop" <%= item.target === 'coop' ? 'selected' : '' %>>สหกรณ์</option>
                          <option value="group" <%= item.target === 'group' ? 'selected' : '' %>>กลุ่มเกษตรกร</option>
                        </select>
                      </div>
                      <div class="field">
                        <label for="suggestion-title-<%= item.id %>">หัวข้อ</label>
                        <input id="suggestion-title-<%= item.id %>" name="title" type="text" value="<%= item.title %>" required />
                      </div>
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="suggestion-content-<%= item.id %>">รายละเอียดคำตอบ</label>
                      <textarea id="suggestion-content-<%= item.id %>" name="content" required><%= item.content %></textarea>
                    </div>
                    <div class="field" style="margin-top: 0.9rem;">
                      <label for="suggestion-review-note-<%= item.id %>">หมายเหตุการตรวจทาน</label>
                      <input
                        id="suggestion-review-note-<%= item.id %>"
                        name="reviewNote"
                        type="text"
                        value="<%= item.reviewNote || '' %>"
                        placeholder="เช่น ปรับถ้อยคำก่อนนำเข้าฐานความรู้"
                      />
                    </div>
                    <div class="suggestion-actions">
                      <button class="secondary-btn" type="submit">บันทึกการแก้ไขก่อน</button>
                    </div>
                  </form>
                </div>
              </details>
              <div class="knowledge-actions">
                <form action="/admin/knowledge-suggestions/approve" method="post" onsubmit="return confirm('ยืนยันการอนุมัติและนำเข้าฐานความรู้จากข้อมูลฉบับล่าสุดใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= knowledgeSuggestionsReturnTo %>" />
                  <button class="primary-btn" type="submit">อนุมัติและนำเข้าจากฉบับล่าสุด</button>
                </form>
                <form action="/admin/knowledge-suggestions/reject" method="post" onsubmit="return confirm('ยืนยันการปฏิเสธข้อเสนอนี้ใช่หรือไม่');">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="<%= knowledgeSuggestionsReturnTo %>" />
                  <button class="secondary-btn" type="submit">ปฏิเสธ</button>
                </form>
              </div>
            </li>
          <% }) %>
        </ul>
        <%- include("partials/pagination", { pagination: knowledgeData.pendingSuggestionsPagination, basePath: "/admin", query: dashboardQuery, pageKey: "pendingPage", anchor: "knowledge-suggestions", itemLabel: "ข้อเสนอที่รอตรวจสอบ" }) %>
      </section>
    </div>
  </body>
</html>
