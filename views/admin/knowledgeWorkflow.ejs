<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-strong: #ffffff;
        --primary: #15547a;
        --primary-strong: #0f4667;
        --text-main: #1f2a37;
        --text-sub: #5d6a79;
        --border: #d8e2ea;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Sarabun", Arial, sans-serif;
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        background-attachment: fixed;
        color: var(--text-main);
      }
      .shell {
        width: min(1180px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.4rem 0 3rem;
      }
      .card,
      .topbar {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      .card {
        padding: 1.25rem;
        margin-bottom: 1rem;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        position: relative;
        overflow: hidden;
      }
      .topbar::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.38), transparent 32%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 42%);
        pointer-events: none;
      }
      .topbar > * {
        position: relative;
        z-index: 1;
      }
      .hero-title {
        margin: 0;
        color: var(--primary-strong);
        font-size: clamp(1.45rem, 2.6vw, 2rem);
      }
      .hero-subtitle {
        margin: 0.28rem 0 0;
        color: var(--text-sub);
        line-height: 1.6;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
      }
      .metric-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 252, 0.92));
      }
      .metric-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 4px;
        background: linear-gradient(90deg, #0f5f8f, transparent 85%);
      }
      .metric-card.source::before {
        background: linear-gradient(90deg, #1c779b, transparent 85%);
      }
      .metric-card.draft::before {
        background: linear-gradient(90deg, #8c5d1f, transparent 85%);
      }
      .metric-card.approved::before {
        background: linear-gradient(90deg, #1d7a52, transparent 85%);
      }
      .metric-card.rejected::before {
        background: linear-gradient(90deg, #922f24, transparent 85%);
      }
      .metric-label {
        margin: 0;
        color: var(--text-sub);
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.35rem 0 0;
        color: var(--primary-strong);
      }
      .alert {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        margin-bottom: 1rem;
        border: 1px solid transparent;
        box-shadow: 0 8px 20px rgba(18, 52, 77, 0.08);
      }
      .alert.success {
        background: #e8f7ee;
        border-color: #b8e3c8;
        color: #1f6a3a;
      }
      .alert.error {
        background: #fce9e7;
        border-color: #f1b8b1;
        color: #9b2c22;
      }
      .alert.info {
        background: #e9f3fb;
        border-color: #bfd7eb;
        color: #174d70;
      }
      .tab-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .tab-row a {
        text-decoration: none;
        font-weight: 700;
        color: #0f4667;
        padding: 0.72rem 1rem;
        border-radius: 14px;
        border: 1px solid #d8e2ea;
        background: #eef4f8;
      }
      .tab-row a.active {
        background: #0f5f8f;
        border-color: #0f5f8f;
        color: #fff;
      }
      .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 0.9rem;
      }
      .field label {
        display: block;
        font-weight: 700;
        margin-bottom: 0.35rem;
      }
      .field input,
      .field select,
      .field textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid #c9d8e4;
        border-radius: 14px;
        padding: 0.8rem 0.9rem;
        font: inherit;
        background: var(--surface-strong);
        color: var(--text-main);
      }
      .field input[type="checkbox"] {
        width: auto;
        padding: 0;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }
      .field textarea {
        min-height: 130px;
        resize: vertical;
      }
      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        outline: none;
        border-color: #6aa6cc;
        box-shadow: 0 0 0 0.18rem rgba(47, 127, 184, 0.14);
      }
      .primary-btn,
      .secondary-btn,
      .danger-btn {
        border: none;
        border-radius: 14px;
        color: #fff;
        padding: 0.9rem 1.05rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .primary-btn {
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
      }
      .secondary-btn {
        background: linear-gradient(145deg, #607180, #4f5c68);
      }
      .danger-btn {
        background: linear-gradient(145deg, #b63d2f, #922f24);
      }
      .primary-btn:disabled,
      .secondary-btn:disabled,
      .danger-btn:disabled {
        opacity: 0.62;
        cursor: not-allowed;
        box-shadow: 0 4px 12px rgba(15, 70, 103, 0.1);
        transform: none;
      }
      .field-help {
        margin: 0.38rem 0 0;
        color: var(--text-sub);
        line-height: 1.55;
        font-size: 0.92rem;
      }
      .section-note,
      .workflow-meta,
      .workflow-body,
      .source-preview,
      .subtle-text {
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .section-note,
      .workflow-meta,
      .subtle-text {
        color: var(--text-sub);
        line-height: 1.7;
      }
      .source-preview,
      .workflow-body {
        color: var(--text-main);
        line-height: 1.75;
        white-space: pre-line;
      }
      .soft-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.85rem;
      }
      .soft-list li {
        padding: 1rem 1.05rem;
        border-radius: 18px;
        border: 1px solid #d8e2ea;
        background: rgba(255, 255, 255, 0.82);
      }
      .workflow-item {
        display: grid;
        gap: 0.85rem;
      }
      .workflow-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
      }
      .list-item-title {
        display: block;
        color: var(--primary-strong);
        line-height: 1.55;
        margin: 0;
      }
      .pill-row,
      .tag-list,
      .source-actions {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
      }
      .pill,
      .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.42rem 0.68rem;
        border-radius: 999px;
        background: #eef4f8;
        color: #0f4667;
        font-size: 0.88rem;
        font-weight: 700;
        border: 1px solid #d8e2ea;
      }
      .status-badge.draft {
        background: #fff4df;
        border-color: #f1d6a3;
        color: #9b6a00;
      }
      .status-badge.approved {
        background: #e8f7ee;
        border-color: #b8e3c8;
        color: #1f6a3a;
      }
      .status-badge.rejected,
      .status-badge.archived {
        background: #fce9e7;
        border-color: #f1b8b1;
        color: #9b2c22;
      }
      .detail-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        padding: 0.8rem 0.95rem;
        border-radius: 14px;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .source-actions {
        margin-top: 0.25rem;
      }
      .source-actions form {
        margin: 0;
      }
      .workflow-note {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        background: rgba(241, 246, 251, 0.82);
        border: 1px solid #d8e2ea;
        color: var(--text-sub);
        line-height: 1.7;
      }
      .workflow-empty-state {
        padding: 1.1rem 1.1rem 1rem;
        border-radius: 18px;
        border: 1px dashed #b9cfe0;
        background: rgba(241, 246, 251, 0.72);
        color: var(--text-sub);
        line-height: 1.75;
      }
      .workflow-empty-state h3 {
        margin: 0 0 0.35rem;
        color: var(--primary-strong);
      }
      .workflow-empty-state p {
        margin: 0;
      }
      .workflow-empty-actions {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
        margin-top: 0.9rem;
      }
      .workflow-empty-actions .detail-link,
      .workflow-empty-actions .primary-btn,
      .workflow-empty-actions .secondary-btn {
        text-decoration: none;
      }
      @media (max-width: 820px) {
        .shell {
          width: min(100%, calc(100% - 1rem));
          padding: 0.75rem 0 1.4rem;
        }
        .card,
        .topbar {
          padding: 1rem;
        }
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }
        .workflow-header {
          flex-direction: column;
        }
        .field input,
        .field select,
        .field textarea,
        .primary-btn,
        .secondary-btn,
        .danger-btn {
          font-size: 16px;
        }
        .source-actions {
          flex-direction: column;
          align-items: stretch;
        }
        .source-actions form,
        .source-actions button,
        .workflow-empty-actions,
        .detail-link {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <%- include("partials/flashMessages") %>

      <section class="topbar">
        <div>
          <h1 class="hero-title">Knowledge Workflow</h1>
          <p class="hero-subtitle">จัดการแหล่งต้นฉบับ คัดร่างจาก AI และส่งต่อไปอนุมัติเป็นคำถามแนะนำหรือฐานความรู้จริง</p>
        </div>
        <a class="detail-link" href="/admin">กลับหน้าแดชบอร์ด</a>
      </section>

      <section class="card" id="workflow-create-source">
        <%- include("partials/knowledgeAdminTabs", { activeTab: "knowledge-workflow" }) %>
      </section>

      <section class="grid">
        <article class="card metric-card source">
          <p class="metric-label">ต้นฉบับล่าสุด</p>
          <div class="metric"><%= data.summary.total %></div>
        </article>
        <article class="card metric-card draft">
          <p class="metric-label">ต้นฉบับร่าง</p>
          <div class="metric"><%= data.summary.draft %></div>
        </article>
        <article class="card metric-card draft">
          <p class="metric-label">draft รอ review</p>
          <div class="metric"><%= data.summary.draftPending %></div>
        </article>
        <article class="card metric-card approved">
          <p class="metric-label">draft อนุมัติแล้ว</p>
          <div class="metric"><%= data.summary.draftApproved %></div>
        </article>
      </section>

      <section class="card">
        <h2 style="margin-top: 0; color: var(--primary-strong);">สร้าง knowledge source ใหม่</h2>
        <p class="section-note">
          หน้านี้เก็บต้นฉบับที่ผ่านการคัดแล้วก่อนส่งต่อให้ AI สร้าง draft จาก source เดียว โดยถ้าติ๊กสร้าง draft ทันที ระบบจะพาคุณไปหน้า detail ของ source นั้นหลังบันทึกเสร็จ
        </p>
        <form action="/admin/knowledge-workflow" method="post" data-workflow-form="native">
          <div class="form-grid">
            <div class="field">
              <label for="workflowDomain">Domain</label>
              <select id="workflowDomain" name="domain">
                <% (domainOptions || []).forEach((option) => { %>
                  <option value="<%= option.value %>" <%= option.value === 'general' ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="workflowTarget">Target</label>
              <select id="workflowTarget" name="target">
                <% (targetOptions || []).forEach((option) => { %>
                  <option value="<%= option.value %>" <%= option.value === 'general' ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </div>
            <div class="field">
              <label for="workflowDocumentType">Document type</label>
              <input id="workflowDocumentType" name="documentType" type="text" maxlength="100" placeholder="เช่น FAQ, ระเบียบ, บันทึกประชุม" />
            </div>
          </div>

          <div class="field" style="margin-top: 0.9rem;">
            <label for="workflowTitle">หัวข้อ / ชื่อต้นฉบับ</label>
            <input id="workflowTitle" name="title" type="text" minlength="3" maxlength="255" placeholder="เช่น สิทธิสมาชิกสหกรณ์ในการกู้ยืม" required />
            <p class="field-help">ตั้งชื่อให้สื่อหัวข้อชัดเจน เช่น ประเด็นกฎหมาย นโยบาย หรือเอกสารอ้างอิงชุดนั้น</p>
          </div>

          <div class="field" style="margin-top: 0.9rem;">
            <label for="workflowSourceReference">แหล่งอ้างอิง</label>
            <input id="workflowSourceReference" name="sourceReference" type="text" maxlength="500" placeholder="เช่น มาตรา 15 หรือเอกสารประชุมคณะกรรมการ" />
          </div>

          <div class="field" style="margin-top: 0.9rem;">
            <label for="workflowSourceText">ต้นฉบับ</label>
            <textarea id="workflowSourceText" name="sourceText" minlength="10" placeholder="วางข้อความต้นฉบับที่ผ่านการคัดแล้วตรงนี้" required></textarea>
            <p class="field-help">ควรเป็นข้อความที่ผ่านการคัดแล้วและพร้อมให้ AI แตกเป็น draft ต่อได้ทันที</p>
          </div>

          <div class="field" style="margin-top: 0.9rem;">
            <label style="display: inline-flex; align-items: center; gap: 0.5rem;">
              <input type="checkbox" name="generateDraftsNow" value="1" />
              <span>สร้าง draft ทันทีหลังบันทึกต้นฉบับ</span>
            </label>
          </div>

          <div style="margin-top: 1rem;">
            <button class="primary-btn" type="submit" data-workflow-submit-button data-loading-text="กำลังบันทึก...">บันทึก knowledge source</button>
          </div>
        </form>
      </section>

      <section class="card">
        <h2 style="margin-top: 0; color: var(--primary-strong);">knowledge sources ล่าสุด</h2>
        <p class="section-note">คลิกเข้าไปดูรายละเอียด source ที่ต้องการรีวิว draft หรือกดสร้าง draft ใหม่จากต้นฉบับเดิมได้ทันที</p>
        <% if (typeof pageErrorMessage !== "undefined" && pageErrorMessage) { %>
          <div class="workflow-empty-state">
            <h3>เกิดปัญหาในการโหลดรายการ</h3>
            <p><%= pageErrorMessage %></p>
            <div class="workflow-empty-actions">
              <a class="detail-link" href="/admin/knowledge-workflow">ลองโหลดใหม่</a>
              <a class="secondary-btn" href="/admin">กลับหน้าแดชบอร์ด</a>
            </div>
          </div>
        <% } else if (!data.recentSources || data.recentSources.length === 0) { %>
          <div class="workflow-empty-state">
            <h3>ยังไม่มี knowledge source</h3>
            <p>เริ่มจากเพิ่มต้นฉบับที่ผ่านการคัดแล้ว และค่อยสร้าง draft จากต้นฉบับนั้นเพื่อเข้าสู่ขั้น review</p>
            <div class="workflow-empty-actions">
              <a class="detail-link" href="#workflow-create-source">สร้าง source ใหม่</a>
            </div>
          </div>
        <% } else { %>
          <ul class="soft-list">
            <% (data.recentSources || []).forEach((item) => { %>
              <li class="workflow-item">
                <div class="workflow-header">
                  <div>
                    <strong class="list-item-title"><%= item.title %></strong>
                    <div class="workflow-meta" style="margin-top: 0.35rem;">
                      <span class="status-badge <%= item.status %>"><%= item.statusLabel %></span>
                      <span class="pill">Domain: <%= item.domainLabel %></span>
                      <span class="pill">Target: <%= item.targetLabel %></span>
                      <% if (item.documentType) { %><span class="pill">Type: <%= item.documentType %></span><% } %>
                      <% if (item.createdAt) { %><span class="pill">สร้างเมื่อ: <%= item.createdAt %></span><% } %>
                    </div>
                  </div>
                  <a class="detail-link" href="/admin/knowledge-workflow/<%= item.id %>">ดู drafts</a>
                </div>

                <% if (item.sourceReference) { %>
                  <div class="workflow-meta">แหล่งอ้างอิง: <%= item.sourceReference %></div>
                <% } %>

                <div class="source-preview"><%= item.sourcePreviewText || item.sourceText %></div>

                <div class="tag-list">
                  <span class="pill">ร่างทั้งหมด <%= item.draftSummary.total %></span>
                  <span class="pill">ร่างรอ review <%= item.draftSummary.draft %></span>
                  <span class="pill">อนุมัติแล้ว <%= item.draftSummary.approved %></span>
                  <span class="pill">ปฏิเสธแล้ว <%= item.draftSummary.rejected %></span>
                </div>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </section>
    </div>
    <%- include("partials/workflowFormScript") %>
  </body>
</html>
