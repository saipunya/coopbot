<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { margin: 0; font-family: 'Sarabun', Arial, sans-serif; background: linear-gradient(160deg, #e6eef6, #f5f9fc); color: #1f2a37; }
      .shell { width: min(1080px, calc(100% - 2rem)); margin: 0 auto; padding: 1.5rem 0 3rem; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid #d8e2ea; border-radius: 20px; box-shadow: 0 18px 45px rgba(18,52,77,0.16); padding: 1.25rem; margin-bottom: 1rem; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:1rem; }
      .topbar a { color: #0f4667; text-decoration:none; font-weight:700; }
      .alert { padding: 0.9rem 1rem; border-radius: 14px; margin-bottom: 1rem; }
      .alert.success { background:#e8f7ee; color:#1f6a3a; border:1px solid #b8e3c8; }
      .alert.error { background:#fce9e7; color:#9b2c22; border:1px solid #f1b8b1; }
      .grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:1rem; }
      .metric { font-size: 1.8rem; font-weight: 700; color: #0f4667; margin: 0.3rem 0 0; }
      .soft-list { list-style:none; padding:0; margin:0; display:grid; gap:0.8rem; }
      .soft-list li { padding:1rem; border:1px solid #d8e2ea; border-radius:16px; background: rgba(255,255,255,0.82); }
      .meta { color:#5d6a79; font-size:0.92rem; margin-top:0.4rem; }
      .request-head { display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; flex-wrap:wrap; }
      .request-actions { display:flex; align-items:center; gap:0.65rem; flex-wrap:wrap; margin-top:0.9rem; }
      .request-actions select { min-width: 180px; border:1px solid #c8d6e2; border-radius:12px; padding:0.7rem 0.85rem; font:inherit; background:#fff; color:#1f2a37; }
      .request-actions button { border:none; border-radius:12px; padding:0.72rem 0.95rem; background:#0f5f8f; color:#fff; font:inherit; font-weight:700; cursor:pointer; }
      .request-actions button:hover { opacity:0.92; }
      .status-chip { display:inline-flex; align-items:center; gap:0.35rem; border-radius:999px; padding:0.32rem 0.75rem; font-size:0.84rem; font-weight:700; }
      .status-chip.pending { background:#fff6dd; color:#946200; }
      .status-chip.approved { background:#e8f7ee; color:#1f6a3a; }
      .status-chip.rejected { background:#fce9e7; color:#9b2c22; }
      @media (max-width: 720px) {
        .request-actions { flex-direction:column; align-items:stretch; }
        .request-actions button, .request-actions select { width:100%; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% const paymentStatusLabelMap = { pending: 'รอพิจารณา', approved: 'อนุมัติแล้ว', rejected: 'ปฏิเสธแล้ว' }; %>
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="card topbar">
        <div>
          <h1 style="margin:0; color:#0f4667;">คำขอชำระเงิน</h1>
          <p style="margin:0.35rem 0 0; color:#5d6a79;">ตรวจสอบคำขอชำระเงินที่รอพิจารณาและรายการที่ดำเนินการแล้ว</p>
        </div>
        <a href="/admin">กลับหน้าแดชบอร์ด</a>
      </section>

      <section class="grid">
        <article class="card"><div>ทั้งหมด</div><div class="metric"><%= data.totalCount %></div></article>
        <article class="card"><div>รอพิจารณา</div><div class="metric"><%= data.pendingCount %></div></article>
        <article class="card"><div>อนุมัติแล้ว</div><div class="metric"><%= data.approvedCount %></div></article>
        <article class="card"><div>ปฏิเสธแล้ว</div><div class="metric"><%= data.rejectedCount %></div></article>
      </section>

      <section class="card">
        <ul class="soft-list">
          <% if (!data.requests.length) { %>
            <li>ยังไม่พบคำขอชำระเงิน</li>
          <% } %>
          <% data.requests.forEach((item) => { %>
            <li>
              <div class="request-head">
                <strong><a href="/admin/payment-requests/<%= item.id %>">#<%= item.id %> - <%= item.planLabel || item.plan_name %></a></strong>
                <span class="status-chip <%= item.status %>"><%= paymentStatusLabelMap[item.status] || item.status %></span>
              </div>
              <div class="meta">
                ผู้ใช้: <%= item.user_name || "-" %> | อีเมล: <%= item.user_email || "-" %> | แพ็กเกจปัจจุบัน: <%= item.userPlanLabel || item.user_plan || "ฟรี" %> | ยอดชำระ: <%= Number(item.amount || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> บาท | สถานะ: <%= paymentStatusLabelMap[item.status] || item.status %>
              </div>
              <% if (item.status === "pending") { %>
                <form class="request-actions" action="/admin/payment-requests/update-plan" method="post">
                  <input type="hidden" name="id" value="<%= item.id %>" />
                  <input type="hidden" name="returnTo" value="/admin/payment-requests" />
                  <select name="planCode" aria-label="เลือกแพ็กเกจใหม่สำหรับคำขอนี้">
                    <% data.plans.forEach((plan) => { %>
                      <option value="<%= plan.code %>" <%= plan.code === item.planCode ? "selected" : "" %>>
                        <%= plan.label %> - <%= Number(plan.priceBaht || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> บาท
                      </option>
                    <% }) %>
                  </select>
                  <button type="submit">อัปเดตแพ็กเกจ</button>
                </form>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </section>
    </div>
  </body>
 </html>
