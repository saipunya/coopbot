<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-start: #e6eef6;
        --bg-end: #f5f9fc;
        --surface: rgba(255, 255, 255, 0.9);
        --surface-strong: #ffffff;
        --primary: #15547a;
        --primary-strong: #0f4667;
        --text-main: #1f2a37;
        --text-sub: #5d6a79;
        --border: #d8e2ea;
        --shadow-soft: 0 18px 45px rgba(18, 52, 77, 0.16);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        font-family: "Sarabun", Arial, sans-serif;
        background:
          radial-gradient(circle at 14% 18%, rgba(35, 126, 184, 0.14), transparent 38%),
          radial-gradient(circle at 85% 10%, rgba(23, 84, 122, 0.12), transparent 32%),
          linear-gradient(160deg, var(--bg-start), var(--bg-end));
        background-attachment: fixed;
        color: var(--text-main);
      }
      .shell {
        width: min(1200px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.4rem 0 3rem;
      }
      .card,
      .topbar {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 22px;
        box-shadow: var(--shadow-soft);
        backdrop-filter: blur(14px);
      }
      .card {
        padding: 1.25rem;
        margin-bottom: 1rem;
      }
      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        position: relative;
        overflow: hidden;
      }
      .topbar::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at top left, rgba(255, 255, 255, 0.38), transparent 32%),
          linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 42%);
        pointer-events: none;
      }
      .topbar > * {
        position: relative;
        z-index: 1;
      }
      .hero-title {
        margin: 0;
        color: var(--primary-strong);
        font-size: clamp(1.45rem, 2.6vw, 2rem);
      }
      .hero-subtitle {
        margin: 0.28rem 0 0;
        color: var(--text-sub);
        line-height: 1.6;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
      }
      .metric-card {
        position: relative;
        overflow: hidden;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 252, 0.92));
      }
      .metric-card::before {
        content: "";
        position: absolute;
        inset: 0 0 auto;
        height: 4px;
        background: linear-gradient(90deg, #0f5f8f, transparent 85%);
      }
      .metric-card.draft::before {
        background: linear-gradient(90deg, #8c5d1f, transparent 85%);
      }
      .metric-card.approved::before {
        background: linear-gradient(90deg, #1d7a52, transparent 85%);
      }
      .metric-card.rejected::before {
        background: linear-gradient(90deg, #922f24, transparent 85%);
      }
      .metric-label {
        margin: 0;
        color: var(--text-sub);
      }
      .metric {
        font-size: 2rem;
        font-weight: 700;
        margin: 0.35rem 0 0;
        color: var(--primary-strong);
      }
      .alert {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        margin-bottom: 1rem;
        border: 1px solid transparent;
        box-shadow: 0 8px 20px rgba(18, 52, 77, 0.08);
      }
      .alert.success {
        background: #e8f7ee;
        border-color: #b8e3c8;
        color: #1f6a3a;
      }
      .alert.error {
        background: #fce9e7;
        border-color: #f1b8b1;
        color: #9b2c22;
      }
      .tab-row {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }
      .tab-row a {
        text-decoration: none;
        font-weight: 700;
        color: #0f4667;
        padding: 0.72rem 1rem;
        border-radius: 14px;
        border: 1px solid #d8e2ea;
        background: #eef4f8;
      }
      .tab-row a.active {
        background: #0f5f8f;
        border-color: #0f5f8f;
        color: #fff;
      }
      .section-note,
      .workflow-meta,
      .workflow-body,
      .source-preview,
      .subtle-text {
        overflow-wrap: anywhere;
        word-break: break-word;
      }
      .section-note,
      .workflow-meta,
      .subtle-text {
        color: var(--text-sub);
        line-height: 1.7;
      }
      .source-preview,
      .workflow-body {
        color: var(--text-main);
        line-height: 1.75;
        white-space: pre-line;
      }
      .soft-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 0.85rem;
      }
      .soft-list li {
        padding: 1rem 1.05rem;
        border-radius: 18px;
        border: 1px solid #d8e2ea;
        background: rgba(255, 255, 255, 0.82);
      }
      .workflow-item {
        display: grid;
        gap: 0.85rem;
      }
      .workflow-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
      }
      .list-item-title {
        display: block;
        color: var(--primary-strong);
        line-height: 1.55;
        margin: 0;
      }
      .pill-row,
      .tag-list,
      .source-actions,
      .draft-actions {
        display: flex;
        gap: 0.55rem;
        flex-wrap: wrap;
      }
      .pill,
      .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.42rem 0.68rem;
        border-radius: 999px;
        background: #eef4f8;
        color: #0f4667;
        font-size: 0.88rem;
        font-weight: 700;
        border: 1px solid #d8e2ea;
      }
      .status-badge.draft {
        background: #fff4df;
        border-color: #f1d6a3;
        color: #9b6a00;
      }
      .status-badge.approved {
        background: #e8f7ee;
        border-color: #b8e3c8;
        color: #1f6a3a;
      }
      .status-badge.rejected,
      .status-badge.archived {
        background: #fce9e7;
        border-color: #f1b8b1;
        color: #9b2c22;
      }
      .detail-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
        color: #fff;
        padding: 0.8rem 0.95rem;
        border-radius: 14px;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .field label {
        display: block;
        font-weight: 700;
        margin-bottom: 0.35rem;
      }
      .field input,
      .field select,
      .field textarea {
        width: 100%;
        box-sizing: border-box;
        border: 1px solid #c9d8e4;
        border-radius: 14px;
        padding: 0.8rem 0.9rem;
        font: inherit;
        background: var(--surface-strong);
        color: var(--text-main);
      }
      .field textarea {
        min-height: 130px;
        resize: vertical;
      }
      .field input:focus,
      .field select:focus,
      .field textarea:focus {
        outline: none;
        border-color: #6aa6cc;
        box-shadow: 0 0 0 0.18rem rgba(47, 127, 184, 0.14);
      }
      .primary-btn,
      .secondary-btn,
      .danger-btn {
        border: none;
        border-radius: 14px;
        color: #fff;
        padding: 0.9rem 1.05rem;
        cursor: pointer;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(15, 70, 103, 0.18);
      }
      .primary-btn {
        background: linear-gradient(145deg, var(--primary), var(--primary-strong));
      }
      .secondary-btn {
        background: linear-gradient(145deg, #607180, #4f5c68);
      }
      .danger-btn {
        background: linear-gradient(145deg, #b63d2f, #922f24);
      }
      .note-box,
      .answer-box,
      .source-box {
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid #d8e2ea;
        background: rgba(241, 246, 251, 0.82);
        line-height: 1.75;
      }
      .keyword-list {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }
      .keyword {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.38rem 0.6rem;
        border-radius: 999px;
        background: #eef4f8;
        border: 1px solid #d8e2ea;
        color: #0f4667;
        font-size: 0.86rem;
        font-weight: 700;
      }
      .workflow-note {
        padding: 0.9rem 1rem;
        border-radius: 16px;
        background: rgba(241, 246, 251, 0.82);
        border: 1px solid #d8e2ea;
        color: var(--text-sub);
        line-height: 1.7;
      }
      .draft-card {
        display: grid;
        gap: 0.85rem;
      }
      .draft-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
      }
      .draft-status-row {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
      }
      .draft-actions {
        align-items: center;
      }
      .draft-actions form {
        margin: 0;
      }
      .source-actions form {
        margin: 0;
      }
      @media (max-width: 820px) {
        .shell {
          width: min(100%, calc(100% - 1rem));
          padding: 0.75rem 0 1.4rem;
        }
        .card,
        .topbar {
          padding: 1rem;
        }
        .topbar {
          flex-direction: column;
          align-items: stretch;
        }
        .workflow-header,
        .draft-header {
          flex-direction: column;
        }
        .field input,
        .field select,
        .field textarea,
        .primary-btn,
        .secondary-btn,
        .danger-btn {
          font-size: 16px;
        }
        .source-actions,
        .draft-actions {
          flex-direction: column;
          align-items: stretch;
        }
        .source-actions form,
        .draft-actions form,
        .source-actions button,
        .draft-actions button,
        .detail-link {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="topbar">
        <div>
          <h1 class="hero-title"><%= data.source.title %></h1>
          <p class="hero-subtitle">ดูต้นฉบับ ตรวจ draft จาก AI และส่งต่อไปยังคำถามแนะนำหรือฐานความรู้ได้จากหน้านี้</p>
        </div>
        <a class="detail-link" href="/admin/knowledge-workflow">กลับหน้ารายการ</a>
      </section>

      <section class="card">
        <%- include("partials/knowledgeAdminTabs", { activeTab: "knowledge-workflow" }) %>
      </section>

      <section class="grid">
        <article class="card metric-card draft">
          <p class="metric-label">ร่างทั้งหมด</p>
          <div class="metric"><%= data.draftSummary.total %></div>
        </article>
        <article class="card metric-card draft">
          <p class="metric-label">ร่างรอ review</p>
          <div class="metric"><%= data.draftSummary.draft %></div>
        </article>
        <article class="card metric-card approved">
          <p class="metric-label">อนุมัติแล้ว</p>
          <div class="metric"><%= data.draftSummary.approved %></div>
        </article>
        <article class="card metric-card rejected">
          <p class="metric-label">ปฏิเสธแล้ว</p>
          <div class="metric"><%= data.draftSummary.rejected %></div>
        </article>
      </section>

      <section class="card">
        <h2 style="margin-top: 0; color: var(--primary-strong);">ข้อมูลต้นฉบับ</h2>
        <div class="pill-row" style="margin-bottom: 0.75rem;">
          <span class="status-badge <%= data.source.status %>"><%= data.source.statusLabel %></span>
          <span class="pill">Domain: <%= data.source.domainLabel %></span>
          <span class="pill">Target: <%= data.source.targetLabel %></span>
          <% if (data.source.documentType) { %><span class="pill">Type: <%= data.source.documentType %></span><% } %>
          <% if (data.source.createdAt) { %><span class="pill">สร้างเมื่อ: <%= data.source.createdAt %></span><% } %>
          <% if (data.source.updatedAt) { %><span class="pill">อัปเดตล่าสุด: <%= data.source.updatedAt %></span><% } %>
        </div>
        <% if (data.source.sourceReference) { %>
          <div class="workflow-meta" style="margin-bottom: 0.75rem;">แหล่งอ้างอิง: <%= data.source.sourceReference %></div>
        <% } %>
        <% if (data.source.approvedBy || data.source.approvedAt) { %>
          <div class="workflow-meta" style="margin-bottom: 0.75rem;">
            <% if (data.source.approvedBy) { %>อนุมัติโดย: <%= data.source.approvedBy %><% } %>
            <% if (data.source.approvedAt) { %><% if (data.source.approvedBy) { %> | <% } %>อนุมัติเมื่อ: <%= data.source.approvedAt %><% } %>
          </div>
        <% } %>
        <div class="source-box"><%= data.source.sourceText %></div>
      </section>

      <section class="card">
        <h2 style="margin-top: 0; color: var(--primary-strong);">สร้าง draft จากต้นฉบับนี้</h2>
        <p class="section-note">
          ถ้ามี draft เดิมอยู่แล้ว ระบบจะไม่สร้างซ้ำจนกว่าจะสั่ง force regenerate เพื่อป้องกันรายการรกและลดความสับสนในหน้าตรวจทาน
        </p>
        <div class="source-actions">
          <form action="/admin/knowledge-sources/<%= data.source.id %>/generate-drafts" method="post" data-workflow-fetch data-action-type="generate" data-success-message="สร้าง draft จากต้นฉบับเรียบร้อยแล้ว">
            <input type="hidden" name="forceRegenerate" value="0" />
            <button class="primary-btn" type="submit">Generate drafts</button>
          </form>
          <form action="/admin/knowledge-sources/<%= data.source.id %>/generate-drafts" method="post" data-workflow-fetch data-action-type="generate" data-success-message="สร้าง draft ใหม่เรียบร้อยแล้ว">
            <input type="hidden" name="forceRegenerate" value="1" />
            <button class="secondary-btn" type="submit">Force regenerate</button>
          </form>
        </div>
        <div class="workflow-note" style="margin-top: 0.9rem;">
          เมื่อกด force regenerate ระบบจะยกเลิกร่างเดิมก่อนสร้างชุดใหม่ให้ทันที โดยทำงานผ่าน backend endpoint เดิมที่มีอยู่แล้ว
        </div>
      </section>

      <section class="card">
        <h2 style="margin-top: 0; color: var(--primary-strong);">drafts ของ source นี้</h2>
        <p class="section-note">รายการด้านล่างรวมทั้ง draft ที่รอ review, รายการที่อนุมัติแล้ว และรายการที่ปฏิเสธแล้ว</p>
        <ul class="soft-list">
          <% if (!data.drafts || data.drafts.length === 0) { %>
            <li class="workflow-note">ยังไม่มี draft สำหรับ source นี้ ลองกด Generate drafts ด้านบนได้เลย</li>
          <% } %>
          <% (data.drafts || []).forEach((draft) => { %>
            <li class="workflow-item draft-card">
              <div class="draft-header">
                <div>
                  <strong class="list-item-title"><%= draft.question %></strong>
                  <div class="workflow-meta" style="margin-top: 0.35rem;">
                    <span class="status-badge <%= draft.status %>"><%= draft.statusLabel %></span>
                    <span class="pill">Confidence: <%= draft.confidence %></span>
                    <span class="pill">Target: <%= draft.approvedTargetLabel %></span>
                    <% if (draft.createdAt) { %><span class="pill">สร้างเมื่อ: <%= draft.createdAt %></span><% } %>
                    <% if (draft.updatedAt) { %><span class="pill">อัปเดตล่าสุด: <%= draft.updatedAt %></span><% } %>
                  </div>
                </div>
                <% if (draft.approvedRecordType) { %>
                  <span class="status-badge approved"><%= draft.approvedRecordTypeLabel %> #<%= draft.approvedRecordId %></span>
                <% } %>
              </div>

              <div class="answer-box">
                <strong>คำตอบย่อ</strong>
                <div class="workflow-body"><%= draft.shortAnswer %></div>
              </div>

              <% if (draft.detailedAnswer && draft.detailedAnswer !== draft.shortAnswer) { %>
                <details class="answer-box">
                  <summary class="subtle-text" style="cursor: pointer; font-weight: 700; color: var(--primary-strong);">ดูคำตอบละเอียด</summary>
                  <div class="workflow-body" style="margin-top: 0.75rem;"><%= draft.detailedAnswer %></div>
                </details>
              <% } %>

              <% if (draft.notes) { %>
                <div class="note-box">
                  <strong>หมายเหตุ</strong>
                  <div class="workflow-body"><%= draft.notes %></div>
                </div>
              <% } %>

              <% if (draft.keywords && draft.keywords.length) { %>
                <div class="tag-list">
                  <% draft.keywords.forEach((keyword) => { %>
                    <span class="keyword"><%= keyword %></span>
                  <% }) %>
                </div>
              <% } %>

              <% if (draft.status === 'draft') { %>
                <div class="draft-actions">
                  <form action="/admin/knowledge-drafts/<%= draft.id %>/approve-suggested" method="post" data-workflow-fetch data-action-type="approve-suggested" data-success-message="อนุมัติ draft เป็นคำถามแนะนำเรียบร้อยแล้ว">
                    <button class="primary-btn" type="submit">อนุมัติเป็นคำถามแนะนำ</button>
                  </form>
                  <form action="/admin/knowledge-drafts/<%= draft.id %>/approve-knowledge" method="post" data-workflow-fetch data-action-type="approve-knowledge" data-success-message="อนุมัติ draft เป็นฐานความรู้เรียบร้อยแล้ว">
                    <button class="secondary-btn" type="submit">อนุมัติเป็นฐานความรู้</button>
                  </form>
                  <form action="/admin/knowledge-drafts/<%= draft.id %>/reject" method="post" data-workflow-fetch data-action-type="reject" data-confirm-message="ยืนยันการปฏิเสธ draft นี้ใช่หรือไม่" data-success-message="ปฏิเสธ draft เรียบร้อยแล้ว">
                    <button class="danger-btn" type="submit">ปฏิเสธร่างนี้</button>
                  </form>
                </div>
              <% } else { %>
                <div class="workflow-note">
                  <div>
                    รายการนี้ถูกดำเนินการแล้ว
                    <% if (draft.approvedRecordType && draft.approvedRecordId) { %>
                      โดยเชื่อมกับ <strong><%= draft.approvedRecordTypeLabel %> #<%= draft.approvedRecordId %></strong>
                    <% } %>
                  </div>
                  <div style="margin-top: 0.35rem;">สถานะปัจจุบัน: <strong><%= draft.statusLabel %></strong></div>
                </div>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </section>
    </div>

    <script>
      (function () {
        function appendQueryParam(url, key, value) {
          const nextUrl = new URL(url, window.location.origin);
          nextUrl.searchParams.delete("success");
          nextUrl.searchParams.delete("error");
          nextUrl.searchParams.set(key, value);
          return nextUrl.toString();
        }

        async function submitWorkflowForm(form) {
          const response = await fetch(form.action, {
            method: "POST",
            headers: {
              "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
              Accept: "application/json",
              "X-Requested-With": "XMLHttpRequest",
            },
            body: new URLSearchParams(new FormData(form)).toString(),
          });

          let payload = {};
          try {
            payload = await response.json();
          } catch (_) {
            payload = {};
          }

          if (response.status === 401) {
            window.location.href = payload.loginPath || "/admin/login";
            return;
          }

          if (!response.ok || !payload.ok) {
            throw new Error(payload.message || payload.reason || "ไม่สามารถดำเนินการได้");
          }

          if (form.dataset.actionType === "generate") {
            let message = payload.reusedExistingDrafts
              ? "มี draft เดิมอยู่แล้ว ระบบจึงใช้ชุดเดิม"
              : `สร้าง draft ใหม่ ${Array.isArray(payload.drafts) ? payload.drafts.length : 0} รายการแล้ว`;

            if (payload.regenerated) {
              message += " และแทนที่ draft เดิมเรียบร้อยแล้ว";
            }

            window.location.href = appendQueryParam(window.location.href, "success", message);
            return;
          }

          const successMessage = form.dataset.successMessage || "ดำเนินการเรียบร้อยแล้ว";
          window.location.href = appendQueryParam(window.location.href, "success", successMessage);
        }

        document.querySelectorAll("form[data-workflow-fetch]").forEach((form) => {
          form.addEventListener("submit", async (event) => {
            event.preventDefault();

            if (form.dataset.confirmMessage && !window.confirm(form.dataset.confirmMessage)) {
              return;
            }

            const submitButton = form.querySelector('button[type="submit"]');
            if (submitButton) {
              submitButton.disabled = true;
            }

            try {
              await submitWorkflowForm(form);
            } catch (error) {
              window.location.href = appendQueryParam(
                window.location.href,
                "error",
                error.message || "ไม่สามารถดำเนินการได้",
              );
            } finally {
              if (submitButton) {
                submitButton.disabled = false;
              }
            }
          });
        });
      })();
    </script>
  </body>
</html>
