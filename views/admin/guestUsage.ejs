<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { margin: 0; font-family: 'Sarabun', Arial, sans-serif; background: linear-gradient(160deg, #e6eef6, #f5f9fc); color: #1f2a37; }
      .shell { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; padding: 1.5rem 0 3rem; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid #d8e2ea; border-radius: 20px; box-shadow: 0 18px 45px rgba(18,52,77,0.16); padding: 1.25rem; margin-bottom: 1rem; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:1rem; flex-wrap:wrap; }
      .topbar a { color:#0f4667; text-decoration:none; font-weight:700; }
      .alert { padding: 0.9rem 1rem; border-radius: 14px; margin-bottom: 1rem; }
      .alert.success { background:#e8f7ee; color:#1f6a3a; border:1px solid #b8e3c8; }
      .alert.error { background:#fce9e7; color:#9b2c22; border:1px solid #f1b8b1; }
      .grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:1rem; }
      .metric-card { position:relative; overflow:hidden; }
      .metric-card::before { content:""; position:absolute; inset:0 0 auto; height:4px; background: linear-gradient(90deg, #0f5f8f, transparent 85%); }
      .metric-card.warn::before { background: linear-gradient(90deg, #8b2e2e, transparent 85%); }
      .metric-card.ok::before { background: linear-gradient(90deg, #1d7a52, transparent 85%); }
      .metric { font-size: 1.8rem; font-weight: 700; color: #0f4667; margin: 0.3rem 0 0; }
      .search-form { display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center; }
      .search-form input { border:1px solid #c8d6e2; border-radius:14px; padding:0.85rem 1rem; font:inherit; }
      .search-form select { border:1px solid #c8d6e2; border-radius:14px; padding:0.85rem 1rem; font:inherit; background:#fff; }
      .search-form .wide { flex:1 1 280px; }
      .search-form button, .search-form a { border:none; border-radius:14px; padding:0.85rem 1rem; font:inherit; font-weight:700; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; justify-content:center; }
      .search-form button { background:#0f5f8f; color:#fff; }
      .search-form a { background:#eef4f8; color:#0f4667; border:1px solid #d8e2ea; }
      .toolbar { display:flex; gap:0.75rem; flex-wrap:wrap; justify-content:space-between; align-items:center; margin-bottom:1rem; }
      .toolbar-actions { display:flex; gap:0.6rem; flex-wrap:wrap; }
      .toolbar-actions a, .toolbar-actions button { border:none; border-radius:12px; padding:0.78rem 0.95rem; font:inherit; font-weight:700; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; justify-content:center; }
      .toolbar-actions a { background:#eef4f8; color:#0f4667; border:1px solid #d8e2ea; }
      .toolbar-actions button { background:#8b2e2e; color:#fff; }
      table { width:100%; border-collapse:collapse; }
      th, td { text-align:left; padding:0.85rem 0.75rem; border-bottom:1px solid #e0e8ee; vertical-align:top; }
      th { color:#5d6a79; font-size:0.88rem; }
      .identity-chip { display:inline-flex; align-items:center; gap:0.4rem; border-radius:999px; padding:0.28rem 0.7rem; background:#eef4f8; color:#0f4667; font-size:0.8rem; font-weight:700; }
      .status-chip { display:inline-flex; align-items:center; gap:0.35rem; border-radius:999px; padding:0.28rem 0.72rem; font-size:0.8rem; font-weight:700; }
      .status-chip.blocked { background:#fce9e7; color:#9b2c22; }
      .status-chip.active { background:#e8f7ee; color:#1f6a3a; }
      .subtle { color:#5d6a79; overflow-wrap:anywhere; word-break:break-word; }
      .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size:0.9rem; overflow-wrap:anywhere; word-break:break-all; }
      .row-actions { display:flex; gap:0.45rem; flex-wrap:wrap; }
      .row-actions button { border:none; border-radius:10px; padding:0.55rem 0.7rem; background:#8b2e2e; color:#fff; font:inherit; font-weight:700; cursor:pointer; }
      .pagination-bar { display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; margin-top:1rem; }
      .pagination-summary { color:#5d6a79; font-size:0.92rem; }
      .pagination-links { display:flex; align-items:center; gap:0.45rem; flex-wrap:wrap; }
      .pagination-link, .pagination-current, .pagination-ellipsis { min-width:2.4rem; padding:0.58rem 0.82rem; border-radius:12px; text-align:center; font-weight:700; }
      .pagination-link { background:#eef4f8; color:#0f4667; text-decoration:none; border:1px solid #d8e2ea; }
      .pagination-current { background:#0f5f8f; color:#fff; border:1px solid #0f5f8f; }
      .pagination-ellipsis { color:#5d6a79; }
      @media (max-width: 820px) {
        .shell { width: min(100%, calc(100% - 1rem)); padding: 0.75rem 0 1.4rem; }
        .card, .topbar { padding: 1rem; }
        .topbar, .toolbar, .toolbar-actions { flex-direction:column; align-items:stretch; }
        .search-form { flex-direction:column; align-items:stretch; }
        .search-form input, .search-form select, .search-form button, .search-form a, .toolbar-actions a, .toolbar-actions button, .row-actions button { width:100%; font-size:16px; }
        table, thead, tbody, tr, th, td { display:block; }
        thead { display:none; }
        tr { padding:0.25rem 0; border-bottom:1px solid #e0e8ee; }
        td { border:none; padding:0.35rem 0; }
        td::before { content: attr(data-label); display:block; font-size:0.78rem; color:#5d6a79; margin-bottom:0.16rem; }
        .mono { font-size:0.82rem; }
        .pagination-bar { flex-direction:column; align-items:stretch; }
        .pagination-links { justify-content:center; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="card topbar">
        <div>
          <h1 style="margin:0; color:#0f4667;">Guest Usage Monitor</h1>
          <p style="margin:0.35rem 0 0; color:#5d6a79;">ดูข้อมูล guest quota ที่ระบบใช้จริงจาก cookie, เครือข่าย และ device hint เพื่อช่วยตรวจสอบกรณีเปลี่ยน browser หรือเคลียร์ cache</p>
        </div>
        <a href="/admin">กลับหน้าแดชบอร์ด</a>
      </section>

      <section class="card">
        <form class="search-form" action="/admin/guest-usage" method="get">
          <input class="wide" type="text" name="q" value="<%= data.query %>" placeholder="ค้นหาด้วย identity type หรือ hash บางส่วน" />
          <select name="identityType">
            <% data.identityTypes.forEach((item) => { %>
              <option value="<%= item.value %>" <%= item.value === data.identityType ? 'selected' : '' %>><%= item.label %></option>
            <% }) %>
          </select>
          <input type="month" name="month" value="<%= data.usageMonth %>" />
          <select name="perPage" aria-label="จำนวนรายการต่อหน้า">
            <% [10, 20, 50].forEach((size) => { %>
              <option value="<%= size %>" <%= Number(data.pagination?.pageSize || 20) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
            <% }) %>
          </select>
          <button type="submit">ค้นหา</button>
          <% if (data.query || data.usageMonth || data.identityType || Number(data.pagination?.pageSize || 20) !== 20) { %>
            <a href="/admin/guest-usage">ล้างตัวกรอง</a>
          <% } %>
        </form>
      </section>

      <section class="grid">
        <article class="card metric-card"><div>Records เดือนนี้</div><div class="metric"><%= data.stats.totalCount %></div></article>
        <article class="card metric-card warn"><div>แตะลิมิต Guest</div><div class="metric"><%= data.stats.blockedCount %></div></article>
        <article class="card metric-card ok"><div>ค่าสูงสุดที่นับได้</div><div class="metric"><%= data.stats.maxQuestionCount %></div></article>
        <article class="card metric-card"><div>Cookie</div><div class="metric"><%= data.stats.cookieCount %></div></article>
        <article class="card metric-card"><div>Network</div><div class="metric"><%= data.stats.networkCount %></div></article>
        <article class="card metric-card"><div>Device hint</div><div class="metric"><%= data.stats.deviceHintCount %></div></article>
      </section>

      <section class="card">
        <div class="toolbar">
          <p class="subtle" style="margin:0;">เดือนที่ดูอยู่: <strong><%= data.usageMonth %></strong> | Guest จะถูกมองว่าแตะลิมิตเมื่อ question_count >= 2</p>
          <div class="toolbar-actions">
            <a href="/admin/guest-usage/export.csv?<%= new URLSearchParams({ q: data.query || '', month: data.usageMonth || '', identityType: data.identityType || '' }).toString() %>">Export CSV</a>
            <form action="/admin/guest-usage/clear" method="post" onsubmit="return confirm('ยืนยันการล้าง guest usage ตามตัวกรองปัจจุบัน?');">
              <input type="hidden" name="returnTo" value="<%= returnPath %>" />
              <input type="hidden" name="q" value="<%= data.query %>" />
              <input type="hidden" name="month" value="<%= data.usageMonth %>" />
              <input type="hidden" name="identityType" value="<%= data.identityType %>" />
              <button type="submit">ล้างตามตัวกรอง</button>
            </form>
          </div>
        </div>
        <div style="overflow:auto;">
          <table>
            <thead>
              <tr>
                <th>ประเภท identity</th>
                <th>Hash ที่ใช้ติดตาม</th>
                <th>จำนวนครั้ง</th>
                <th>สถานะ</th>
                <th>ใช้งานล่าสุด</th>
                <th>สร้างเมื่อ</th>
                <th>จัดการ</th>
              </tr>
            </thead>
            <tbody>
              <% if (!data.records.length) { %>
                <tr>
                  <td colspan="7">ไม่พบข้อมูล guest usage ตามเงื่อนไขที่เลือก</td>
                </tr>
              <% } %>
              <% data.records.forEach((record) => { %>
                <tr>
                  <td data-label="ประเภท identity"><span class="identity-chip"><%= record.identityTypeLabel %></span></td>
                  <td data-label="Hash ที่ใช้ติดตาม">
                    <div class="mono"><%= record.maskedIdentityHash %></div>
                    <div class="subtle mono"><%= record.identity_hash %></div>
                  </td>
                  <td data-label="จำนวนครั้ง"><strong><%= Number(record.question_count || 0) %></strong></td>
                  <td data-label="สถานะ">
                    <span class="status-chip <%= record.isBlocked ? 'blocked' : 'active' %>">
                      <%= record.isBlocked ? 'แตะลิมิตแล้ว' : 'ยังใช้งานได้' %>
                    </span>
                  </td>
                  <td data-label="ใช้งานล่าสุด"><%= record.last_used_at ? new Date(record.last_used_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short' }) : '-' %></td>
                  <td data-label="สร้างเมื่อ"><%= record.created_at ? new Date(record.created_at).toLocaleString('th-TH', { dateStyle: 'medium', timeStyle: 'short' }) : '-' %></td>
                  <td data-label="จัดการ">
                    <div class="row-actions">
                      <form action="/admin/guest-usage/clear" method="post" onsubmit="return confirm('ยืนยันการล้าง guest usage รายการนี้?');">
                        <input type="hidden" name="id" value="<%= record.id %>" />
                        <input type="hidden" name="returnTo" value="<%= returnPath %>" />
                        <input type="hidden" name="q" value="<%= data.query %>" />
                        <input type="hidden" name="month" value="<%= data.usageMonth %>" />
                        <input type="hidden" name="identityType" value="<%= data.identityType %>" />
                        <button type="submit">ล้างรายการนี้</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <%- include("partials/pagination", { pagination: data.pagination, basePath: "/admin/guest-usage", query: { q: data.query || "", month: data.usageMonth || "", identityType: data.identityType || "", perPage: data.pagination?.pageSize || 20 }, pageKey: "page", itemLabel: "records guest usage" }) %>
      </section>
    </div>
  </body>
</html>