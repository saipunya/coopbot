<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { margin: 0; font-family: 'Sarabun', Arial, sans-serif; background: linear-gradient(160deg, #e6eef6, #f5f9fc); color: #1f2a37; }
      .shell { width: min(980px, calc(100% - 2rem)); margin: 0 auto; padding: 1.5rem 0 3rem; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid #d8e2ea; border-radius: 20px; box-shadow: 0 18px 45px rgba(18,52,77,0.16); padding: 1.25rem; margin-bottom: 1rem; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:1rem; position:relative; overflow:hidden; }
      .topbar::before { content:""; position:absolute; inset:0; background: radial-gradient(circle at top left, rgba(255,255,255,0.36), transparent 30%), linear-gradient(135deg, rgba(255,255,255,0.16), transparent 44%); pointer-events:none; }
      .topbar > * { position:relative; z-index:1; }
      .topbar a { color: #0f4667; text-decoration:none; font-weight:700; }
      .alert { padding: 0.9rem 1rem; border-radius: 14px; margin-bottom: 1rem; }
      .alert.success { background:#e8f7ee; color:#1f6a3a; border:1px solid #b8e3c8; }
      .alert.error { background:#fce9e7; color:#9b2c22; border:1px solid #f1b8b1; }
      .detail-card { position:relative; overflow:hidden; }
      .detail-card::before { content:""; position:absolute; inset:0 0 auto; height:4px; background: linear-gradient(90deg, var(--tone), transparent 85%); }
      .detail-card > * { position:relative; z-index:1; }
      .meta { display:grid; gap:0.7rem; color:#5d6a79; }
      .meta-grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap:0.8rem; margin-bottom:1rem; }
      .meta-panel { padding:0.9rem 1rem; border-radius:16px; background:rgba(255,255,255,0.6); border:1px solid rgba(255,255,255,0.7); }
      .chip-row { display:flex; gap:0.45rem; flex-wrap:wrap; margin-bottom:1rem; }
      .plan-chip, .status-pill { display:inline-flex; align-items:center; gap:0.35rem; border-radius:999px; padding:0.34rem 0.75rem; font-size:0.82rem; font-weight:700; }
      .plan-chip.free { background:#deeffa; color:#214b69; }
      .plan-chip.pro { background:#daf2ec; color:#145147; }
      .plan-chip.premium { background:#f6e7c6; color:#6b4917; }
      .status-pill.pending { background:#fff6dd; color:#946200; }
      .status-pill.approved { background:#e8f7ee; color:#1f6a3a; }
      .status-pill.rejected { background:#fce9e7; color:#9b2c22; }
      .actions { display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:1rem; }
      .plan-editor { margin-top:1.25rem; padding:1rem; border:1px solid #d8e2ea; border-radius:16px; background:rgba(245,249,252,0.85); }
      .plan-editor form { display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center; }
      .plan-editor select { min-width:220px; border:1px solid #c8d6e2; border-radius:12px; padding:0.8rem 0.9rem; font:inherit; background:#fff; color:#1f2a37; }
      button { border:none; border-radius:12px; padding:0.8rem 1rem; font-weight:700; cursor:pointer; color:#fff; }
      .secondary { background: linear-gradient(145deg, #0f5f8f, #0d496d); }
      .approve { background: linear-gradient(145deg, #1d7a52, #16613f); }
      .reject { background: linear-gradient(145deg, #b63d2f, #922f24); }
      @media (max-width: 720px) {
        .shell { width: min(100%, calc(100% - 1rem)); padding: 0.75rem 0 1.4rem; }
        .card, .topbar { padding: 1rem; }
        .topbar { flex-direction: column; align-items: stretch; }
        .meta-grid { grid-template-columns: 1fr; }
        .chip-row { flex-direction: column; align-items: flex-start; }
        .status-pill, .plan-chip { width: fit-content; }
        .plan-editor form { flex-direction:column; align-items:stretch; }
        .plan-editor select, .plan-editor button, .actions form, .actions button { width:100%; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% const paymentStatusLabelMap = { pending: 'รอพิจารณา', approved: 'อนุมัติแล้ว', rejected: 'ปฏิเสธแล้ว' }; %>
      <% const normalizePlanCode = (value) => ({ standard: 'pro', professional: 'pro', 'premium-monthly': 'premium', 'premium-yearly': 'premium' }[String(value || '').toLowerCase()] || String(value || 'free').toLowerCase()); %>
      <% const requestPlanCode = normalizePlanCode(data.request.planCode || data.request.plan_name || 'free'); %>
      <% const currentPlanCode = normalizePlanCode(data.request.user_plan || 'free'); %>
      <% const requestTone = requestPlanCode === 'premium' ? '#8c5d1f' : requestPlanCode === 'pro' ? '#0f695f' : '#205f89'; %>
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="card topbar">
        <div>
          <h1 style="margin:0; color:#0f4667;">คำขอชำระเงิน #<%= data.request.id %></h1>
          <p style="margin:0.35rem 0 0; color:#5d6a79;">ตรวจสอบรายละเอียดคำขอและอัปเดตสถานะได้จากหน้านี้</p>
        </div>
        <a href="/admin/payment-requests">กลับไปหน้ารายการ</a>
      </section>

      <section class="card detail-card" style="--tone:<%= requestTone %>; background:<%= requestPlanCode === 'premium' ? 'linear-gradient(150deg, #f8ead3, #fffaf2)' : requestPlanCode === 'pro' ? 'linear-gradient(150deg, #daf2ec, #f9fcfb)' : 'linear-gradient(150deg, #dff1fb, #fbfdff)' %>;">
        <div class="chip-row">
          <span class="plan-chip <%= requestPlanCode %>">แพ็กเกจที่ร้องขอ <%= data.request.planLabel || data.request.plan_name %></span>
          <span class="plan-chip <%= currentPlanCode %>">ปัจจุบัน <%= data.request.userPlanLabel || data.request.user_plan || 'ฟรี' %></span>
          <span class="status-pill <%= data.request.status %>"><%= paymentStatusLabelMap[data.request.status] || data.request.status %></span>
        </div>
        <div class="meta-grid">
          <div class="meta-panel"><strong>ผู้ใช้</strong><div style="margin-top:0.35rem;"><%= data.request.user_name || '-' %><br /><span style="color:#5d6a79;"><%= data.request.user_email || '-' %></span></div></div>
          <div class="meta-panel"><strong>ยอดชำระ</strong><div style="margin-top:0.35rem;"><%= Number(data.request.amount || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> บาท</div></div>
          <div class="meta-panel"><strong>อายุแพ็กเกจปัจจุบัน</strong><div style="margin-top:0.35rem;"><%= data.request.userPlanExpiresAt ? new Date(data.request.userPlanExpiresAt).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : '-' %></div></div>
        </div>
        <div class="meta">
          <div><strong>แพ็กเกจที่ร้องขอ:</strong> <%= data.request.planLabel || data.request.plan_name %></div>
          <div><strong>สร้างเมื่อ:</strong> <%= data.request.created_at ? new Date(data.request.created_at).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %></div>
          <div><strong>ตรวจสอบเมื่อ:</strong> <%= data.request.reviewed_at ? new Date(data.request.reviewed_at).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %></div>
          <div><strong>ตรวจสอบโดย:</strong> <%= data.request.reviewed_by || "-" %></div>
          <div><strong>หมายเหตุ:</strong> <%= data.request.note || "-" %></div>
          <% if (data.request.slip_image) { %>
            <div><strong>สลิป:</strong> <a href="<%= data.request.slip_image %>" target="_blank" rel="noopener">ดูภาพสลิป</a></div>
          <% } %>
        </div>

        <% if (data.request.status === "pending") { %>
          <div class="plan-editor">
            <strong style="display:block; margin-bottom:0.55rem; color:#0f4667;">ปรับแพ็กเกจของคำขอนี้ก่อนอนุมัติ</strong>
            <form action="/admin/payment-requests/update-plan" method="post">
              <input type="hidden" name="id" value="<%= data.request.id %>" />
              <input type="hidden" name="returnTo" value="/admin/payment-requests/<%= data.request.id %>" />
              <select name="planCode" aria-label="เลือกแพ็กเกจใหม่">
                <% data.plans.forEach((plan) => { %>
                  <option value="<%= plan.code %>" <%= plan.code === data.request.planCode ? "selected" : "" %>>
                    <%= plan.label %> - <%= Number(plan.priceBaht || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> บาท
                  </option>
                <% }) %>
              </select>
              <button class="secondary" type="submit">อัปเดตแพ็กเกจ</button>
            </form>
          </div>

          <div class="actions">
            <form action="/admin/payment-requests/approve" method="post" onsubmit="return confirm('อนุมัติคำขอนี้และเปิดใช้งานแพ็กเกจที่ร้องขอเป็นเวลา 30 วันใช่หรือไม่');">
              <input type="hidden" name="id" value="<%= data.request.id %>" />
              <button class="approve" type="submit">อนุมัติ</button>
            </form>
            <form action="/admin/payment-requests/reject" method="post" onsubmit="return confirm('ปฏิเสธคำขอนี้และคงแพ็กเกจปัจจุบันของผู้ใช้ไว้ใช่หรือไม่');">
              <input type="hidden" name="id" value="<%= data.request.id %>" />
              <button class="reject" type="submit">ปฏิเสธ</button>
            </form>
          </div>
        <% } %>
      </section>
    </div>
  </body>
</html>
