<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { margin: 0; font-family: 'Sarabun', Arial, sans-serif; background: linear-gradient(160deg, #e6eef6, #f5f9fc); color: #1f2a37; }
      .shell { width: min(980px, calc(100% - 2rem)); margin: 0 auto; padding: 1.5rem 0 3rem; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid #d8e2ea; border-radius: 20px; box-shadow: 0 18px 45px rgba(18,52,77,0.16); padding: 1.25rem; margin-bottom: 1rem; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:1rem; }
      .topbar a { color: #0f4667; text-decoration:none; font-weight:700; }
      .alert { padding: 0.9rem 1rem; border-radius: 14px; margin-bottom: 1rem; }
      .alert.success { background:#e8f7ee; color:#1f6a3a; border:1px solid #b8e3c8; }
      .alert.error { background:#fce9e7; color:#9b2c22; border:1px solid #f1b8b1; }
      .meta { display:grid; gap:0.7rem; color:#5d6a79; }
      .actions { display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:1rem; }
      button { border:none; border-radius:12px; padding:0.8rem 1rem; font-weight:700; cursor:pointer; color:#fff; }
      .approve { background: linear-gradient(145deg, #1d7a52, #16613f); }
      .reject { background: linear-gradient(145deg, #b63d2f, #922f24); }
    </style>
  </head>
  <body>
    <div class="shell">
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="card topbar">
        <div>
          <h1 style="margin:0; color:#0f4667;">Payment Request #<%= data.request.id %></h1>
          <p style="margin:0.35rem 0 0; color:#5d6a79;">Review payment request details and update status.</p>
        </div>
        <a href="/admin/payment-requests">Back to list</a>
      </section>

      <section class="card">
        <div class="meta">
          <div><strong>User:</strong> <%= data.request.user_name || "-" %></div>
          <div><strong>Email:</strong> <%= data.request.user_email || "-" %></div>
          <div><strong>Current plan:</strong> <%= data.request.userPlanLabel || data.request.user_plan || "Free" %></div>
          <div><strong>Current plan expires at:</strong> <%= data.request.userPlanExpiresAt ? new Date(data.request.userPlanExpiresAt).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %></div>
          <div><strong>Requested plan:</strong> <%= data.request.planLabel || data.request.plan_name %></div>
          <div><strong>Amount:</strong> <%= Number(data.request.amount || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> THB</div>
          <div><strong>Status:</strong> <%= data.request.status %></div>
          <div><strong>Created:</strong> <%= data.request.created_at ? new Date(data.request.created_at).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %></div>
          <div><strong>Reviewed at:</strong> <%= data.request.reviewed_at ? new Date(data.request.reviewed_at).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %></div>
          <div><strong>Reviewed by:</strong> <%= data.request.reviewed_by || "-" %></div>
          <div><strong>Note:</strong> <%= data.request.note || "-" %></div>
          <% if (data.request.slip_image) { %>
            <div><strong>Slip:</strong> <a href="<%= data.request.slip_image %>" target="_blank" rel="noopener">View slip image</a></div>
          <% } %>
        </div>

        <% if (data.request.status === "pending") { %>
          <div class="actions">
            <form action="/admin/payment-requests/approve" method="post" onsubmit="return confirm('Approve this payment request and activate the requested plan for 30 days?');">
              <input type="hidden" name="id" value="<%= data.request.id %>" />
              <button class="approve" type="submit">Approve</button>
            </form>
            <form action="/admin/payment-requests/reject" method="post" onsubmit="return confirm('Reject this payment request and keep the user current plan unchanged?');">
              <input type="hidden" name="id" value="<%= data.request.id %>" />
              <button class="reject" type="submit">Reject</button>
            </form>
          </div>
        <% } %>
      </section>
    </div>
  </body>
</html>
