<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
      body { margin: 0; font-family: 'Sarabun', Arial, sans-serif; background: linear-gradient(160deg, #e6eef6, #f5f9fc); color: #1f2a37; }
      .shell { width: min(1120px, calc(100% - 2rem)); margin: 0 auto; padding: 1.5rem 0 3rem; }
      .card { background: rgba(255,255,255,0.9); border: 1px solid #d8e2ea; border-radius: 20px; box-shadow: 0 18px 45px rgba(18,52,77,0.16); padding: 1.25rem; margin-bottom: 1rem; }
      .topbar { display:flex; justify-content:space-between; align-items:center; gap:1rem; position:relative; overflow:hidden; }
      .topbar::before { content:""; position:absolute; inset:0; background: radial-gradient(circle at top left, rgba(255,255,255,0.36), transparent 30%), linear-gradient(135deg, rgba(255,255,255,0.16), transparent 44%); pointer-events:none; }
      .topbar > * { position:relative; z-index:1; }
      .topbar a { color: #0f4667; text-decoration:none; font-weight:700; }
      .alert { padding: 0.9rem 1rem; border-radius: 14px; margin-bottom: 1rem; }
      .alert.success { background:#e8f7ee; color:#1f6a3a; border:1px solid #b8e3c8; }
      .alert.error { background:#fce9e7; color:#9b2c22; border:1px solid #f1b8b1; }
      .grid { display:grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap:1rem; }
      .metric-card { position:relative; overflow:hidden; }
      .metric-card::before { content:""; position:absolute; inset:0 0 auto; height:4px; background: linear-gradient(90deg, #0f5f8f, transparent 85%); }
      .metric-card.free::before { background: linear-gradient(90deg, #205f89, transparent 85%); }
      .metric-card.paid::before { background: linear-gradient(90deg, #0f695f, transparent 85%); }
      .metric-card.active::before { background: linear-gradient(90deg, #1d7a52, transparent 85%); }
      .metric { font-size: 1.8rem; font-weight: 700; color: #0f4667; margin: 0.3rem 0 0; }
      .search-form { display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center; }
      .search-form input { flex:1 1 320px; border:1px solid #c8d6e2; border-radius:14px; padding:0.85rem 1rem; font:inherit; }
      .search-form button, .search-form a { border:none; border-radius:14px; padding:0.85rem 1rem; font:inherit; font-weight:700; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; justify-content:center; }
      .search-form button { background:#0f5f8f; color:#fff; }
      .search-form a { background:#eef4f8; color:#0f4667; border:1px solid #d8e2ea; }
      .soft-list { list-style:none; padding:0; margin:0; display:grid; gap:0.9rem; }
      .user-card { padding:1rem; border:1px solid #d8e2ea; border-radius:22px; background: rgba(255,255,255,0.82); position:relative; overflow:hidden; }
      .user-card::before { content:""; position:absolute; inset:0 0 auto; height:4px; background: linear-gradient(90deg, var(--tone), transparent 85%); }
      .user-head { display:flex; justify-content:space-between; align-items:flex-start; gap:1rem; flex-wrap:wrap; }
      .identity { display:flex; gap:0.85rem; align-items:center; }
      .user-card, .user-head, .identity, .meta, .plan-chip-row, .plan-hint { min-width:0; overflow-wrap:anywhere; word-break:break-word; }
      .avatar { width:48px; height:48px; border-radius:50%; object-fit:cover; border:1px solid #d8e2ea; background:#e7eef5; }
      .avatar-fallback { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#dbe9f4; color:#0f4667; font-weight:700; border:1px solid #d8e2ea; }
      .meta { color:#5d6a79; font-size:0.94rem; margin-top:0.6rem; line-height:1.6; }
      .status-chip { display:inline-flex; align-items:center; gap:0.35rem; border-radius:999px; padding:0.32rem 0.75rem; font-size:0.84rem; font-weight:700; }
      .status-chip.active { background:#e8f7ee; color:#1f6a3a; }
      .status-chip.inactive { background:#fce9e7; color:#9b2c22; }
      .plan-chip-row { display:flex; gap:0.45rem; flex-wrap:wrap; margin-top:0.7rem; }
      .plan-chip { display:inline-flex; align-items:center; gap:0.35rem; border-radius:999px; padding:0.32rem 0.72rem; font-size:0.78rem; font-weight:700; }
      .plan-chip.free { background:#deeffa; color:#214b69; }
      .plan-chip.pro { background:#daf2ec; color:#145147; }
      .plan-chip.premium { background:#f6e7c6; color:#6b4917; }
      .plan-form { margin-top:1rem; display:grid; gap:0.75rem; }
      .plan-controls { display:grid; grid-template-columns: minmax(180px, 220px) minmax(140px, 180px) auto; gap:0.75rem; align-items:center; }
      .plan-form select, .plan-form input { border:1px solid #c8d6e2; border-radius:12px; padding:0.78rem 0.9rem; font:inherit; background:#fff; color:#1f2a37; width:100%; box-sizing:border-box; }
      .plan-form button { border:none; border-radius:12px; padding:0.82rem 1rem; background:#0f5f8f; color:#fff; font:inherit; font-weight:700; cursor:pointer; }
      .plan-hint { color:#5d6a79; font-size:0.88rem; }
      .pagination-bar { display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; margin-top:1rem; }
      .pagination-summary { color:#5d6a79; font-size:0.92rem; }
      .pagination-links { display:flex; align-items:center; gap:0.45rem; flex-wrap:wrap; }
      .pagination-link, .pagination-current, .pagination-ellipsis { min-width:2.4rem; padding:0.58rem 0.82rem; border-radius:12px; text-align:center; font-weight:700; }
      .pagination-link { background:#eef4f8; color:#0f4667; text-decoration:none; border:1px solid #d8e2ea; }
      .pagination-current { background:#0f5f8f; color:#fff; border:1px solid #0f5f8f; }
      .pagination-ellipsis { color:#5d6a79; }
      @media (max-width: 820px) {
        .shell { width: min(100%, calc(100% - 1rem)); padding: 0.75rem 0 1.4rem; }
        .card, .topbar { padding: 1rem; }
        .topbar { flex-direction: column; align-items: stretch; }
        .search-form { flex-direction: column; align-items: stretch; }
        .search-form input { flex-basis: auto; }
        .search-form input, .search-form button, .search-form a, .plan-form select, .plan-form input, .plan-form button { font-size:16px; }
        .plan-controls { grid-template-columns: 1fr; }
        .plan-form button, .search-form button, .search-form a { width:100%; }
        .user-head, .identity { flex-direction: column; align-items: flex-start; }
        .status-chip { width: fit-content; }
        .pagination-bar { flex-direction:column; align-items:stretch; }
        .pagination-links { justify-content:center; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <% const normalizePlanCode = (value) => ({ standard: 'pro', professional: 'pro', 'premium-monthly': 'premium', 'premium-yearly': 'premium' }[String(value || '').toLowerCase()] || String(value || 'free').toLowerCase()); %>
      <% if (successMessage) { %><div class="alert success"><%= successMessage %></div><% } %>
      <% if (errorMessage) { %><div class="alert error"><%= errorMessage %></div><% } %>

      <section class="card topbar">
        <div>
          <h1 style="margin:0; color:#0f4667;">จัดการผู้ใช้งาน</h1>
          <p style="margin:0.35rem 0 0; color:#5d6a79;">ปรับแพ็กเกจผู้ใช้งานและกำหนดระยะเวลาใช้งานได้จากหน้านี้</p>
        </div>
        <a href="/admin">กลับหน้าแดชบอร์ด</a>
      </section>

      <section class="card">
        <form class="search-form" action="/admin/users" method="get">
          <input type="text" name="q" value="<%= data.query %>" placeholder="ค้นหาด้วยชื่อ, อีเมล หรือ Google ID" />
          <select name="perPage" aria-label="จำนวนรายการต่อหน้า">
            <% [10, 20, 50].forEach((size) => { %>
              <option value="<%= size %>" <%= Number(data.pagination?.pageSize || 12) === size ? 'selected' : '' %>><%= size %> รายการ/หน้า</option>
            <% }) %>
          </select>
          <button type="submit">ค้นหาผู้ใช้</button>
          <% if (data.query || Number(data.pagination?.pageSize || 12) !== 12) { %>
            <a href="/admin/users">ล้างคำค้น</a>
          <% } %>
        </form>
      </section>

      <section class="grid">
        <article class="card metric-card"><div>ผู้ใช้ทั้งหมด</div><div class="metric"><%= data.totalCount %></div></article>
        <article class="card metric-card free"><div>แพ็กเกจฟรี</div><div class="metric"><%= data.freeCount %></div></article>
        <article class="card metric-card paid"><div>แพ็กเกจชำระเงิน</div><div class="metric"><%= data.paidCount %></div></article>
        <article class="card metric-card active"><div>สถานะใช้งาน</div><div class="metric"><%= data.activeCount %></div></article>
      </section>

      <section class="card">
        <ul class="soft-list">
          <% if (!data.users.length) { %>
            <li class="user-card">ไม่พบผู้ใช้งานตามคำค้นนี้</li>
          <% } %>
          <% data.users.forEach((account) => { %>
            <% const accountPlanCode = normalizePlanCode(account.planCode || account.plan || 'free'); %>
            <% const accountTone = accountPlanCode === 'premium' ? '#8c5d1f' : accountPlanCode === 'pro' ? '#0f695f' : '#205f89'; %>
            <li class="user-card" style="--tone:<%= accountTone %>; background:<%= accountPlanCode === 'premium' ? 'linear-gradient(150deg, #f8ead3, #fffaf2)' : accountPlanCode === 'pro' ? 'linear-gradient(150deg, #daf2ec, #f9fcfb)' : 'linear-gradient(150deg, #dff1fb, #fbfdff)' %>;">
              <div class="user-head">
                <div class="identity">
                  <% if (account.avatar_url) { %>
                    <img class="avatar" src="<%= account.avatar_url %>" alt="<%= account.name || account.email || 'user' %>" />
                  <% } else { %>
                    <div class="avatar-fallback"><%= String(account.name || account.email || "U").trim().charAt(0).toUpperCase() %></div>
                  <% } %>
                  <div>
                    <strong style="display:block; color:#0f4667;"><%= account.name || "-" %></strong>
                    <div style="color:#5d6a79;"><%= account.email || "-" %></div>
                    <div class="plan-chip-row">
                      <span class="plan-chip <%= accountPlanCode %>"><%= account.planLabel %></span>
                      <span class="plan-chip <%= accountPlanCode %>"><%= Number.isFinite(account.monthlyLimit) ? `${account.monthlyLimit} คำถาม/เดือน` : 'ไม่จำกัดจำนวนคำถาม' %></span>
                    </div>
                  </div>
                </div>
                <span class="status-chip <%= account.status === 'active' ? 'active' : 'inactive' %>"><%= account.status === 'active' ? 'ใช้งานอยู่' : 'ไม่ใช้งาน' %></span>
              </div>

              <div class="meta">
                แพ็กเกจปัจจุบัน: <strong><%= account.planLabel %></strong>
                <% if (Number.isFinite(account.monthlyLimit)) { %> | โควต้า: <%= account.monthlyLimit %> คำถาม/เดือน<% } else { %> | โควต้า: ไม่จำกัด<% } %>
                | ประวัติการค้นหา: <%= account.searchHistoryRetentionLabel %>
                <br />
                เริ่มใช้: <%= account.plan_started_at ? new Date(account.plan_started_at).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %>
                | หมดอายุ: <%= account.planExpiresAt ? new Date(account.planExpiresAt).toLocaleString("th-TH", { dateStyle: "medium", timeStyle: "short" }) : "-" %>
                <% if (account.remainingDays !== null) { %>
                  | คงเหลือ: <%= account.remainingDays > 0 ? `${account.remainingDays} วัน` : "หมดอายุแล้ว" %>
                <% } %>
              </div>

              <form class="plan-form" action="/admin/users/update-plan" method="post">
                <input type="hidden" name="userId" value="<%= account.id %>" />
                <input type="hidden" name="returnTo" value="<%= returnPath %>" />
                <div class="plan-controls">
                  <select name="planCode" data-plan-select>
                    <% data.plans.forEach((plan) => { %>
                      <option value="<%= plan.code %>" <%= plan.code === account.planCode ? "selected" : "" %>>
                        <%= plan.label %>
                        <% if (Number(plan.priceBaht || 0) > 0) { %>
                          - <%= Number(plan.priceBaht || 0).toLocaleString("th-TH", { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %> บาท
                        <% } %>
                      </option>
                    <% }) %>
                  </select>
                  <input
                    type="number"
                    name="durationDays"
                    min="1"
                    step="1"
                    value="<%= account.remainingDays && account.remainingDays > 0 ? account.remainingDays : data.defaultPlanDurationDays %>"
                    data-duration-input
                  />
                  <button type="submit">บันทึกแพ็กเกจ</button>
                </div>
                <div class="plan-hint" data-plan-hint>
                  ถ้าเลือกแพ็กเกจฟรี ระบบจะล้างวันหมดอายุแพ็กเกจอัตโนมัติ ส่วนแพ็กเกจแบบชำระเงินจะเริ่มนับจากเวลาที่บันทึก
                </div>
              </form>
            </li>
          <% }) %>
        </ul>
        <%- include("partials/pagination", { pagination: data.pagination, basePath: "/admin/users", query: { q: data.query || "", perPage: data.pagination?.pageSize || 12 }, pageKey: "page", itemLabel: "ผู้ใช้งาน" }) %>
      </section>
    </div>

    <script>
      document.querySelectorAll(".plan-form").forEach((form) => {
        const select = form.querySelector("[data-plan-select]");
        const durationInput = form.querySelector("[data-duration-input]");
        const hint = form.querySelector("[data-plan-hint]");

        const syncPlanFields = () => {
          const isFree = select && select.value === "free";
          if (durationInput) {
            durationInput.disabled = isFree;
          }
          if (hint) {
            hint.textContent = isFree
              ? "แพ็กเกจฟรีจะล้างวันหมดอายุแพ็กเกจและกลับเป็นสิทธิ์ใช้งานแบบฟรีทันที"
              : "แพ็กเกจแบบชำระเงินจะตั้ง plan_started_at ใหม่ และคำนวณวันหมดอายุจากจำนวนวันที่กำหนด";
          }
        };

        if (select) {
          select.addEventListener("change", syncPlanFields);
          syncPlanFields();
        }
      });
    </script>
  </body>
</html>
