PORT=3000
NODE_ENV=development
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=coopbot
DB_CONNECTION_LIMIT=10
SESSION_SECRET=change-this-session-secret
MAX_UPLOAD_BYTES=20971520
CHUNK_SIZE=1400
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ENABLE_EMBEDDING=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PDF_TEXT_MIN_LENGTH=80
PDF_OCR_SCALE=2.5
PDF_OCR_MAX_PAGES=20
USE_MOCK_AI=true
USE_MOCK_TELEGRAM=false
USE_MOCK_PAYMENT=false
CHAT_REQUEST_TIMEOUT_MS=25000
CHAT_BUDGET_BUFFER_MS=3000
OPENAI_TIMEOUT_MS=20000
OPENAI_EMBEDDING_TIMEOUT_MS=4000
LAW_CHATBOT_HYBRID_SEARCH_TIMEOUT_MS=4000
LAW_CHATBOT_CONTEXT_RESEARCH_MIN_BUDGET_MS=7000
LAW_CHATBOT_INTERNET_SEARCH_MIN_BUDGET_MS=5000
LAW_CHATBOT_AI_SUMMARY_MIN_BUDGET_MS=2500

OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_AUTH_DEBUG=0
